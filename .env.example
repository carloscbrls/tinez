# Yahoo OAuth — Required Environment Variables
# Set these in Netlify dashboard (Settings > Environment Variables)
#
# YAHOO_CLIENT_ID
#   Found in Yahoo Developer Network > My Apps > {your app} > Client ID
#   Current value: dj0yJmk9WHBRT3hndWh0NDAxJmQ9WVdrOWVEZExWbkZuY0hZbWNHbzlNQT09JnM9Y29uc3VtZXJzZWNyZXQmc3Y9MCZ4PWVk
#
# YAHOO_CLIENT_SECRET
#   Found in Yahoo Developer Network > My Apps > {your app} > Client Secret
#   ⚠️ DO NOT hardcode this in source code. Use Netlify env vars.
#
# YAHOO_REDIRECT_URI (optional)
#   Default: https://tinez.netlify.app/api/yahoo/callback
#   Only change if deploying to a custom domain.
#
# NETLIFY_BLOB_STORE (auto-set by Netlify)
#   Used for persistent OAuth token storage across function cold starts.
#   If not available, tokens are stored in-memory and users re-authenticate hourly.

YAHOO_CLIENT_ID=
YAHOO_CLIENT_SECRET=
YAHOO_REDIRECT_URI=https://tinez.netlify.app/api/yahoo/callback

# FantasyNerds API — Optional IDP Projections
# Sign up at https://www.fantasynerds.com/create-account
# Free tier available, $74.95/yr for full access
# Provides expert-curated IDP weekly projections and draft rankings
#
# FANTASYNERDS_API_KEY
#   Found in your FantasyNerds account dashboard after signing up.
#   Without this key, IDP projections use the TINEZ statistical model.
#   With this key, projections blend FantasyNerds expert data (70%) with
#   the TINEZ model (30%) for more accurate weekly projections.

FANTASYNERDS_API_KEY=
