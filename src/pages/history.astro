---
import Layout from "../layouts/Layout.astro";
import { getChampionsByYear, getCarlitosChampionships, getCarlitosRunnerUps, getChampionCounts } from "../data/champions";
const allChampions = getChampionsByYear();
const carlitosWins = getCarlitosChampionships();
const carlitosRunnerUps = getCarlitosRunnerUps();
const counts = getChampionCounts();
---

<Layout title="History">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">H</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">History</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 12 Seasons (2014-2025)</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Carlitos Stats -->
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-amber-400">{carlitosWins.length}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Championships</div>
      <div class="text-xs text-zinc-600 mt-0.5">2015, 2016, 2018</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-zinc-100">{carlitosRunnerUps.length}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Runner-Up</div>
      <div class="text-xs text-zinc-600 mt-0.5">2014, 2019, 2022</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-emerald-400">{allChampions.length}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Seasons</div>
      <div class="text-xs text-zinc-600 mt-0.5">12 years of TINEZ</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-zinc-100">{counts.length}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Different Champions</div>
      <div class="text-xs text-zinc-600 mt-0.5">{counts.filter(c => c.wins > 0).length} unique winners</div>
    </div>
  </div>

  <!-- All-Time Leaderboard -->
  <div class="mb-8">
    <h2 class="text-lg font-bold text-zinc-100 mb-4">🏆 All-Time Leaderboard</h2>
    <div class="glass-card rounded-xl overflow-hidden">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-zinc-700/50 bg-zinc-800/30">
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">#</th>
            <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Owner</th>
            <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-amber-500">🏆 Wins</th>
            <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-zinc-500">🥈 Runner-Up</th>
            <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-zinc-500">🥉 Third</th>
            <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-zinc-500">Total Podiums</th>
          </tr>
        </thead>
        <tbody>
          {counts.map((c, i) => {
            const total = c.wins + c.runnerUps + c.thirds;
            const isYou = c.owner === "Carlitos";
            return (
              <tr class="border-b border-zinc-800/30 hover:bg-zinc-800/20 transition-colors" class:list={[isYou ? 'bg-amber-500/5' : '']}>
                <td class="px-4 py-3 text-zinc-500 font-mono text-xs">{i + 1}</td>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <span class="font-medium" class:list={[isYou ? 'text-amber-400' : 'text-zinc-200']}>{c.owner}</span>
                    {isYou && <span class="rounded-full bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-400">YOU</span>}
                  </div>
                </td>
                <td class="px-4 py-3 text-center">
                  <span class="font-bold text-amber-400">{c.wins}</span>
                </td>
                <td class="px-4 py-3 text-center font-medium text-zinc-300">{c.runnerUps}</td>
                <td class="px-4 py-3 text-center font-medium text-zinc-300">{c.thirds}</td>
                <td class="px-4 py-3 text-center font-bold text-zinc-100">{total}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Championship History -->
  <div>
    <h2 class="text-lg font-bold text-zinc-100 mb-4">📅 Season-by-Season</h2>
    <div class="grid gap-4 stagger-children">
      {allChampions.map(c => {
        const isChampion = c.championOwner === "Carlitos";
        const isRunnerUp = c.runnerUpOwner === "Carlitos";
        const isThird = c.thirdPlaceOwner === "Carlitos";
        return (
          <div class="glass-card rounded-xl p-5">
            <div class="flex items-center justify-between mb-3">
              <div class="flex items-center gap-3">
                <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-sm font-bold text-white shadow-lg shadow-amber-500/20">{c.year}</div>
                <div>
                  <h3 class="font-bold text-zinc-100">{c.year} Season</h3>
                  <span class="text-xs text-zinc-500">League ID: {c.leagueId}</span>
                </div>
              </div>
              <a href={`https://football.fantasysports.yahoo.com/league/riptinez/${c.year}`} target="_blank" class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 hover:bg-zinc-700 transition-all">
                View Season →
              </a>
            </div>
            <div class="grid gap-3 sm:grid-cols-3">
              <div class="rounded-lg p-3" class:list={[isChampion ? 'bg-amber-500/10 border border-amber-500/20' : 'bg-zinc-800/20']}>
                <div class="flex items-center gap-1.5 mb-1">
                  <span class="text-sm">🏆</span>
                  <span class="text-xs font-medium uppercase tracking-wider text-amber-500">Champion</span>
                </div>
                <div class="font-semibold text-sm text-zinc-100">{c.champion}</div>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class="text-xs text-zinc-500">{c.championOwner}</span>
                  {isChampion && <span class="rounded-full bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-400">YOU</span>}
                </div>
              </div>
              <div class="rounded-lg p-3" class:list={[isRunnerUp ? 'bg-zinc-600/10 border border-zinc-500/20' : 'bg-zinc-800/20']}>
                <div class="flex items-center gap-1.5 mb-1">
                  <span class="text-sm">🥈</span>
                  <span class="text-xs font-medium uppercase tracking-wider text-zinc-400">Runner-Up</span>
                </div>
                <div class="font-semibold text-sm text-zinc-100">{c.runnerUp}</div>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class="text-xs text-zinc-500">{c.runnerUpOwner}</span>
                  {isRunnerUp && <span class="rounded-full bg-zinc-500/10 px-1.5 py-0.5 text-[10px] font-medium text-zinc-400">YOU</span>}
                </div>
              </div>
              <div class="rounded-lg p-3" class:list={[isThird ? 'bg-amber-700/10 border border-amber-700/20' : 'bg-zinc-800/20']}>
                <div class="flex items-center gap-1.5 mb-1">
                  <span class="text-sm">🥉</span>
                  <span class="text-xs font-medium uppercase tracking-wider text-zinc-400">Third Place</span>
                </div>
                <div class="font-semibold text-sm text-zinc-100">{c.thirdPlace}</div>
                <div class="flex items-center gap-1.5 mt-0.5">
                  <span class="text-xs text-zinc-500">{c.thirdPlaceOwner}</span>
                  {isThird && <span class="rounded-full bg-amber-700/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-600">YOU</span>}
                </div>
              </div>
            </div>
            <div class="mt-3 text-xs text-zinc-600">
              Your finish: <span class="font-medium text-zinc-400">{c.finish}</span>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>
