---
import Layout from "../layouts/Layout.astro";
import { teams } from "../data/teams";

const sortedTeams = [...teams].sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="Standings">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📊</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Pre-Season Standings</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2026 Season · Pre-Season</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Standings Table -->
  <div class="glass-card-static rounded-xl overflow-x-auto">
    <table class="premium-table">
      <thead>
        <tr>
          <th class="w-8">#</th>
          <th>Team</th>
          <th class="text-center">W</th>
          <th class="text-center">L</th>
          <th class="text-center">T</th>
          <th class="text-center">Pct</th>
          <th class="text-right">PF</th>
          <th class="text-right">PA</th>
          <th class="text-right">Diff</th>
          <th class="text-center">Streak</th>
        </tr>
      </thead>
      <tbody>
        {sortedTeams.map((t, i) => (
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td class="text-zinc-500 font-mono text-xs">{i + 1}</td>
            <td>
              <div class="flex items-center gap-2.5">
                <div class="h-8 w-8 rounded-lg flex items-center justify-center text-xs font-bold text-white" style={`background: linear-gradient(135deg, ${t.primaryColor}, ${t.secondaryColor})`}>
                  {t.shortName}
                </div>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">{t.name}</div>
                  <div class="text-[10px] text-zinc-500">{t.owner}</div>
                </div>
              </div>
            </td>
            <td class="text-center font-mono text-sm font-semibold text-zinc-500">0</td>
            <td class="text-center font-mono text-sm text-zinc-500">0</td>
            <td class="text-center font-mono text-sm text-zinc-500">0</td>
            <td class="text-center font-mono text-xs text-zinc-500">.000</td>
            <td class="text-right font-mono text-sm text-zinc-500">0.0</td>
            <td class="text-right font-mono text-sm text-zinc-500">0.0</td>
            <td class="text-right font-mono text-sm text-zinc-500">0.0</td>
            <td class="text-center">
              <span class="text-xs text-zinc-600">—</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Pre-Season Notice -->
  <div class="mt-8 glass-card-accent rounded-xl p-6 text-center">
    <div class="text-4xl mb-3">🏖️</div>
    <h2 class="text-lg font-bold text-amber-400 mb-1">Pre-Season</h2>
    <p class="text-sm text-zinc-500">The 2026 season hasn't started yet. Standings will update once Week 1 kicks off.</p>
    <p class="text-xs text-zinc-600 mt-1">14 teams · All 0-0-0 · Season starts September 2026</p>
  </div>
</Layout>
