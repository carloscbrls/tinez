---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Blog | TINEZ">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📝</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">TINEZ Blog</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Fantasy football analysis, rankings, and insights</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
    <a href="/blog/2026-ppr-top-50" class="group block rounded-xl border border-zinc-800 bg-zinc-900/50 p-6 hover:border-amber-500/40 transition-all">
      <div class="text-3xl mb-3">🏆</div>
      <h2 class="text-lg font-bold text-white group-hover:text-amber-400 transition-colors">2026 PPR Draft Rankings: Top 50</h2>
      <p class="mt-2 text-sm text-zinc-400">FantasyNerds consensus PPR rankings for the 2026 season. Bijan Robinson leads the pack at RB1 with 20.4 projected PPR points per game.</p>
      <div class="mt-3 flex items-center gap-2 text-xs text-zinc-500">
        <span>Jun 27, 2026</span>
        <span>·</span>
        <span>3 min read</span>
      </div>
    </a>
  </div>
</Layout>
