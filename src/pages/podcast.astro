---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Podcast">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🎙️</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">TINEZ Podcast</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Weekly Matchup Recaps · Auto-Generated Audio</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pre-Season Notice -->
  <div class="glass-card-accent rounded-xl p-12 text-center mb-8">
    <div class="text-5xl mb-4">🎙️</div>
    <h2 class="text-xl font-bold text-amber-400 mb-2">Pre-Season — Podcast episodes coming soon</h2>
    <p class="text-zinc-400">Weekly podcast episodes will be generated once the season starts.</p>
  </div>

  <!-- About -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">🎙️</span>
      <h2 class="text-lg font-bold text-zinc-100">About the TINEZ Podcast</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-amber-400 mb-2">How It Works</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Each week's matchups are analyzed from league data</li>
          <li>• A full podcast script is auto-generated with narratives</li>
          <li>• Top performers, blowouts, and close games highlighted</li>
          <li>• Audio generated via Microsoft Edge TTS (neural voices)</li>
          <li>• Two voices: Christopher (narrator) + Guy (color commentator)</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Episode Format</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• <strong class="text-zinc-200">Intro</strong> — Week overview and league leader</li>
          <li>• <strong class="text-zinc-200">Matchups</strong> — Every game broken down</li>
          <li>• <strong class="text-zinc-200">Highlights</strong> — Top score, blowout, close game</li>
          <li>• <strong class="text-zinc-200">Outro</strong> — Standings update and preview</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
