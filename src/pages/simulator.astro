---
import Layout from "../layouts/Layout.astro";
import { fetchRosters, fetchUsers, fetchAllMatchups, LEAGUE_CONFIG } from "../data/sleeper-api";

const [rosters, users, matchupsByWeek] = await Promise.all([
  fetchRosters(),
  fetchUsers(),
  fetchAllMatchups(1, 18),
]);

const userMap = new Map(users.map(u => [u.user_id, u]));
const teamNameMap = new Map(rosters.map(r => {
  const user = userMap.get(r.owner_id);
  return [r.roster_id, user?.metadata?.team_name || user?.display_name || `Team ${r.roster_id}`];
}));

// Collect all weekly scores per team
const teamScores = new Map<number, number[]>();
for (const [, m] of matchupsByWeek) {
  for (const matchup of m) {
    if (!teamScores.has(matchup.roster_id)) teamScores.set(matchup.roster_id, []);
    teamScores.get(matchup.roster_id)!.push(matchup.points);
  }
}

// Calculate what-if records
const whatIf: { rosterId: number; name: string; actualWins: number; actualLosses: number; bestWins: number; worstWins: number; avgWins: number; luckScore: number }[] = [];

for (const [rosterId, scores] of teamScores) {
  const name = teamNameMap.get(rosterId) || `Team ${rosterId}`;
  const roster = rosters.find(r => r.roster_id === rosterId);
  const actualWins = roster?.settings.wins || 0;
  const actualLosses = roster?.settings.losses || 0;

  // Simulate against every other team's weekly scores
  let bestWins = 0;
  let worstWins = 0;
  let totalWins = 0;
  let simCount = 0;

  for (const [otherId, otherScores] of teamScores) {
    if (otherId === rosterId) continue;
    
    let wins = 0;
    let losses = 0;
    const minWeeks = Math.min(scores.length, otherScores.length);
    
    for (let w = 0; w < minWeeks; w++) {
      if (scores[w] > otherScores[w]) wins++;
      else losses++;
    }
    
    totalWins += wins;
    simCount++;
    if (wins > bestWins) bestWins = wins;
    if (wins < worstWins || worstWins === 0) worstWins = wins;
  }

  const avgWins = totalWins / simCount;
  const luckScore = actualWins - avgWins;

  whatIf.push({ rosterId, name, actualWins, actualLosses, bestWins, worstWins, avgWins: Math.round(avgWins * 10) / 10, luckScore: Math.round(luckScore * 10) / 10 });
}

whatIf.sort((a, b) => b.actualWins - a.actualWins);

// Luckiest and unluckiest
const luckiest = [...whatIf].sort((a, b) => b.luckScore - a.luckScore);
const unluckiest = [...whatIf].sort((a, b) => a.luckScore - b.luckScore);
---

<Layout title="Schedule Simulator">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🔮</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Schedule Simulator</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · What-If Records · Luck Analysis</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- How It Works -->
  <div class="glass-card-accent rounded-xl p-5 mb-8">
    <div class="flex items-center gap-3">
      <span class="text-2xl">🔮</span>
      <div>
        <h2 class="text-sm font-bold text-amber-400">How It Works</h2>
        <p class="text-xs text-zinc-500 mt-0.5">We simulate each team's weekly score against every other team's weekly score to see what their record would be with a different schedule. Positive luck = you won more games than average. Negative luck = your record doesn't reflect how good your team was.</p>
      </div>
    </div>
  </div>

  <!-- Full Schedule Simulator Table -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">📊</div>
      <h2 class="text-lg font-bold text-amber-400">What-If Records</h2>
    </div>
    <div class="glass-card-static rounded-xl overflow-x-auto">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Team</th>
            <th class="text-center">Actual</th>
            <th class="text-center">Best Possible</th>
            <th class="text-center">Worst Possible</th>
            <th class="text-center">Avg vs All</th>
            <th class="text-center">Luck</th>
            <th class="text-center">Verdict</th>
          </tr>
        </thead>
        <tbody>
          {whatIf.map(t => {
            const luckColor = t.luckScore > 1 ? 'text-emerald-400' : t.luckScore < -1 ? 'text-red-400' : 'text-zinc-400';
            const verdict = t.luckScore > 1 ? 'Lucky 🍀' : t.luckScore < -1 ? 'Unlucky 💀' : 'Fair ⚖️';
            return (
              <tr class="hover:bg-zinc-800/30 transition-colors">
                <td>
                  <span class="text-sm font-semibold text-zinc-100">{t.name}</span>
                </td>
                <td class="text-center">
                  <span class="font-mono text-sm font-bold text-zinc-300">{t.actualWins}-{t.actualLosses}</span>
                </td>
                <td class="text-center">
                  <span class="font-mono text-sm text-emerald-400">{t.bestWins}-{t.actualWins + t.actualLosses - t.bestWins}</span>
                </td>
                <td class="text-center">
                  <span class="font-mono text-sm text-red-400">{t.worstWins}-{t.actualWins + t.actualLosses - t.worstWins}</span>
                </td>
                <td class="text-center">
                  <span class="font-mono text-sm text-zinc-400">{t.avgWins.toFixed(1)}-{(t.actualWins + t.actualLosses - t.avgWins).toFixed(1)}</span>
                </td>
                <td class="text-center">
                  <span class={`font-mono text-sm font-bold ${luckColor}`}>{t.luckScore > 0 ? '+' : ''}{t.luckScore.toFixed(1)}</span>
                </td>
                <td class="text-center">
                  <span class="text-xs font-semibold" class:list={[t.luckScore > 1 ? 'text-emerald-400' : t.luckScore < -1 ? 'text-red-400' : 'text-zinc-500']}>{verdict}</span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Luckiest Teams -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-sm">🍀</div>
      <h2 class="text-lg font-bold text-emerald-400">Luckiest Teams</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {luckiest.slice(0, 6).map(t => (
        <div class="glass-card rounded-xl p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-bold text-zinc-100">{t.name}</span>
            <span class="text-lg">🍀</span>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <div>
              <span class="text-zinc-500">Actual: </span>
              <span class="font-bold text-zinc-300">{t.actualWins}-{t.actualLosses}</span>
            </div>
            <div>
              <span class="text-zinc-500">Expected: </span>
              <span class="font-bold text-zinc-400">{t.avgWins.toFixed(1)}-{(t.actualWins + t.actualLosses - t.avgWins).toFixed(1)}</span>
            </div>
            <div>
              <span class="text-emerald-400 font-bold">+{t.luckScore.toFixed(1)}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Unluckiest Teams -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-500/10 text-sm">💀</div>
      <h2 class="text-lg font-bold text-red-400">Unluckiest Teams</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {unluckiest.slice(0, 6).map(t => (
        <div class="glass-card rounded-xl p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-sm font-bold text-zinc-100">{t.name}</span>
            <span class="text-lg">💀</span>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <div>
              <span class="text-zinc-500">Actual: </span>
              <span class="font-bold text-zinc-300">{t.actualWins}-{t.actualLosses}</span>
            </div>
            <div>
              <span class="text-zinc-500">Expected: </span>
              <span class="font-bold text-zinc-400">{t.avgWins.toFixed(1)}-{(t.actualWins + t.actualLosses - t.avgWins).toFixed(1)}</span>
            </div>
            <div>
              <span class="text-red-400 font-bold">{t.luckScore.toFixed(1)}</span>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Explanation -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💡</span>
      <h2 class="text-lg font-bold text-zinc-100">What This Means</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-1">🍀 Lucky</h3>
        <p class="text-xs text-zinc-500">Your actual record is better than your average simulated record. You benefited from facing teams on their bad weeks or catching opponents at the right time.</p>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-red-400 mb-1">💀 Unlucky</h3>
        <p class="text-xs text-zinc-500">Your actual record is worse than your average simulated record. You consistently faced teams when they scored their highest. Your team is better than your record shows.</p>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-zinc-400 mb-1">⚖️ Fair</h3>
        <p class="text-xs text-zinc-500">Your record matches expectations. Your schedule was neither particularly favorable nor unfavorable.</p>
      </div>
    </div>
  </div>
</Layout>
