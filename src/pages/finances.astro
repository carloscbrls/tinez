---
import Layout from "../layouts/Layout.astro";
import { teams } from "../data/teams";
---

<Layout title="Finances">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">💰</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">League Finances</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2026 Season · $150/team</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pre-Season Notice -->
  <div class="glass-card-accent rounded-xl p-12 text-center mb-8">
    <div class="text-5xl mb-4">💰</div>
    <h2 class="text-xl font-bold text-amber-400 mb-2">Pre-Season — Financial data will appear after the season starts</h2>
    <p class="text-zinc-400">Dues, payouts, and team financial status will update once the season begins.</p>
  </div>

  <!-- Summary Cards -->
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-amber-400">$2,100</div>
      <div class="text-xs text-zinc-500 mt-1">Total Dues Collected</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">14 teams × $150</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-emerald-400">$2,100</div>
      <div class="text-xs text-zinc-500 mt-1">Total Payouts</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">Championship + Weekly + Season</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-zinc-100">$0</div>
      <div class="text-xs text-zinc-500 mt-1">Remaining Balance</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">Platform fees + carryover</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-amber-400">$150</div>
      <div class="text-xs text-zinc-500 mt-1">Avg per Team</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">$150 buy-in</div>
    </div>
  </div>

  <!-- Payout Breakdown -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">🏆</div>
      <h2 class="text-lg font-bold text-amber-400">Payout Breakdown</h2>
    </div>
    <div class="glass-card-static rounded-xl overflow-hidden">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Category</th>
            <th class="text-right">Amount</th>
            <th class="text-center">% of Pool</th>
            <th class="text-center">Recipients</th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🥇</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">1st Place — Champion</div>
                  <div class="text-[10px] text-zinc-500">Super Bowl LX Winner</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-emerald-400">$1,400</td>
            <td class="text-center font-mono text-sm text-zinc-400">67%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🥈</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">2nd Place — Runner Up</div>
                  <div class="text-[10px] text-zinc-500">Super Bowl LX Runner Up</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-zinc-300">$700</td>
            <td class="text-center font-mono text-sm text-zinc-400">33%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🥉</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">3rd Place</div>
                  <div class="text-[10px] text-zinc-500">Third Place Game Winner</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-amber-400">$350</td>
            <td class="text-center font-mono text-sm text-zinc-400">17%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">📊</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">Regular Season Champion</div>
                  <div class="text-[10px] text-zinc-500">Best record after Week 14</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-blue-400">$100</td>
            <td class="text-center font-mono text-sm text-zinc-400">5%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🔥</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">Weekly High Score</div>
                  <div class="text-[10px] text-zinc-500">Weeks 1-14, highest weekly score</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-purple-400">$25 × 14</td>
            <td class="text-center font-mono text-sm text-zinc-400">17%</td>
            <td class="text-center text-xs text-zinc-500">14 weeks</td>
          </tr>
        </tbody>
        <tfoot>
          <tr class="border-t border-amber-500/30 bg-amber-500/5">
            <td class="px-4 py-3">
              <span class="text-sm font-bold text-amber-400">Total Payouts</span>
            </td>
            <td class="px-4 py-3 text-right text-lg font-bold text-amber-400">$2,100</td>
            <td class="px-4 py-3 text-center font-mono text-sm text-amber-400">100%</td>
            <td class="px-4 py-3 text-center text-xs text-zinc-500">—</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Team Dues Status -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-sm">✅</div>
      <h2 class="text-lg font-bold text-emerald-400">Team Dues</h2>
    </div>
    <div class="glass-card-static rounded-xl overflow-x-auto">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Team</th>
            <th class="text-center">Owner</th>
            <th class="text-center">Dues</th>
            <th class="text-center">Status</th>
          </tr>
        </thead>
        <tbody>
          {teams.map(t => (
            <tr class="hover:bg-zinc-800/30 transition-colors">
              <td>
                <span class="text-sm font-semibold text-zinc-100">{t.name}</span>
              </td>
              <td class="text-center text-sm text-zinc-400">{t.owner}</td>
              <td class="text-center font-mono text-sm text-zinc-300">$150</td>
              <td class="text-center">
                <span class="inline-flex items-center gap-1 rounded-full bg-zinc-800/50 px-2.5 py-0.5 text-[10px] font-medium text-zinc-500">
                  Pending
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Payment Info -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💳</span>
      <h2 class="text-lg font-bold text-zinc-100">Payment Information</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-amber-400 mb-2">How to Pay</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Dues are <strong class="text-zinc-200">$150</strong> per team per season</li>
          <li>• Due before the annual draft</li>
          <li>• Payment via Venmo, PayPal, or Cash</li>
          <li>• Unpaid teams forfeit draft eligibility</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Payout Schedule</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Weekly high score: <strong class="text-zinc-200">$25</strong> per week (Weeks 1-14)</li>
          <li>• Regular season champ: <strong class="text-zinc-200">$100</strong> after Week 14</li>
          <li>• Playoff payouts: Week 17 after Super Bowl</li>
          <li>• All payouts via Venmo within 7 days</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
