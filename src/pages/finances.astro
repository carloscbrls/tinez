---
import Layout from "../layouts/Layout.astro";
import { fetchRosters, fetchUsers, LEAGUE_CONFIG } from "../data/sleeper-api";

const [rosters, users] = await Promise.all([
  fetchRosters(),
  fetchUsers(),
]);

const userMap = new Map(users.map(u => [u.user_id, u]));

// Build team data with finances
const teams = rosters
  .map(r => {
    const user = userMap.get(r.owner_id);
    return {
      name: user?.metadata?.team_name || user?.display_name || `Team ${r.roster_id}`,
      owner: user?.display_name || "Unknown",
      wins: r.settings.wins,
      losses: r.settings.losses,
      pf: r.settings.fpts,
      rosterId: r.roster_id,
    };
  })
  .sort((a, b) => b.wins - a.wins || b.pf - a.pf);

const duesPerTeam = 150;
const totalDues = teams.length * duesPerTeam;
const payouts = {
  first: 1400,
  second: 700,
  third: 350,
  regSeason: 100,
  weekly: 25,
  weeklyWeeks: 14,
};
const totalPayouts = payouts.first + payouts.second + payouts.third + payouts.regSeason + (payouts.weekly * payouts.weeklyWeeks);
const remaining = totalDues - totalPayouts;
---

<Layout title="Finances">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">💰</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">League Finances</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · {LEAGUE_CONFIG.season} Season · ${duesPerTeam}/team</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Summary Cards -->
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-amber-400">${totalDues.toLocaleString()}</div>
      <div class="text-xs text-zinc-500 mt-1">Total Dues Collected</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">{teams.length} teams × ${duesPerTeam}</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-emerald-400">${totalPayouts.toLocaleString()}</div>
      <div class="text-xs text-zinc-500 mt-1">Total Payouts</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">Championship + Weekly + Season</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-zinc-100">${remaining.toLocaleString()}</div>
      <div class="text-xs text-zinc-500 mt-1">Remaining Balance</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">Platform fees + carryover</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-2xl font-extrabold text-amber-400">${(totalDues / teams.length).toFixed(0)}</div>
      <div class="text-xs text-zinc-500 mt-1">Avg per Team</div>
      <div class="text-[10px] text-zinc-600 mt-0.5">${duesPerTeam} buy-in</div>
    </div>
  </div>

  <!-- Payout Breakdown -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">🏆</div>
      <h2 class="text-lg font-bold text-amber-400">Payout Breakdown</h2>
    </div>
    <div class="glass-card-static rounded-xl overflow-hidden">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Category</th>
            <th class="text-right">Amount</th>
            <th class="text-center">% of Pool</th>
            <th class="text-center">Recipients</th>
          </tr>
        </thead>
        <tbody>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🥇</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">1st Place — Champion</div>
                  <div class="text-[10px] text-zinc-500">Super Bowl LX Winner</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-emerald-400">${payouts.first.toLocaleString()}</td>
            <td class="text-center font-mono text-sm text-zinc-400">{((payouts.first / totalPayouts) * 100).toFixed(0)}%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🥈</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">2nd Place — Runner Up</div>
                  <div class="text-[10px] text-zinc-500">Super Bowl LX Runner Up</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-zinc-300">${payouts.second.toLocaleString()}</td>
            <td class="text-center font-mono text-sm text-zinc-400">{((payouts.second / totalPayouts) * 100).toFixed(0)}%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🥉</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">3rd Place</div>
                  <div class="text-[10px] text-zinc-500">Third Place Game Winner</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-amber-400">${payouts.third.toLocaleString()}</td>
            <td class="text-center font-mono text-sm text-zinc-400">{((payouts.third / totalPayouts) * 100).toFixed(0)}%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">📊</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">Regular Season Champion</div>
                  <div class="text-[10px] text-zinc-500">Best record after Week 14</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-blue-400">${payouts.regSeason.toLocaleString()}</td>
            <td class="text-center font-mono text-sm text-zinc-400">{((payouts.regSeason / totalPayouts) * 100).toFixed(0)}%</td>
            <td class="text-center text-xs text-zinc-500">1 team</td>
          </tr>
          <tr class="hover:bg-zinc-800/30 transition-colors">
            <td>
              <div class="flex items-center gap-2">
                <span class="text-lg">🔥</span>
                <div>
                  <div class="text-sm font-semibold text-zinc-100">Weekly High Score</div>
                  <div class="text-[10px] text-zinc-500">Weeks 1-14, highest weekly score</div>
                </div>
              </div>
            </td>
            <td class="text-right text-lg font-bold text-purple-400">${payouts.weekly} × {payouts.weeklyWeeks}</td>
            <td class="text-center font-mono text-sm text-zinc-400">{((payouts.weekly * payouts.weeklyWeeks / totalPayouts) * 100).toFixed(0)}%</td>
            <td class="text-center text-xs text-zinc-500">14 weeks</td>
          </tr>
        </tbody>
        <tfoot>
          <tr class="border-t border-amber-500/30 bg-amber-500/5">
            <td class="px-4 py-3">
              <span class="text-sm font-bold text-amber-400">Total Payouts</span>
            </td>
            <td class="px-4 py-3 text-right text-lg font-bold text-amber-400">${totalPayouts.toLocaleString()}</td>
            <td class="px-4 py-3 text-center font-mono text-sm text-amber-400">100%</td>
            <td class="px-4 py-3 text-center text-xs text-zinc-500">—</td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <!-- Team Dues Status -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-sm">✅</div>
      <h2 class="text-lg font-bold text-emerald-400">Team Dues</h2>
    </div>
    <div class="glass-card-static rounded-xl overflow-x-auto">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Team</th>
            <th class="text-center">Owner</th>
            <th class="text-center">Dues</th>
            <th class="text-center">Status</th>
          </tr>
        </thead>
        <tbody>
          {teams.map(t => (
            <tr class="hover:bg-zinc-800/30 transition-colors">
              <td>
                <span class="text-sm font-semibold text-zinc-100">{t.name}</span>
              </td>
              <td class="text-center text-sm text-zinc-400">{t.owner}</td>
              <td class="text-center font-mono text-sm text-zinc-300">${duesPerTeam}</td>
              <td class="text-center">
                <span class="inline-flex items-center gap-1 rounded-full bg-emerald-500/10 px-2.5 py-0.5 text-[10px] font-medium text-emerald-400">
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  Paid
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Payment Info -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💳</span>
      <h2 class="text-lg font-bold text-zinc-100">Payment Information</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-amber-400 mb-2">How to Pay</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Dues are <strong class="text-zinc-200">${duesPerTeam}</strong> per team per season</li>
          <li>• Due before the annual draft</li>
          <li>• Payment via Venmo, PayPal, or Cash</li>
          <li>• Unpaid teams forfeit draft eligibility</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Payout Schedule</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Weekly high score: <strong class="text-zinc-200">${payouts.weekly}</strong> per week (Weeks 1-14)</li>
          <li>• Regular season champ: <strong class="text-zinc-200">${payouts.regSeason}</strong> after Week 14</li>
          <li>• Playoff payouts: Week 17 after Super Bowl</li>
          <li>• All payouts via Venmo within 7 days</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
