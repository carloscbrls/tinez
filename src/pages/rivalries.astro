---
import Layout from "../layouts/Layout.astro";
import { fetchRosters, fetchUsers, fetchAllMatchups, LEAGUE_CONFIG } from "../data/sleeper-api";
import { teams } from "../data/teams";

const [rosters, users, matchupsByWeek] = await Promise.all([
  fetchRosters(),
  fetchUsers(),
  fetchAllMatchups(1, 18),
]);

const userMap = new Map(users.map(u => [u.user_id, u]));
const teamNameMap = new Map(rosters.map(r => {
  const user = userMap.get(r.owner_id);
  return [r.roster_id, user?.metadata?.team_name || user?.display_name || `Team ${r.roster_id}`];
}));

// Build head-to-head records
const h2h = new Map<string, Map<string, { wins: number; losses: number; pf: number; pa: number }>>();

for (const [week, m] of matchupsByWeek) {
  const grouped = new Map<number, any[]>();
  for (const matchup of m) {
    if (!grouped.has(matchup.matchup_id)) grouped.set(matchup.matchup_id, []);
    grouped.get(matchup.matchup_id)!.push(matchup);
  }

  for (const g of grouped.values()) {
    if (g.length < 2) continue;
    const [t1, t2] = g;
    const r1 = t1.roster_id;
    const r2 = t2.roster_id;
    if (r1 === r2) continue;

    if (!h2h.has(r1)) h2h.set(r1, new Map());
    if (!h2h.has(r2)) h2h.set(r2, new Map());
    if (!h2h.get(r1)!.has(r2)) h2h.get(r1)!.set(r2, { wins: 0, losses: 0, pf: 0, pa: 0 });
    if (!h2h.get(r2)!.has(r1)) h2h.get(r2)!.set(r1, { wins: 0, losses: 0, pf: 0, pa: 0 });

    const r1v2 = h2h.get(r1)!.get(r2)!;
    const r2v1 = h2h.get(r2)!.get(r1)!;

    if (t1.points > t2.points) {
      r1v2.wins++; r2v1.losses++;
    } else {
      r1v2.losses++; r2v1.wins++;
    }
    r1v2.pf += t1.points; r1v2.pa += t2.points;
    r2v1.pf += t2.points; r2v1.pa += t1.points;
  }
}

// Find top rivalries (most matchups played)
const rivalries: { team1: string; team2: string; t1Id: number; t2Id: number; t1Record: string; t2Record: string; t1PF: number; t2PF: number; totalGames: number; intensity: number }[] = [];

for (const [t1Id, opponents] of h2h) {
  for (const [t2Id, stats] of opponents) {
    if (t1Id >= t2Id) continue; // Only process each pair once
    const t1Name = teamNameMap.get(t1Id) || `Team ${t1Id}`;
    const t2Name = teamNameMap.get(t2Id) || `Team ${t2Id}`;
    const totalGames = stats.wins + stats.losses;
    const avgScore = ((stats.pf + stats.pa) / totalGames).toFixed(1);
    const intensity = totalGames * (stats.wins > stats.losses ? stats.wins / stats.losses : stats.losses / stats.wins);

    rivalries.push({
      team1: t1Name,
      team2: t2Name,
      t1Id,
      t2Id,
      t1Record: `${stats.wins}-${stats.losses}`,
      t2Record: `${stats.losses}-${stats.wins}`,
      t1PF: stats.pf,
      t2PF: stats.pa,
      totalGames,
      intensity: Math.round(intensity * 10) / 10,
    });
  }
}

rivalries.sort((a, b) => b.totalGames - a.totalGames || b.intensity - a.intensity);

// Top 20 rivalries
const topRivalries = rivalries.slice(0, 20);

// Most one-sided rivalries
const oneSided = [...rivalries]
  .filter(r => r.totalGames >= 3)
  .sort((a, b) => {
    const aRatio = Math.max(parseInt(a.t1Record.split('-')[0]), parseInt(a.t1Record.split('-')[1])) / Math.min(parseInt(a.t1Record.split('-')[0]), parseInt(a.t1Record.split('-')[1]) || 1);
    const bRatio = Math.max(parseInt(b.t1Record.split('-')[0]), parseInt(b.t1Record.split('-')[1])) / Math.min(parseInt(b.t1Record.split('-')[0]), parseInt(b.t1Record.split('-')[1]) || 1);
    return bRatio - aRatio;
  })
  .slice(0, 10);

// Closest rivalries
const closest = [...rivalries]
  .filter(r => r.totalGames >= 3)
  .sort((a, b) => {
    const aDiff = Math.abs(parseInt(a.t1Record.split('-')[0]) - parseInt(a.t1Record.split('-')[1]));
    const bDiff = Math.abs(parseInt(b.t1Record.split('-')[0]) - parseInt(b.t1Record.split('-')[1]));
    return aDiff - bDiff;
  })
  .slice(0, 10);
---

<Layout title="Rivalries">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">⚔️</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Rivalry Tracker</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · Head-to-Head Records · {rivalries.length} Rivalries</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Top Rivalries -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">🔥</div>
      <h2 class="text-lg font-bold text-amber-400">Top Rivalries</h2>
      <span class="text-xs text-zinc-600">By games played</span>
    </div>
    <div class="glass-card-static rounded-xl overflow-x-auto">
      <table class="premium-table">
        <thead>
          <tr>
            <th>Rivalry</th>
            <th class="text-center">Games</th>
            <th class="text-center">Record</th>
            <th class="text-center">Avg Score</th>
            <th class="text-center">Intensity</th>
            <th class="text-center">Dominance</th>
          </tr>
        </thead>
        <tbody>
          {topRivalries.map(r => {
            const [wins, losses] = r.t1Record.split('-').map(Number);
            const total = wins + losses;
            const winPct = ((wins / total) * 100).toFixed(0);
            const avgScore = ((r.t1PF + r.t2PF) / total).toFixed(1);
            const dominant = wins > losses ? r.team1 : r.team2;
            const domWins = wins > losses ? wins : losses;
            const domLosses = wins > losses ? losses : wins;
            return (
              <tr class="hover:bg-zinc-800/30 transition-colors">
                <td>
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-zinc-100">{r.team1}</span>
                    <span class="text-xs text-zinc-600">vs</span>
                    <span class="text-sm font-semibold text-zinc-100">{r.team2}</span>
                  </div>
                </td>
                <td class="text-center font-mono text-sm font-bold text-zinc-300">{total}</td>
                <td class="text-center">
                  <span class="font-mono text-sm">
                    <span class="text-emerald-400">{wins}</span>
                    <span class="text-zinc-600">-</span>
                    <span class="text-red-400">{losses}</span>
                  </span>
                </td>
                <td class="text-center font-mono text-sm text-zinc-400">{avgScore}</td>
                <td class="text-center">
                  <div class="flex items-center justify-center gap-1">
                    <div class="h-1.5 w-16 rounded-full bg-zinc-800 overflow-hidden">
                      <div class="h-full rounded-full bg-gradient-to-r from-amber-400 to-orange-500" style={`width: ${Math.min(r.intensity * 10, 100)}%`}></div>
                    </div>
                    <span class="text-[10px] text-zinc-500">{r.intensity.toFixed(1)}</span>
                  </div>
                </td>
                <td class="text-center">
                  <span class="text-xs font-semibold" class:list={[winPct >= '60' ? 'text-emerald-400' : winPct >= '50' ? 'text-amber-400' : 'text-zinc-500']}>
                    {dominant} ({domWins}-{domLosses})
                  </span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Most One-Sided -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-500/10 text-sm">💀</div>
      <h2 class="text-lg font-bold text-red-400">Most One-Sided</h2>
      <span class="text-xs text-zinc-600">Min 3 games played</span>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {oneSided.map(r => {
        const [wins, losses] = r.t1Record.split('-').map(Number);
        const dominant = wins > losses ? r.team1 : r.team2;
        const dominated = wins > losses ? r.team2 : r.team1;
        const domWins = wins > losses ? wins : losses;
        const domLosses = wins > losses ? losses : wins;
        return (
          <div class="glass-card rounded-xl p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-bold text-emerald-400">{dominant}</span>
              <span class="text-xs text-zinc-600">dominates</span>
              <span class="text-sm font-bold text-red-400">{dominated}</span>
            </div>
            <div class="flex items-center justify-center gap-3">
              <span class="text-2xl font-bold text-emerald-400">{domWins}</span>
              <span class="text-xs text-zinc-600">-</span>
              <span class="text-2xl font-bold text-red-400">{domLosses}</span>
            </div>
            <div class="text-center text-[10px] text-zinc-600 mt-1">{r.totalGames} games played</div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Closest Rivalries -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-sm">⚖️</div>
      <h2 class="text-lg font-bold text-emerald-400">Closest Rivalries</h2>
      <span class="text-xs text-zinc-600">Min 3 games played</span>
    </div>
    <div class="grid gap-3 sm:grid-cols-2">
      {closest.map(r => {
        const [wins, losses] = r.t1Record.split('-').map(Number);
        return (
          <div class="glass-card rounded-xl p-4">
            <div class="flex items-center justify-between mb-2">
              <span class="text-sm font-semibold text-zinc-200">{r.team1}</span>
              <span class="text-xs text-zinc-600">vs</span>
              <span class="text-sm font-semibold text-zinc-200">{r.team2}</span>
            </div>
            <div class="flex items-center justify-center gap-3">
              <span class="text-xl font-bold text-zinc-300">{wins}</span>
              <span class="text-xs text-zinc-600">-</span>
              <span class="text-xl font-bold text-zinc-300">{losses}</span>
            </div>
            <div class="text-center text-[10px] text-zinc-600 mt-1">{r.totalGames} games · Avg {((r.t1PF + r.t2PF) / r.totalGames).toFixed(1)} pts</div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Rivalry Intensity Scale -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">📊</span>
      <h2 class="text-lg font-bold text-zinc-100">How Rivalry Intensity Works</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-3">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <div class="text-2xl mb-1">🔥</div>
        <h3 class="text-sm font-bold text-amber-400 mb-1">Intensity Score</h3>
        <p class="text-xs text-zinc-500">Games played × win ratio. More games + lopsided record = higher intensity. A 5-0 rivalry scores higher than a 3-2.</p>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <div class="text-2xl mb-1">💀</div>
        <h3 class="text-sm font-bold text-red-400 mb-1">One-Sided</h3>
        <p class="text-xs text-zinc-500">When one team dominates another. These are the rivalries where bragging rights are well-earned.</p>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <div class="text-2xl mb-1">⚖️</div>
        <h3 class="text-sm font-bold text-emerald-400 mb-1">Closest</h3>
        <p class="text-xs text-zinc-500">When records are nearly even. These are the rivalries where every matchup is a toss-up.</p>
      </div>
    </div>
  </div>
</Layout>
