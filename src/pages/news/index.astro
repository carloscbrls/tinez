---
import Layout from "../../layouts/Layout.astro";
import { fetchTrendingWithDetails, getPositionEmoji, getInjuryBadge } from "../../data/sleeper";
import { getEspnHeadshotUrl, getNflTeamLogoUrl } from "../../data/players";
import { fetchNflNews } from "../../data/nfl-api";

const trendingAdds = await fetchTrendingWithDetails("add", 24, 15);
const trendingDrops = await fetchTrendingWithDetails("drop", 24, 10);
const news = await fetchNflNews(15);
---

<Layout title="Fantasy News Hub">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-emerald-500/20">
      <div class="absolute inset-0 bg-gradient-to-br from-emerald-600/10 via-green-600/5 to-transparent animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-emerald-400 to-green-500 text-lg font-bold text-white shadow-lg shadow-emerald-500/20">N</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Fantasy News Hub</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Trending players, waiver wire alerts, and NFL headlines</p>
          </div>
        </div>
        <div class="mt-3 flex flex-wrap gap-2">
          <a href="/news/trending" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-700/50 transition-all">📈 Full Trending</a>
          <a href="/news/injuries" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-700/50 transition-all">🚑 Injury Report</a>
        </div>
      </div>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-2 stagger-children">
    <!-- Trending Adds -->
    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-zinc-100">🔥 Most Added</h2>
        <span class="text-xs text-zinc-500 bg-zinc-800/30 px-2 py-1 rounded-md">Last 24 hours</span>
      </div>
      <div class="space-y-2">
        {trendingAdds.map((t, i) => {
          const p = t.player!;
          const badge = getInjuryBadge(p.injury_status);
          const espnId = p.yahoo_id || 0;
          return (
            <div class="glass-card rounded-lg p-3 flex items-center gap-3">
              <span class="w-5 text-right text-xs font-mono text-zinc-600 shrink-0">{i + 1}</span>
              <div class="h-10 w-10 rounded-lg bg-zinc-800/50 overflow-hidden shrink-0">
                {espnId > 0 ? (
                  <img src={getEspnHeadshotUrl(espnId)} alt={p.full_name} class="h-full w-full object-cover" loading="lazy" onerror="this.style.display='none'" />
                ) : (
                  <div class="h-full w-full flex items-center justify-center text-sm">{getPositionEmoji(p.position)}</div>
                )}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="truncate font-semibold text-sm text-zinc-100">{p.full_name}</span>
                  <span class="shrink-0 rounded bg-zinc-800/50 px-1.5 py-0.5 text-xs font-mono text-zinc-400 border border-zinc-700/30">{p.position}</span>
                  <span class="shrink-0 text-xs text-zinc-500">{p.team}</span>
                  {badge && (
                    <span class={`shrink-0 rounded px-1.5 py-0.5 text-xs ${badge.color}`}>{badge.label}</span>
                  )}
                </div>
                {p.injury_notes && (
                  <div class="mt-0.5 text-xs text-zinc-500 truncate">{p.injury_notes}</div>
                )}
              </div>
              <div class="text-right shrink-0">
                <div class="text-sm font-bold text-emerald-400">{t.count.toLocaleString()}</div>
                <div class="text-xs text-zinc-600">adds</div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Trending Drops -->
    <div>
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-zinc-100">❄️ Most Dropped</h2>
        <span class="text-xs text-zinc-500 bg-zinc-800/30 px-2 py-1 rounded-md">Last 24 hours</span>
      </div>
      <div class="space-y-2">
        {trendingDrops.map((t, i) => {
          const p = t.player!;
          const badge = getInjuryBadge(p.injury_status);
          const espnId = p.yahoo_id || 0;
          return (
            <div class="glass-card rounded-lg p-3 flex items-center gap-3">
              <span class="w-5 text-right text-xs font-mono text-zinc-600 shrink-0">{i + 1}</span>
              <div class="h-10 w-10 rounded-lg bg-zinc-800/50 overflow-hidden shrink-0">
                {espnId > 0 ? (
                  <img src={getEspnHeadshotUrl(espnId)} alt={p.full_name} class="h-full w-full object-cover" loading="lazy" onerror="this.style.display='none'" />
                ) : (
                  <div class="h-full w-full flex items-center justify-center text-sm">{getPositionEmoji(p.position)}</div>
                )}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2 flex-wrap">
                  <span class="truncate font-semibold text-sm text-zinc-100">{p.full_name}</span>
                  <span class="shrink-0 rounded bg-zinc-800/50 px-1.5 py-0.5 text-xs font-mono text-zinc-400 border border-zinc-700/30">{p.position}</span>
                  <span class="shrink-0 text-xs text-zinc-500">{p.team}</span>
                  {badge && (
                    <span class={`shrink-0 rounded px-1.5 py-0.5 text-xs ${badge.color}`}>{badge.label}</span>
                  )}
                </div>
                {p.injury_notes && (
                  <div class="mt-0.5 text-xs text-zinc-500 truncate">{p.injury_notes}</div>
                )}
              </div>
              <div class="text-right shrink-0">
                <div class="text-sm font-bold text-red-400">{t.count.toLocaleString()}</div>
                <div class="text-xs text-zinc-600">drops</div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- NFL Headlines -->
  {news.length > 0 && (
    <div class="mt-8">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-bold text-zinc-100">📰 NFL Headlines</h2>
        <span class="text-xs text-zinc-500 bg-zinc-800/30 px-2 py-1 rounded-md">ESPN · NFL.com · Rotoworld</span>
      </div>
      <div class="space-y-2">
        {news.map((item) => (
          <a href={item.link} target="_blank" rel="noopener noreferrer" class="glass-card rounded-lg p-4 block group hover:bg-zinc-800/40 transition-all">
            <div class="flex items-start gap-3">
              <div class="flex-1 min-w-0">
                <div class="text-sm font-semibold text-zinc-100 group-hover:text-amber-300 transition-colors line-clamp-2">{item.title}</div>
                {item.snippet && (
                  <p class="mt-1 text-xs text-zinc-500 line-clamp-2">{item.snippet}</p>
                )}
                <div class="mt-2 flex items-center gap-2 text-xs">
                  <span class="text-amber-400 font-medium">{item.source}</span>
                  {item.date && (
                    <>
                      <span class="text-zinc-700">·</span>
                      <span class="text-zinc-600">{new Date(item.date).toLocaleDateString("en-US", { month: "short", day: "numeric", hour: "2-digit", minute: "2-digit" })}</span>
                    </>
                  )}
                </div>
              </div>
              <svg class="w-4 h-4 text-zinc-600 group-hover:text-amber-400 transition-colors shrink-0 mt-1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
            </div>
          </a>
        ))}
      </div>
    </div>
  )}

  <!-- Injury Report -->
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-zinc-100">🚑 Injury Report</h2>
      <a href="/news/injuries" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">View all →</a>
    </div>
    <div class="glass-card rounded-xl p-8 text-center">
      <div class="text-4xl mb-3">🚑</div>
      <p class="text-zinc-400">Full injury report with player statuses available.</p>
      <p class="mt-1 text-xs text-zinc-600">Injury data available via Sleeper API for all 12K+ players.</p>
      <a href="/news/injuries" class="mt-4 inline-flex items-center gap-1.5 rounded-lg bg-amber-500/10 border border-amber-500/20 px-4 py-2 text-sm font-medium text-amber-400 hover:bg-amber-500/20 transition-all">
        View Full Injury Report
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </div>

  <!-- Waiver Wire Watch -->
  <div class="mt-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-zinc-100">📋 Waiver Wire Watch</h2>
      <a href="/news/trending" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">Full list →</a>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
      {trendingAdds.slice(0, 6).map((t) => {
        const p = t.player!;
        const espnId = p.yahoo_id || 0;
        return (
          <div class="glass-card rounded-xl p-4">
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-lg bg-zinc-800/50 overflow-hidden shrink-0">
                {espnId > 0 ? (
                  <img src={getEspnHeadshotUrl(espnId)} alt={p.full_name} class="h-full w-full object-cover" loading="lazy" onerror="this.style.display='none'" />
                ) : (
                  <div class="h-full w-full flex items-center justify-center text-sm">{getPositionEmoji(p.position)}</div>
                )}
              </div>
              <div class="min-w-0">
                <div class="font-semibold text-sm text-zinc-100 truncate">{p.full_name}</div>
                <div class="flex items-center gap-1.5 text-xs text-zinc-500">
                  <span>{p.team}</span>
                  <span>·</span>
                  <span class="position-badge" class:list={[`position-badge-${p.position.toLowerCase()}`]}>{p.position}</span>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center justify-between text-xs">
              <span class="text-emerald-400 font-semibold">{t.count.toLocaleString()} adds today</span>
              {p.years_exp > 0 && <span class="text-zinc-600">Year {p.years_exp}</span>}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>