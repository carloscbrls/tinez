---
import Layout from "../../layouts/Layout.astro";
import { fetchTrendingWithDetails, getPositionEmoji, getInjuryBadge } from "../../data/sleeper";

const trendingAdds = await fetchTrendingWithDetails("add", 24, 15);
const trendingDrops = await fetchTrendingWithDetails("drop", 24, 10);
---

<Layout title="Fantasy News Hub">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-emerald-600/20 via-green-600/10 to-zinc-900 p-8 border border-emerald-500/20">
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight">Fantasy News Hub</h1>
        <p class="mt-1 text-zinc-400">Trending players, waiver wire alerts, and NFL headlines</p>
        <p class="mt-2 text-xs text-zinc-600">Powered by Sleeper API · Updated hourly</p>
      </div>
    </div>
  </div>

  <div class="grid gap-8 lg:grid-cols-2">
    <!-- Trending Adds -->
    <div>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold">🔥 Most Added</h2>
        <span class="text-xs text-zinc-500">Last 24 hours</span>
      </div>
      <div class="space-y-2">
        {trendingAdds.map((t, i) => {
          const p = t.player!;
          const badge = getInjuryBadge(p.injury_status);
          return (
            <div class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/50 p-3 hover:border-zinc-700 transition-colors">
              <span class="w-5 text-right text-xs font-mono text-zinc-600">{i + 1}</span>
              <div class="flex h-8 w-8 items-center justify-center rounded-md bg-zinc-800 text-sm">
                {getPositionEmoji(p.position)}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class="truncate font-medium text-sm">{p.full_name}</span>
                  <span class="shrink-0 rounded bg-zinc-800 px-1.5 py-0.5 text-xs font-mono text-zinc-400">{p.position}</span>
                  <span class="shrink-0 text-xs text-zinc-500">{p.team}</span>
                  {badge && (
                    <span class={`shrink-0 rounded px-1.5 py-0.5 text-xs ${badge.color}`}>{badge.label}</span>
                  )}
                </div>
                {p.injury_notes && (
                  <div class="mt-0.5 text-xs text-zinc-500 truncate">{p.injury_notes}</div>
                )}
              </div>
              <div class="text-right">
                <div class="text-sm font-semibold text-emerald-400">{t.count.toLocaleString()}</div>
                <div class="text-xs text-zinc-600">adds</div>
              </div>
            </div>
          );
        })}
      </div>
    </div>

    <!-- Trending Drops -->
    <div>
      <div class="mb-4 flex items-center justify-between">
        <h2 class="text-lg font-semibold">❄️ Most Dropped</h2>
        <span class="text-xs text-zinc-500">Last 24 hours</span>
      </div>
      <div class="space-y-2">
        {trendingDrops.map((t, i) => {
          const p = t.player!;
          const badge = getInjuryBadge(p.injury_status);
          return (
            <div class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/50 p-3 hover:border-zinc-700 transition-colors">
              <span class="w-5 text-right text-xs font-mono text-zinc-600">{i + 1}</span>
              <div class="flex h-8 w-8 items-center justify-center rounded-md bg-zinc-800 text-sm">
                {getPositionEmoji(p.position)}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class="truncate font-medium text-sm">{p.full_name}</span>
                  <span class="shrink-0 rounded bg-zinc-800 px-1.5 py-0.5 text-xs font-mono text-zinc-400">{p.position}</span>
                  <span class="shrink-0 text-xs text-zinc-500">{p.team}</span>
                  {badge && (
                    <span class={`shrink-0 rounded px-1.5 py-0.5 text-xs ${badge.color}`}>{badge.label}</span>
                  )}
                </div>
                {p.injury_notes && (
                  <div class="mt-0.5 text-xs text-zinc-500 truncate">{p.injury_notes}</div>
                )}
              </div>
              <div class="text-right">
                <div class="text-sm font-semibold text-red-400">{t.count.toLocaleString()}</div>
                <div class="text-xs text-zinc-600">drops</div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </div>

  <!-- Injury Report -->
  <div class="mt-8">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold">🚑 Injury Report</h2>
      <a href="/news/injuries" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">View all →</a>
    </div>
    <div class="rounded-xl border border-zinc-800 p-6 text-center">
      <p class="text-zinc-500">Full injury report with player statuses coming soon.</p>
      <p class="mt-1 text-xs text-zinc-600">Injury data available via Sleeper API for all 12K+ players.</p>
    </div>
  </div>

  <!-- Waiver Wire -->
  <div class="mt-8">
    <div class="mb-4 flex items-center justify-between">
      <h2 class="text-lg font-semibold">📋 Waiver Wire Watch</h2>
      <a href="/news/trending" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">Full list →</a>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {trendingAdds.slice(0, 6).map((t) => {
        const p = t.player!;
        return (
          <div class="rounded-lg border border-zinc-800 bg-zinc-900/30 p-4">
            <div class="flex items-center gap-2">
              <span class="text-lg">{getPositionEmoji(p.position)}</span>
              <div>
                <div class="font-medium text-sm">{p.full_name}</div>
                <div class="text-xs text-zinc-500">{p.team} · {p.position}</div>
              </div>
            </div>
            <div class="mt-2 flex items-center justify-between text-xs">
              <span class="text-zinc-500">{t.count.toLocaleString()} adds today</span>
              {p.years_exp > 0 && <span class="text-zinc-600">Year {p.years_exp}</span>}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>
