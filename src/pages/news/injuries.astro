---
import Layout from "../../layouts/Layout.astro";
import { fetchPlayers, getPositionEmoji, getInjuryBadge } from "../../data/sleeper";

const players = await fetchPlayers();
const injured = Object.values(players)
  .filter((p) => {
    const s = p.injury_status;
    return s && s !== "None" && s !== "" && s !== "Active" && p.active;
  })
  .sort((a, b) => {
    const order = ["Questionable", "Doubtful", "Out", "IR", "Suspended"];
    const aIdx = order.indexOf(a.injury_status || "");
    const bIdx = order.indexOf(b.injury_status || "");
    return (aIdx === -1 ? 99 : aIdx) - (bIdx === -1 ? 99 : bIdx);
  });
---

<Layout title="Injury Report | News">
  <a href="/news" class="mb-4 inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
    ← News Hub
  </a>

  <div class="mb-6">
    <h1 class="text-2xl font-bold">🚑 Injury Report</h1>
    <p class="mt-1 text-zinc-400">{injured.length} players with injury designations</p>
  </div>

  <div class="overflow-hidden rounded-xl border border-zinc-800">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-zinc-800 bg-zinc-900 text-left text-xs uppercase tracking-wider text-zinc-500">
          <th class="px-4 py-3">Player</th>
          <th class="px-4 py-3">Pos</th>
          <th class="px-4 py-3">Team</th>
          <th class="px-4 py-3">Status</th>
          <th class="px-4 py-3 hidden md:table-cell">Injury</th>
          <th class="px-4 py-3 hidden lg:table-cell">Notes</th>
        </tr>
      </thead>
      <tbody>
        {injured.slice(0, 100).map((p) => {
          const badge = getInjuryBadge(p.injury_status);
          return (
            <tr class="border-b border-zinc-800/50 hover:bg-zinc-900/50 transition-colors">
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <span>{getPositionEmoji(p.position)}</span>
                  <span class="font-medium">{p.full_name}</span>
                </div>
              </td>
              <td class="px-4 py-3">
                <span class="rounded bg-zinc-800 px-1.5 py-0.5 text-xs font-mono text-zinc-400">{p.position}</span>
              </td>
              <td class="px-4 py-3 text-zinc-400">{p.team}</td>
              <td class="px-4 py-3">
                {badge && (
                  <span class={`rounded px-2 py-0.5 text-xs font-medium ${badge.color}`}>{badge.label}</span>
                )}
              </td>
              <td class="px-4 py-3 text-zinc-400 hidden md:table-cell">{p.injury_body_part || "-"}</td>
              <td class="px-4 py-3 text-zinc-500 text-xs hidden lg:table-cell max-w-xs truncate">{p.injury_notes || "-"}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  {injured.length > 100 && (
    <p class="mt-4 text-center text-sm text-zinc-600">
      Showing 100 of {injured.length} injured players
    </p>
  )}
</Layout>
