---
import Layout from "../layouts/Layout.astro";
---

<Layout title="League Rules">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-amber-600/20 via-orange-600/10 to-zinc-900 p-8 border border-amber-500/20">
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight">League Rules</h1>
        <p class="mt-1 text-zinc-400">TINEZ LEAGUE · 2026 Season</p>
      </div>
    </div>
  </div>

  <div class="grid gap-6 lg:grid-cols-2">
    <!-- League Basics -->
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="mb-3 text-lg font-semibold text-amber-400">League Basics</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-zinc-500">League Name</dt>
          <dd class="text-zinc-300">TINEZ LEAGUE</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">League ID</dt>
          <dd class="text-zinc-300">#103379</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Commissioner</dt>
          <dd class="text-zinc-300">Carlitos (Frozen Fury)</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Scoring Type</dt>
          <dd class="text-zinc-300">Head-to-Head</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Max Teams</dt>
          <dd class="text-zinc-300">14</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Divisions</dt>
          <dd class="text-zinc-300">2 Divisions</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Draft Type</dt>
          <dd class="text-zinc-300">Offline Draft</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Keeper League</dt>
          <dd class="text-zinc-300">Yes</dd>
        </div>
      </dl>
    </div>

    <!-- Scoring -->
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="mb-3 text-lg font-semibold text-amber-400">Scoring</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-zinc-500">Fractional Points</dt>
          <dd class="text-zinc-300">Yes</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Negative Points</dt>
          <dd class="text-zinc-300">Yes</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Passing TD</dt>
          <dd class="text-zinc-300">6 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Interceptions</dt>
          <dd class="text-zinc-300">-3 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Receptions (PPR)</dt>
          <dd class="text-zinc-300">0.5 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Rushing/Receiving TD</dt>
          <dd class="text-zinc-300">6 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Return Yards</dt>
          <dd class="text-zinc-300">25 yds/pt</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">2-Point Conversion</dt>
          <dd class="text-zinc-300">3 pts</dd>
        </div>
      </dl>
    </div>

    <!-- Roster -->
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="mb-3 text-lg font-semibold text-amber-400">Roster Positions</h2>
      <div class="flex flex-wrap gap-2">
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">QB</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">WR ×3</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">RB ×2</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">TE</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">W/R/T</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">K</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">D</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">DB ×2</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">DL ×2</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">LB ×2</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">BN ×6</span>
        <span class="rounded-lg bg-zinc-800 px-2.5 py-1 text-xs font-medium text-zinc-300">IR ×3</span>
      </div>
      <p class="mt-3 text-xs text-zinc-500">25 total roster spots · 16 starters · 6 bench · 3 IR</p>
    </div>

    <!-- Transactions -->
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="mb-3 text-lg font-semibold text-amber-400">Transactions</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-zinc-500">Max Acquisitions (Season)</dt>
          <dd class="text-zinc-300">60</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Max Acquisitions (Week)</dt>
          <dd class="text-zinc-300">No max</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Max Trades (Season)</dt>
          <dd class="text-zinc-300">No max</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Trade End Date</dt>
          <dd class="text-zinc-300">Nov 28, 2026</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Trade Review</dt>
          <dd class="text-zinc-300">League Votes</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Trade Reject Time</dt>
          <dd class="text-zinc-300">2 days</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Waiver Type</dt>
          <dd class="text-zinc-300">Continual rolling list</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Post-Draft Players</dt>
          <dd class="text-zinc-300">Free Agents</dd>
        </div>
      </dl>
    </div>

    <!-- Playoffs -->
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="mb-3 text-lg font-semibold text-amber-400">Playoffs</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-zinc-500">Teams</dt>
          <dd class="text-zinc-300">8 teams</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Weeks</dt>
          <dd class="text-zinc-300">15, 16, 17</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Ends</dt>
          <dd class="text-zinc-300">Monday, Jan 4</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Seeding</dt>
          <dd class="text-zinc-300">Division winners top seeds</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Tie-Breaker</dt>
          <dd class="text-zinc-300">Best record vs opponent wins</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Reseeding</dt>
          <dd class="text-zinc-300">No</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Lock Eliminated Teams</dt>
          <dd class="text-zinc-300">Yes</dd>
        </div>
      </dl>
    </div>

    <!-- Defensive Scoring -->
    <div class="rounded-xl border border-zinc-800 p-5">
      <h2 class="mb-3 text-lg font-semibold text-amber-400">Defensive Scoring</h2>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between">
          <dt class="text-zinc-500">Tackle Solo</dt>
          <dd class="text-zinc-300">1.5 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Tackle Assist</dt>
          <dd class="text-zinc-300">0.5 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Sack</dt>
          <dd class="text-zinc-300">3 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Interception</dt>
          <dd class="text-zinc-300">3 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Fumble Force/Recovery</dt>
          <dd class="text-zinc-300">2 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Defensive TD</dt>
          <dd class="text-zinc-300">6 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Safety</dt>
          <dd class="text-zinc-300">3 pts</dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-zinc-500">Pass Defended</dt>
          <dd class="text-zinc-300">1 pt</dd>
        </div>
      </dl>
    </div>
  </div>
</Layout>
