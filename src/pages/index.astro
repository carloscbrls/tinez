---
import Layout from "../layouts/Layout.astro";
import { getStandings, teams } from "../data/teams";
const standings = getStandings();
---

<Layout title="TINEZ LEAGUE">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-amber-600/20 via-orange-600/10 to-zinc-900 p-8 border border-amber-500/20">
      <div class="relative z-10">
        <div class="flex items-center gap-3 mb-2">
          <h1 class="text-3xl font-bold tracking-tight">TINEZ LEAGUE</h1>
          <span class="rounded-full bg-amber-500/20 px-3 py-0.5 text-xs font-medium text-amber-400">2026</span>
        </div>
        <p class="text-zinc-400">14 teams · Head-to-Head · Keeper League</p>
        <p class="mt-1 text-sm text-zinc-500">Commissioner: Carlitos · Yahoo League ID #103379</p>
        <div class="mt-3 flex flex-wrap gap-2">
          <a href="/rules" class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-700 transition-colors">📋 League Rules</a>
          <a href="/schedules" class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-700 transition-colors">📅 NFL Schedules</a>
          <a href="/news" class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-700 transition-colors">📰 Fantasy News</a>
          <a href="/podcasts" class="rounded-lg bg-zinc-800 px-3 py-1.5 text-xs font-medium text-zinc-300 hover:bg-zinc-700 transition-colors">🎙️ Podcasts</a>
        </div>
      </div>
    </div>
  </div>

  <!-- League Overview -->
  <div class="mb-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
      <div class="text-2xl font-bold text-amber-400">14</div>
      <div class="text-xs text-zinc-500 mt-1">Teams</div>
    </div>
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
      <div class="text-2xl font-bold text-amber-400">2</div>
      <div class="text-xs text-zinc-500 mt-1">Divisions</div>
    </div>
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
      <div class="text-2xl font-bold text-amber-400">8</div>
      <div class="text-xs text-zinc-500 mt-1">Playoff Teams</div>
    </div>
    <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
      <div class="text-2xl font-bold text-amber-400">0.5 PPR</div>
      <div class="text-xs text-zinc-500 mt-1">Scoring</div>
    </div>
  </div>

  <!-- Standings -->
  <div class="mb-6">
    <h2 class="text-xl font-semibold">Standings</h2>
  </div>

  <div class="overflow-hidden rounded-xl border border-zinc-800">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-zinc-800 bg-zinc-900 text-left text-xs uppercase tracking-wider text-zinc-500">
          <th class="px-4 py-3 w-8">#</th>
          <th class="px-4 py-3">Team</th>
          <th class="px-4 py-3 text-center">W</th>
          <th class="px-4 py-3 text-center">L</th>
          <th class="px-4 py-3 text-center">T</th>
          <th class="px-4 py-3 text-right">PF</th>
          <th class="px-4 py-3 text-right">PA</th>
          <th class="px-4 py-3 text-right hidden sm:table-cell">Diff</th>
          <th class="px-4 py-3 text-center hidden md:table-cell">Streak</th>
        </tr>
      </thead>
      <tbody>
        {standings.map((team, i) => (
          <tr class="border-b border-zinc-800/50 hover:bg-zinc-900/50 transition-colors">
            <td class="px-4 py-3 text-zinc-500 font-mono text-xs">{i + 1}</td>
            <td class="px-4 py-3">
              <a href={`/teams/${team.id}`} class="flex items-center gap-3 hover:opacity-80 transition-opacity">
                <div class="h-8 w-8 rounded-lg flex items-center justify-center text-xs font-bold text-white" style={`background: ${team.primaryColor}`}>
                  {team.shortName}
                </div>
                <div>
                  <div class="font-medium text-zinc-100">{team.name}</div>
                  <div class="text-xs text-zinc-500">{team.owner}</div>
                </div>
              </a>
            </td>
            <td class="px-4 py-3 text-center font-mono">{team.wins}</td>
            <td class="px-4 py-3 text-center font-mono">{team.losses}</td>
            <td class="px-4 py-3 text-center font-mono">{team.ties}</td>
            <td class="px-4 py-3 text-right font-mono">{team.pointsFor.toFixed(1)}</td>
            <td class="px-4 py-3 text-right font-mono">{team.pointsAgainst.toFixed(1)}</td>
            <td class="px-4 py-3 text-right font-mono hidden sm:table-cell">{(team.pointsFor - team.pointsAgainst) > 0 ? '+' : ''}{(team.pointsFor - team.pointsAgainst).toFixed(1)}</td>
            <td class="px-4 py-3 text-center hidden md:table-cell">
              <span class="inline-block rounded-full bg-zinc-800 px-2 py-0.5 text-xs font-mono">{team.streak}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <!-- Week 1 Matchups -->
  <div class="mt-8">
    <h2 class="mb-4 text-xl font-semibold">Week 1 Matchups</h2>
    <div class="grid gap-3 sm:grid-cols-2">
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #00BFFF">FF</div>
            <span class="text-sm font-medium">Frozen Fury</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #6B705C">APT</div>
            <span class="text-sm font-medium">APieceofToast!</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #DC2626">RHGD</div>
            <span class="text-sm font-medium">The Red Hare & Golden Dragon</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #4A0E4E">LET</div>
            <span class="text-sm font-medium">L.E.T. Gang</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #FF4500">LFB</div>
            <span class="text-sm font-medium">LaFlamaBlanca</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #9B2226">TWHL</div>
            <span class="text-sm font-medium">THIS WILL HURTS A LITTLE</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #1A1A2E">BTB</div>
            <span class="text-sm font-medium">Black Team Bitch</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #7F4F24">SS</div>
            <span class="text-sm font-medium">Syrup Squad</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #2D6A4F">EB</div>
            <span class="text-sm font-medium">El Bolillo</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #5C4D7D">IRF</div>
            <span class="text-sm font-medium">Injured Reserve's Finest</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #0A9396">JITM</div>
            <span class="text-sm font-medium">JUST IN Tucker's Massage…</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #001219">TTD</div>
            <span class="text-sm font-medium">Take that Daak</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
      <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4">
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #005F73">BPH</div>
            <span class="text-sm font-medium">Best Pacheco Hoe</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
        <div class="my-2 text-center text-xs text-zinc-600">vs</div>
        <div class="flex items-center justify-between">
          <div class="flex items-center gap-2">
            <div class="h-6 w-6 rounded flex items-center justify-center text-xs font-bold text-white" style="background: #800000">RTT</div>
            <span class="text-sm font-medium">RemeberTheTrojans</span>
          </div>
          <span class="text-xs text-zinc-600">0-0-0</span>
        </div>
      </div>
    </div>
  </div>
</Layout>
