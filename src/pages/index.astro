---
import Layout from "../layouts/Layout.astro";
import { getStandings, teams } from "../data/teams";
import { getNflTeamLogoUrl } from "../data/players";
const standings = getStandings();
---

<Layout title="TINEZ LEAGUE">
  <!-- Hero Section -->
  <div class="relative mb-10 overflow-hidden rounded-2xl border border-amber-500/20">
    <div class="hero-gradient absolute inset-0 animate-gradient"></div>
    <div class="absolute inset-0 bg-gradient-to-t from-zinc-950 via-transparent to-transparent"></div>
    <div class="relative z-10 p-8 md:p-12">
      <div class="flex flex-col gap-6 md:flex-row md:items-center md:justify-between">
        <div>
          <div class="flex items-center gap-3 mb-3">
            <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-xl font-bold text-white shadow-lg shadow-amber-500/20">T</div>
            <div>
              <h1 class="text-3xl md:text-4xl font-extrabold tracking-tight">
                <span class="gradient-text">TINEZ LEAGUE</span>
              </h1>
              <div class="flex items-center gap-2 mt-1">
                <span class="rounded-full bg-amber-500/15 px-3 py-0.5 text-xs font-semibold text-amber-400 border border-amber-500/20">2026 Season</span>
                <span class="text-xs text-zinc-500">Yahoo League #103379</span>
              </div>
            </div>
          </div>
          <p class="text-zinc-400 max-w-xl">14 teams battling for supremacy in the most competitive keeper league in fantasy football.</p>
        </div>
        <div class="flex flex-wrap gap-2">
          <a href="/rules" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700/50 hover:text-zinc-100 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/></svg>
            Rules
          </a>
          <a href="/schedules" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700/50 hover:text-zinc-100 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            Schedules
          </a>
          <a href="/players" class="inline-flex items-center gap-1.5 rounded-lg bg-amber-500/10 backdrop-blur-sm border border-amber-500/20 px-4 py-2 text-sm font-medium text-amber-400 hover:bg-amber-500/20 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Players
          </a>
          <a href="/news" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700/50 hover:text-zinc-100 transition-all">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 22h16a2 2 0 0 0 2-2V4a2 2 0 0 0-2-2H8a2 2 0 0 0-2 2v16a2 2 0 0 1-2 2Zm0 0a2 2 0 0 1-2-2v-9h2"/><path d="M18 14h-8"/><path d="M15 18h-5"/><path d="M10 6h8v4h-8V6Z"/></svg>
            News
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- League Overview Stats -->
  <div class="mb-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-4 stagger-children">
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">14</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Teams</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">🏆</div>
      </div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">2</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Divisions</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">⚔️</div>
      </div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">8</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Playoff Teams</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">🏅</div>
      </div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">0.5</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">PPR Scoring</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">📊</div>
      </div>
    </div>
  </div>

  <!-- Standings -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-zinc-100">League Standings</h2>
      <a href="/teams" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">View all teams →</a>
    </div>
    <div class="glass-card-static rounded-xl overflow-hidden">
      <table class="premium-table">
        <thead>
          <tr>
            <th class="w-8">#</th>
            <th>Team</th>
            <th class="text-center">W</th>
            <th class="text-center">L</th>
            <th class="text-center">T</th>
            <th class="text-right">PF</th>
            <th class="text-right hidden sm:table-cell">PA</th>
            <th class="text-right hidden md:table-cell">Diff</th>
            <th class="text-center hidden lg:table-cell">Streak</th>
          </tr>
        </thead>
        <tbody>
          {standings.map((team, i) => {
            const diff = team.pointsFor - team.pointsAgainst;
            const isTop3 = i < 3;
            return (
              <tr class="hover:bg-zinc-800/30 transition-colors cursor-pointer" onclick={`window.location='/teams/${team.id}'`}>
                <td class="text-zinc-500 font-mono text-xs">
                  {i === 0 ? <span class="text-amber-400">🥇</span> : i === 1 ? <span class="text-zinc-300">🥈</span> : i === 2 ? <span class="text-amber-600">🥉</span> : i + 1}
                </td>
                <td>
                  <a href={`/teams/${team.id}`} class="flex items-center gap-3 group">
                    <div class="h-9 w-9 rounded-lg flex items-center justify-center text-xs font-bold text-white shrink-0" style={`background: linear-gradient(135deg, ${team.primaryColor}, ${team.secondaryColor})`}>
                      {team.shortName}
                    </div>
                    <div>
                      <div class="font-semibold text-sm text-zinc-100 group-hover:text-amber-400 transition-colors">{team.name}</div>
                      <div class="text-xs text-zinc-500">{team.owner}</div>
                    </div>
                  </a>
                </td>
                <td class="text-center font-mono text-sm font-semibold">{team.wins}</td>
                <td class="text-center font-mono text-sm">{team.losses}</td>
                <td class="text-center font-mono text-sm text-zinc-500">{team.ties}</td>
                <td class="text-right font-mono text-sm font-semibold text-emerald-400">{team.pointsFor.toFixed(1)}</td>
                <td class="text-right font-mono text-sm text-zinc-400 hidden sm:table-cell">{team.pointsAgainst.toFixed(1)}</td>
                <td class="text-right font-mono text-sm hidden md:table-cell">
                  <span class={diff > 0 ? "text-emerald-400" : diff < 0 ? "text-red-400" : "text-zinc-500"}>
                    {diff > 0 ? '+' : ''}{diff.toFixed(1)}
                  </span>
                </td>
                <td class="text-center hidden lg:table-cell">
                  <span class="inline-flex items-center rounded-full bg-zinc-800/50 px-2.5 py-0.5 text-xs font-mono text-zinc-400 border border-zinc-700/30">{team.streak}</span>
                </td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Week 1 Matchups -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-xl font-bold text-zinc-100">Week 1 Matchups</h2>
      <span class="text-xs text-zinc-500">Season Opener</span>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 stagger-children">
      {[
        { team1: teams[0], team2: teams[12] },
        { team1: teams[1], team2: teams[5] },
        { team1: teams[2], team2: teams[10] },
        { team1: teams[3], team2: teams[9] },
        { team1: teams[4], team2: teams[8] },
        { team1: teams[6], team2: teams[7] },
        { team1: teams[11], team2: teams[13] },
      ].map(m => (
        <div class="glass-card rounded-xl p-4">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <div class="h-8 w-8 rounded-lg flex items-center justify-center text-xs font-bold text-white shrink-0" style={`background: linear-gradient(135deg, ${m.team1.primaryColor}, ${m.team1.secondaryColor})`}>
                {m.team1.shortName}
              </div>
              <div>
                <div class="text-sm font-semibold text-zinc-100">{m.team1.name}</div>
                <div class="text-xs text-zinc-500">{m.team1.owner}</div>
              </div>
            </div>
            <div class="text-xs text-zinc-600 font-mono">{m.team1.wins}-{m.team1.losses}</div>
          </div>
          <div class="my-2 flex items-center gap-2">
            <div class="flex-1 h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent"></div>
            <span class="text-xs font-semibold text-zinc-500 uppercase tracking-widest">VS</span>
            <div class="flex-1 h-px bg-gradient-to-r from-transparent via-zinc-700 to-transparent"></div>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-2.5">
              <div class="h-8 w-8 rounded-lg flex items-center justify-center text-xs font-bold text-white shrink-0" style={`background: linear-gradient(135deg, ${m.team2.primaryColor}, ${m.team2.secondaryColor})`}>
                {m.team2.shortName}
              </div>
              <div>
                <div class="text-sm font-semibold text-zinc-100">{m.team2.name}</div>
                <div class="text-xs text-zinc-500">{m.team2.owner}</div>
              </div>
            </div>
            <div class="text-xs text-zinc-600 font-mono">{m.team2.wins}-{m.team2.losses}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>