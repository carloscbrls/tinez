---
import Layout from "../../layouts/Layout.astro";
import {
  fetchAllPlayersWithValues,
  getValueLabel,
  getValueColor,
  getValueBg,
  getEspnHeadshotUrl,
  getNflTeamLogo,
  getProfileKey,
} from "../../data/leaguelogs";

const allPlayers = await fetchAllPlayersWithValues();

const byPosition: Record<string, typeof allPlayers> = {};
for (const p of allPlayers) {
  if (!byPosition[p.position]) byPosition[p.position] = [];
  byPosition[p.position].push(p);
}
for (const pos of Object.keys(byPosition)) {
  byPosition[pos].sort((a, b) => a.overallRank - b.overallRank);
}

const positions = ["QB", "RB", "WR", "TE"];
const positionMeta: Record<string, { icon: string; color: string; gradient: string; desc: string }> = {
  QB: { icon: "🎯", color: "text-blue-400", gradient: "from-blue-500/10 to-indigo-500/5", desc: "Field generals" },
  RB: { icon: "💨", color: "text-emerald-400", gradient: "from-emerald-500/10 to-teal-500/5", desc: "Workhorses" },
  WR: { icon: "🔥", color: "text-amber-400", gradient: "from-amber-500/10 to-orange-500/5", desc: "Playmakers" },
  TE: { icon: "🛡️", color: "text-purple-400", gradient: "from-purple-500/10 to-pink-500/5", desc: "Matchup nightmares" },
};

const totalPlayers = allPlayers.length;
const profileKey = getProfileKey();
---

<Layout title="Player Values">
  <!-- Hero -->
  <div class="mb-10">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-amber-500/5 via-transparent to-transparent"></div>
      <div class="relative z-10 p-6 md:p-10">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 text-2xl shadow-lg shadow-amber-500/20">💎</div>
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl md:text-4xl font-extrabold tracking-tight mb-1">
              <span class="bg-gradient-to-r from-amber-200 via-amber-400 to-orange-400 bg-clip-text text-transparent">Player Values</span>
            </h1>
            <p class="text-zinc-400 text-sm md:text-base">Market-driven valuations from LeagueLogs · <span class="text-zinc-300 font-semibold">{totalPlayers}</span> players ranked · Updates every 6h</p>
          </div>
          <div class="flex items-center gap-2 shrink-0">
            <span class="flex h-2 w-2 rounded-full bg-emerald-400 animate-pulse"></span>
            <span class="text-[11px] text-zinc-500 font-mono">LIVE DATA</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Value Legend - Compact card -->
  <div class="mb-10 rounded-xl border border-zinc-800/60 bg-zinc-900/50 backdrop-blur-sm p-5">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-sm">📊</span>
      <h2 class="text-xs font-bold text-zinc-400 uppercase tracking-widest">Value Tiers</h2>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-5 gap-2">
      <div class="rounded-lg bg-amber-500/10 border border-amber-500/20 px-3 py-2.5 text-center">
        <div class="text-xs font-bold text-amber-400">Elite</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">80 – 100</div>
      </div>
      <div class="rounded-lg bg-emerald-500/10 border border-emerald-500/20 px-3 py-2.5 text-center">
        <div class="text-xs font-bold text-emerald-400">High</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">60 – 79</div>
      </div>
      <div class="rounded-lg bg-blue-500/10 border border-blue-500/20 px-3 py-2.5 text-center">
        <div class="text-xs font-bold text-blue-400">Mid</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">40 – 59</div>
      </div>
      <div class="rounded-lg bg-zinc-500/10 border border-zinc-500/20 px-3 py-2.5 text-center">
        <div class="text-xs font-bold text-zinc-400">Low</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">20 – 39</div>
      </div>
      <div class="rounded-lg bg-zinc-700/20 border border-zinc-700/30 px-3 py-2.5 text-center">
        <div class="text-xs font-bold text-zinc-600">Depth</div>
        <div class="text-[10px] text-zinc-700 mt-0.5">0 – 19</div>
      </div>
    </div>
  </div>

  <!-- Position Sections -->
  <div class="space-y-10">
    {positions.filter(p => byPosition[p]?.length).map(pos => {
      const meta = positionMeta[pos];
      const players = byPosition[pos].slice(0, 50);
      return (
        <section>
          <!-- Section Header -->
          <div class="flex items-center justify-between mb-4">
            <div class="flex items-center gap-3">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-800/80 text-sm">{meta.icon}</div>
              <div>
                <h2 class="text-lg font-bold text-zinc-100">{pos}s</h2>
                <p class="text-[11px] text-zinc-500">{meta.desc} · {players.length} ranked</p>
              </div>
            </div>
            <div class="hidden sm:flex items-center gap-1.5 text-[10px] text-zinc-600">
              <span class="font-mono">#{players[0]?.overallRank || "—"}</span>
              <span>to</span>
              <span class="font-mono">#{players[players.length-1]?.overallRank || "—"}</span>
            </div>
          </div>

          <!-- Table -->
          <div class="rounded-xl border border-zinc-800/40 bg-zinc-900/30 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="border-b border-zinc-800/40">
                    <th class="text-left px-4 py-3 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Player</th>
                    <th class="text-center px-3 py-3 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Team</th>
                    <th class="text-center px-3 py-3 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Rank</th>
                    <th class="text-center px-3 py-3 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Pos</th>
                    <th class="text-right px-4 py-3 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Value</th>
                    <th class="text-center px-3 py-3 text-[10px] font-semibold uppercase tracking-widest text-zinc-500">Tier</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-zinc-800/20">
                  {players.map((p, i) => {
                    const headshot = getEspnHeadshotUrl(p.espnId);
                    const teamLogo = getNflTeamLogo(p.team);
                    const valueLabel = getValueLabel(p.value);
                    const valueColor = getValueColor(p.value);
                    const isEven = i % 2 === 0;
                    return (
                      <tr class={`transition-colors hover:bg-zinc-800/30 ${isEven ? 'bg-zinc-900/20' : 'bg-transparent'}`}>
                        <td class="px-4 py-2.5">
                          <div class="flex items-center gap-3">
                            <div class="relative shrink-0">
                              {headshot ? (
                                <img src={headshot} alt={p.name} class="h-9 w-9 rounded-lg object-cover bg-zinc-800 ring-1 ring-zinc-700/50" loading="lazy" onerror="this.style.display='none'" />
                              ) : (
                                <div class="h-9 w-9 rounded-lg bg-zinc-800 ring-1 ring-zinc-700/50 flex items-center justify-center text-xs font-bold text-zinc-600">
                                  {p.name.charAt(0)}
                                </div>
                              )}
                            </div>
                            <div class="min-w-0">
                              <div class="text-sm font-semibold text-zinc-100 truncate max-w-[160px] md:max-w-[200px]">{p.name}</div>
                              <div class="text-[10px] text-zinc-600 font-mono">#{p.overallRank} overall</div>
                            </div>
                          </div>
                        </td>
                        <td class="px-3 py-2.5 text-center">
                          <div class="flex items-center justify-center gap-1.5">
                            <img src={teamLogo} alt={p.team} class="h-5 w-5 object-contain" loading="lazy" onerror="this.style.display='none'" />
                            <span class="text-xs font-mono font-medium text-zinc-400">{p.team}</span>
                          </div>
                        </td>
                        <td class="px-3 py-2.5 text-center">
                          <span class="inline-flex items-center justify-center h-6 min-w-[28px] rounded-md bg-zinc-800/60 px-1.5 text-xs font-mono font-semibold text-zinc-300">
                            {p.overallRank}
                          </span>
                        </td>
                        <td class="px-3 py-2.5 text-center">
                          <span class="inline-flex items-center justify-center h-6 min-w-[28px] rounded-md bg-zinc-800/40 px-1.5 text-xs font-mono text-zinc-500">
                            {p.positionRank}
                          </span>
                        </td>
                        <td class="px-4 py-2.5 text-right">
                          <div class="flex items-center justify-end gap-2">
                            <div class="w-16 h-1.5 rounded-full bg-zinc-800 overflow-hidden">
                              <div class="h-full rounded-full transition-all" class:list={[
                                p.value >= 80 ? 'bg-amber-400' :
                                p.value >= 60 ? 'bg-emerald-400' :
                                p.value >= 40 ? 'bg-blue-400' :
                                p.value >= 20 ? 'bg-zinc-400' : 'bg-zinc-600'
                              ]} style={`width: ${p.value}%`}></div>
                            </div>
                            <span class="text-sm font-mono font-bold text-zinc-200 w-12 text-right">{p.value.toFixed(1)}</span>
                          </div>
                        </td>
                        <td class="px-3 py-2.5 text-center">
                          <span class={`inline-block rounded-md px-2 py-1 text-[10px] font-semibold border ${getValueBg(p.value)} ${valueColor}`}>
                            {valueLabel}
                          </span>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </div>
        </section>
      );
    })}
  </div>

  <!-- Attribution -->
  <div class="mt-12 pt-6 border-t border-zinc-800/30 text-center">
    <a href="https://leaguelogs.com" target="_blank" rel="noopener" class="inline-flex items-baseline gap-1.5 text-sm text-zinc-600 hover:text-zinc-400 transition-colors" style="font-family:Georgia,'Times New Roman',serif;">
      <span>Powered by</span>
      <em class="font-semibold not-italic" style="letter-spacing:-0.01em;">LeagueLogs</em>
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-amber-400/60"></span>
    </a>
  </div>
</Layout>
