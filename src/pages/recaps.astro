---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Recaps">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📰</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Weekly Recaps</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2026 Season · Auto-Generated</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pre-Season Notice -->
  <div class="glass-card-accent rounded-xl p-12 text-center mb-8">
    <div class="text-5xl mb-4">📰</div>
    <h2 class="text-xl font-bold text-amber-400 mb-2">Pre-Season — No recaps yet</h2>
    <p class="text-zinc-400">Check back after Week 1.</p>
  </div>

  <!-- Season Summary -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">📊</span>
      <h2 class="text-lg font-bold text-zinc-100">Season Summary</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      <div class="bg-zinc-800/30 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-amber-400">0</div>
        <div class="text-xs text-zinc-500">Weeks Completed</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-amber-400">—</div>
        <div class="text-xs text-zinc-500">Current Leader</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-amber-400">0</div>
        <div class="text-xs text-zinc-500">Most Points For</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4 text-center">
        <div class="text-2xl font-bold text-amber-400">0</div>
        <div class="text-xs text-zinc-500">Total Transactions</div>
      </div>
    </div>
  </div>
</Layout>
