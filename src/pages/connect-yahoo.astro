---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Connect Yahoo | Tinez Fantasy Football">
  <main class="min-h-screen bg-gradient-to-b from-zinc-950 via-zinc-900 to-zinc-950">
    <!-- Hero -->
    <div class="relative overflow-hidden border-b border-zinc-800/50">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-purple-600/10 via-transparent to-transparent"></div>
      <div class="max-w-4xl mx-auto px-4 py-16 md:py-24 relative">
        <div class="flex items-center gap-3 mb-4">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-purple-500 to-pink-500 text-lg shadow-lg shadow-purple-500/20">🔗</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-bold text-white">Connect Yahoo</h1>
            <p class="text-zinc-400 text-xs md:text-sm">Link your Yahoo Fantasy Football league</p>
          </div>
        </div>

        <div class="bg-zinc-900/60 border border-zinc-800 rounded-2xl p-6 md:p-8 mt-6">
          <h2 class="text-lg font-semibold text-white mb-2">Why connect Yahoo?</h2>
          <ul class="space-y-2 text-zinc-400 text-sm">
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-0.5">•</span>
              <span>View your league's actual rosters, standings, and matchups</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-0.5">•</span>
              <span>Live fantasy scores during the season</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-0.5">•</span>
              <span>Real Yahoo ADP and ownership percentages</span>
            </li>
            <li class="flex items-start gap-2">
              <span class="text-purple-400 mt-0.5">•</span>
              <span>Personalized trade and waiver recommendations</span>
            </li>
          </ul>

          <div class="mt-6 flex flex-col sm:flex-row gap-3">
            <a
              href="/api/yahoo/login"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold text-sm hover:from-purple-500 hover:to-pink-500 transition-all shadow-lg shadow-purple-600/20"
            >
              <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
                <path d="M13.5 2L22 20h-5.5L12 9.5 7.5 20H2l8.5-18h3z"/>
              </svg>
              Connect Yahoo Account
            </a>
            <a
              href="/api/yahoo/status"
              class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl bg-zinc-800 text-zinc-300 font-semibold text-sm hover:bg-zinc-700 transition-all"
            >
              Check Connection Status
            </a>
          </div>
        </div>

        <div class="mt-4 text-xs text-zinc-600">
          <p>You'll be redirected to Yahoo to authorize access. Your credentials are never stored on our servers.</p>
        </div>
      </div>
    </div>
  </main>
</Layout>
