---
import Layout from "../layouts/Layout.astro";
import { teams } from "../data/teams";
---

<Layout title="Keepers">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🔄</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Keeper Tracker</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2026 Season · Keeper (1+1) Format</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pre-Season Notice -->
  <div class="glass-card-accent rounded-xl p-12 text-center mb-8">
    <div class="text-5xl mb-4">🔄</div>
    <h2 class="text-xl font-bold text-amber-400 mb-2">Pre-Season — Keeper selections pending</h2>
    <p class="text-zinc-400">Keeper data will appear once teams submit their selections before the draft.</p>
  </div>

  <!-- Keeper Rules -->
  <div class="glass-card-accent rounded-xl p-5 mb-8">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-lg">📋</span>
      <h2 class="text-sm font-bold text-amber-400 uppercase tracking-wider">Keeper Rules</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 text-xs text-zinc-400">
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Each team keeps <strong class="text-zinc-200">1 player + 1 rookie</strong> from previous season</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Keepers cost <strong class="text-zinc-200">1 round higher</strong> than previous draft position</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Undrafted players kept as <strong class="text-zinc-200">15th round</strong> pick</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Rookies kept as <strong class="text-zinc-200">16th round</strong> pick (separate from main keeper)</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Players kept <strong class="text-zinc-200">max 2 consecutive years</strong> before returning to pool</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Keeper deadline: <strong class="text-zinc-200">1 week before draft</strong></span>
      </div>
    </div>
  </div>

  <!-- Team Keeper Cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
    {teams.map(t => (
      <div class="glass-card rounded-xl overflow-hidden">
        <div class="bg-gradient-to-r from-amber-500/10 to-orange-500/5 p-4 border-b border-zinc-800/40">
          <h3 class="text-sm font-bold text-zinc-100">{t.name}</h3>
          <p class="text-[10px] text-zinc-500">{t.owner}</p>
        </div>
        <div class="p-4">
          <div class="text-center py-4">
            <p class="text-xs text-zinc-600">Keeper selections pending</p>
          </div>
        </div>
      </div>
    ))}
  </div>

  <!-- Keeper Strategy Tips -->
  <div class="mt-8 glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💡</span>
      <h2 class="text-lg font-bold text-zinc-100">Keeper Strategy</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Best Keeper Values</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Late-round RBs who became starters (e.g., 12th round → 11th round cost)</li>
          <li>• Breakout WRs drafted in double-digit rounds</li>
          <li>• Rookies who outperformed their ADP</li>
          <li>• Players returning from injury with discounted cost</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-red-400 mb-2">When NOT to Keep</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• First-round picks (no discount, same value in draft)</li>
          <li>• Aging stars with declining production</li>
          <li>• Players in timeshares or uncertain roles</li>
          <li>• When you can get equal value in the same round</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
