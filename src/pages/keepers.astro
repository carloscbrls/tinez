---
import Layout from "../layouts/Layout.astro";
import { teams } from "../data/teams";
import { teamRosters, getKeeperEligible, getKeeperCost, getKeeperSummary } from "../data/keepers";
---

<Layout title="Keepers">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🔄</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Keeper Tracker</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2026 Season · Keeper (1+1) Format</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- 2025 Final Standings -->
  <div class="glass-card-accent rounded-xl p-5 mb-8">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-lg">🏆</span>
      <h2 class="text-sm font-bold text-amber-400 uppercase tracking-wider">2025 Season Results</h2>
    </div>
    <div class="grid gap-2 text-xs">
      <div class="flex items-center gap-2">
        <span class="text-yellow-400">🥇</span>
        <span class="text-zinc-200 font-semibold">Best Pacheco Hoe</span>
        <span class="text-zinc-500">(jayyphilly) — Champion</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-zinc-400">🥈</span>
        <span class="text-zinc-200 font-semibold">The Red Hare & Golden Dragon</span>
        <span class="text-zinc-500">(darnell) — 2nd Place</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="text-amber-700">🥉</span>
        <span class="text-zinc-200 font-semibold">LaFlamaBlanca</span>
        <span class="text-zinc-500">(scooter) — 3rd Place</span>
      </div>
    </div>
  </div>

  <!-- Keeper Rules -->
  <div class="glass-card-accent rounded-xl p-5 mb-8">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-lg">📋</span>
      <h2 class="text-sm font-bold text-amber-400 uppercase tracking-wider">Keeper Rules</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 text-xs text-zinc-400">
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Each team keeps <strong class="text-zinc-200">1 player + 1 rookie</strong> from previous season</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Keepers cost <strong class="text-zinc-200">1 round higher</strong> than previous draft position</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Undrafted players kept as <strong class="text-zinc-200">15th round</strong> pick</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Rookies kept as <strong class="text-zinc-200">16th round</strong> pick (separate from main keeper)</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Players kept <strong class="text-zinc-200">max 2 consecutive years</strong> before returning to pool</span>
      </div>
      <div class="flex items-start gap-2">
        <span class="text-emerald-400 mt-0.5">•</span>
        <span>Keeper deadline: <strong class="text-zinc-200">1 week before draft</strong></span>
      </div>
    </div>
  </div>

  <!-- Team Keeper Cards -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
    {teamRosters.map(roster => {
      const { eligible, kept } = getKeeperSummary(roster.teamName);
      return (
        <div class="glass-card rounded-xl overflow-hidden">
          <div class="bg-gradient-to-r from-amber-500/10 to-orange-500/5 p-4 border-b border-zinc-800/40">
            <h3 class="text-sm font-bold text-zinc-100">{roster.teamName}</h3>
            <p class="text-[10px] text-zinc-500">{roster.manager}</p>
          </div>
          <div class="p-4">
            <!-- Previously Kept Players -->
            {kept.length > 0 && (
              <div class="mb-3">
                <h4 class="text-[10px] font-semibold text-amber-400 uppercase tracking-wider mb-2">Previously Kept (2025)</h4>
                <div class="space-y-1.5">
                  {kept.map(p => (
                    <div class="flex items-center justify-between bg-amber-500/5 rounded-lg px-2.5 py-1.5">
                      <div class="flex items-center gap-1.5">
                        <span class="text-xs">🔒</span>
                        <span class="text-xs font-medium text-zinc-200">{p.name}</span>
                        <span class="text-[10px] text-zinc-500">{p.position} · {p.nflTeam}</span>
                      </div>
                      <span class="text-[10px] text-amber-400 font-mono">Rd {p.draftRound}</span>
                    </div>
                  ))}
                </div>
              </div>
            )}

            <!-- Keeper Eligible Players -->
            <div>
              <h4 class="text-[10px] font-semibold text-emerald-400 uppercase tracking-wider mb-2">Keeper Eligible (Rd 4+)</h4>
              <div class="space-y-1 max-h-48 overflow-y-auto">
                {eligible.map(p => {
                  const cost = getKeeperCost(p);
                  return (
                    <div class="flex items-center justify-between px-2.5 py-1 hover:bg-zinc-800/30 rounded-lg transition-colors">
                      <div class="flex items-center gap-1.5 min-w-0">
                        <span class="text-xs shrink-0">{p.isKeeper ? "🔒" : "🔓"}</span>
                        <span class="text-xs text-zinc-200 truncate">{p.name}</span>
                        <span class="text-[10px] text-zinc-500 shrink-0">{p.position} · {p.nflTeam}</span>
                      </div>
                      <div class="flex items-center gap-1.5 shrink-0">
                        <span class="text-[10px] text-zinc-600 font-mono">Rd {p.draftRound}</span>
                        <span class="text-[10px] text-emerald-400 font-mono">→ Rd {cost}</span>
                      </div>
                    </div>
                  );
                })}
              </div>
            </div>

            {eligible.length === 0 && kept.length === 0 && (
              <div class="text-center py-4">
                <p class="text-xs text-zinc-600">Keeper selections pending</p>
              </div>
            )}
          </div>
        </div>
      );
    })}
  </div>

  <!-- Keeper Strategy Tips -->
  <div class="mt-8 glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💡</span>
      <h2 class="text-lg font-bold text-zinc-100">Keeper Strategy</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Best Keeper Values</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Late-round RBs who became starters (e.g., 12th round → 11th round cost)</li>
          <li>• Breakout WRs drafted in double-digit rounds</li>
          <li>• Rookies who outperformed their ADP</li>
          <li>• Players returning from injury with discounted cost</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-red-400 mb-2">When NOT to Keep</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• First-round picks (no discount, same value in draft)</li>
          <li>• Aging stars with declining production</li>
          <li>• Players in timeshares or uncertain roles</li>
          <li>• When you can get equal value in the same round</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
