---
import Layout from "../layouts/Layout.astro";
import { nflTeams } from "../data/nfl-teams";
---

<Layout title="NFL Team X Feeds">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-sky-600/20 via-blue-600/10 to-zinc-900 p-8 border border-sky-500/20">
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight">NFL Team X Feeds</h1>
        <p class="mt-1 text-zinc-400">Follow all 32 NFL teams on X/Twitter</p>
      </div>
    </div>
  </div>

  <!-- Quick links -->
  <div class="mb-6 flex flex-wrap gap-2">
    <a href="/schedules" class="rounded-lg bg-zinc-800 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700 transition-colors">
      📅 View Schedules
    </a>
    <a href="/podcasts" class="rounded-lg bg-zinc-800 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700 transition-colors">
      🎙️ Fantasy Podcasts
    </a>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
    {nflTeams.map(team => (
      <a
        href={`https://x.com/${team.xHandle}`}
        target="_blank"
        rel="noopener noreferrer"
        class="group flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/30 p-3 hover:border-zinc-700 hover:bg-zinc-900/50 transition-all"
      >
        <div
          class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg text-sm font-bold text-white"
          style={`background: ${team.primaryColor}`}
        >
          {team.shortName}
        </div>
        <div class="min-w-0 flex-1">
          <div class="truncate font-medium text-sm group-hover:text-sky-400 transition-colors">{team.name}</div>
          <div class="text-xs text-zinc-500">@{team.xHandle}</div>
        </div>
        <svg class="h-4 w-4 shrink-0 text-zinc-600 group-hover:text-zinc-400 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    ))}
  </div>

  <!-- Embedded X Timeline Widget Demo -->
  <div class="mt-8">
    <h2 class="mb-4 text-lg font-semibold">Featured Feeds</h2>
    <div class="grid gap-4 md:grid-cols-2">
      <!-- NFL Official -->
      <div class="rounded-xl border border-zinc-800 p-4">
        <div class="mb-3 flex items-center gap-2">
          <span class="text-lg">🏈</span>
          <span class="font-medium">@NFL</span>
        </div>
        <a 
          href="https://x.com/NFL" 
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-lg bg-zinc-900 p-8 text-center text-sm text-zinc-500 hover:bg-zinc-800 transition-colors"
        >
          <p>Follow @NFL on X for official league news, highlights, and updates.</p>
          <p class="mt-2 text-xs text-zinc-600">Click to open on X.com</p>
        </a>
      </div>

      <!-- Fantasy Focus -->
      <div class="rounded-xl border border-zinc-800 p-4">
        <div class="mb-3 flex items-center gap-2">
          <span class="text-lg">🎯</span>
          <span class="font-medium">@ESPNFantasy</span>
        </div>
        <a 
          href="https://x.com/ESPNFantasy" 
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-lg bg-zinc-900 p-8 text-center text-sm text-zinc-500 hover:bg-zinc-800 transition-colors"
        >
          <p>Follow @ESPNFantasy for expert advice, rankings, and breaking news.</p>
          <p class="mt-2 text-xs text-zinc-600">Click to open on X.com</p>
        </a>
      </div>
    </div>
  </div>
</Layout>
