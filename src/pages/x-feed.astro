---
import Layout from "../layouts/Layout.astro";
import { nflTeams } from "../data/nfl-teams";
import { getNflTeamLogoUrl } from "../data/players";
---

<Layout title="NFL Team X Feeds">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-sky-500/20">
      <div class="absolute inset-0 bg-gradient-to-br from-sky-600/10 via-blue-600/5 to-transparent animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-sky-400 to-blue-500 text-lg font-bold text-white shadow-lg shadow-sky-500/20">X</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">NFL Team X Feeds</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Follow all 32 NFL teams on X/Twitter</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick links -->
  <div class="mb-6 flex flex-wrap gap-2">
    <a href="/schedules" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700/50 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
      View Schedules
    </a>
    <a href="/podcasts" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 backdrop-blur-sm border border-zinc-700/50 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700/50 transition-all">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18v-6a9 9 0 0 1 18 0v6"/><path d="M21 19a2 2 0 0 1-2 2h-1a2 2 0 0 1-2-2v-3a2 2 0 0 1 2-2h3zM3 19a2 2 0 0 0 2 2h1a2 2 0 0 0 2-2v-3a2 2 0 0 0-2-2H3z"/></svg>
      Fantasy Podcasts
    </a>
  </div>

  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 stagger-children">
    {nflTeams.map(team => (
      <a
        href={`https://x.com/${team.xHandle}`}
        target="_blank"
        rel="noopener noreferrer"
        class="glass-card rounded-lg p-3 flex items-center gap-3 group"
      >
        <img src={getNflTeamLogoUrl(team.shortName)} alt={team.name} class="h-9 w-9 object-contain shrink-0" loading="lazy" onerror="this.style.display='none'" />
        <div class="min-w-0 flex-1">
          <div class="truncate font-semibold text-sm text-zinc-100 group-hover:text-sky-400 transition-colors">{team.name}</div>
          <div class="text-xs text-zinc-500">@{team.xHandle}</div>
        </div>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-zinc-600 group-hover:text-zinc-400 transition-colors"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
      </a>
    ))}
  </div>

  <!-- Featured Feeds -->
  <div class="mt-8">
    <h2 class="text-lg font-bold text-zinc-100 mb-4">Featured Feeds</h2>
    <div class="grid gap-4 md:grid-cols-2 stagger-children">
      <!-- NFL Official -->
      <div class="glass-card rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-800/50 text-sm">🏈</div>
          <span class="font-bold text-zinc-200">@NFL</span>
        </div>
        <a 
          href="https://x.com/NFL" 
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-xl bg-gradient-to-br from-zinc-800/30 to-zinc-900/30 p-8 text-center text-sm text-zinc-500 hover:from-zinc-800/50 hover:to-zinc-900/50 transition-all border border-zinc-700/20"
        >
          <p>Follow @NFL on X for official league news, highlights, and updates.</p>
          <p class="mt-2 text-xs text-zinc-600">Click to open on X.com</p>
        </a>
      </div>

      <!-- Fantasy Focus -->
      <div class="glass-card rounded-xl p-5">
        <div class="flex items-center gap-2 mb-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-zinc-800/50 text-sm">🎯</div>
          <span class="font-bold text-zinc-200">@ESPNFantasy</span>
        </div>
        <a 
          href="https://x.com/ESPNFantasy" 
          target="_blank"
          rel="noopener noreferrer"
          class="block rounded-xl bg-gradient-to-br from-zinc-800/30 to-zinc-900/30 p-8 text-center text-sm text-zinc-500 hover:from-zinc-800/50 hover:to-zinc-900/50 transition-all border border-zinc-700/20"
        >
          <p>Follow @ESPNFantasy for expert advice, rankings, and breaking news.</p>
          <p class="mt-2 text-xs text-zinc-600">Click to open on X.com</p>
        </a>
      </div>
    </div>
  </div>
</Layout>