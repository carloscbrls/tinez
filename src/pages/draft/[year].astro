---
import Layout from "../../layouts/Layout.astro";
import { fetchDraft, fetchDraftPicks, fetchAllPlayers, fetchUsers, LEAGUE_CONFIG } from "../../data/sleeper-api";
import { getEspnHeadshotUrl } from "../../data/players";
import { getNFLTeam } from "../../data/nfl-teams";

export async function getStaticPaths() {
  return [{ params: { year: "2025" }, props: { year: 2025 } }];
}

const { year } = Astro.props;

const [draft, picks, allPlayers, users] = await Promise.all([
  fetchDraft(),
  fetchDraftPicks(),
  fetchAllPlayers(),
  fetchUsers(),
]);

const userMap = new Map(users.map(u => [u.user_id, u]));

// Group picks by round
const byRound: Record<number, typeof picks> = {};
for (const pick of picks) {
  if (!byRound[pick.round]) byRound[pick.round] = [];
  byRound[pick.round].push(pick);
}

// Sort rounds
const rounds = Object.keys(byRound).map(Number).sort((a, b) => a - b);

// Get player info for a pick
function getPickPlayer(pick: typeof picks[0]) {
  if (!pick.player_id) return null;
  return allPlayers[pick.player_id] || null;
}

function getPickOwner(pick: typeof picks[0]) {
  const user = userMap.get(pick.picked_by_user_id);
  return user?.metadata?.team_name || user?.display_name || "Unknown";
}

const positionColors: Record<string, string> = {
  QB: "from-blue-500 to-indigo-500",
  RB: "from-emerald-500 to-teal-500",
  WR: "from-amber-500 to-orange-500",
  TE: "from-purple-500 to-pink-500",
  K: "from-red-500 to-rose-500",
  DEF: "from-zinc-500 to-zinc-600",
};
---

<Layout title={`${year} Draft`}>
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📋</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">{year} Draft Board</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · {picks.length} picks · {rounds.length} rounds</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Draft Summary -->
  <div class="grid gap-4 sm:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-amber-400">{picks.length}</div>
      <div class="text-xs text-zinc-500 mt-1">Total Picks</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-emerald-400">{rounds.length}</div>
      <div class="text-xs text-zinc-500 mt-1">Rounds</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-blue-400">{picks.filter(p => p.player_id).length}</div>
      <div class="text-xs text-zinc-500 mt-1">Players Drafted</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-purple-400">{new Set(picks.filter(p => p.player_id).map(p => allPlayers[p.player_id!]?.position).filter(Boolean)).size}</div>
      <div class="text-xs text-zinc-500 mt-1">Positions</div>
    </div>
  </div>

  <!-- Draft Board by Round -->
  {rounds.map(round => (
    <div class="mb-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-7 w-7 items-center justify-center rounded-lg bg-amber-500/10 text-xs font-bold text-amber-400">{round}</div>
        <h2 class="text-sm font-bold text-zinc-200">Round {round}</h2>
        <span class="text-xs text-zinc-600">({byRound[round].length} picks)</span>
      </div>
      <div class="glass-card-static rounded-xl overflow-x-auto">
        <table class="premium-table">
          <thead>
            <tr>
              <th class="w-8">Pick</th>
              <th>Player</th>
              <th class="text-center">Pos</th>
              <th class="text-center">Team</th>
              <th>Drafted By</th>
            </tr>
          </thead>
          <tbody>
            {byRound[round].map(pick => {
              const player = getPickPlayer(pick);
              const owner = getPickOwner(pick);
              const espnId = player?.espn_id || 0;
              const nfl = player?.team ? getNFLTeam(player.team) : null;
              return (
                <tr class="hover:bg-zinc-800/30 transition-colors">
                  <td class="text-zinc-500 font-mono text-xs">{pick.pick_no}</td>
                  <td>
                    <div class="flex items-center gap-2.5">
                      {espnId > 0 ? (
                        <img src={getEspnHeadshotUrl(espnId)} alt={player?.full_name || "Player"} class="h-8 w-8 rounded-lg object-cover" loading="lazy" onerror="this.style.display='none'" />
                      ) : (
                        <div class="h-8 w-8 rounded-lg bg-zinc-800 flex items-center justify-center text-xs font-bold text-zinc-500">?</div>
                      )}
                      <div>
                        <div class="text-sm font-semibold text-zinc-100">{player?.full_name || "Unknown"}</div>
                        <div class="text-[10px] text-zinc-500">{nfl?.name || player?.team || "FA"}</div>
                      </div>
                    </div>
                  </td>
                  <td class="text-center">
                    {player?.position ? (
                      <span class={`inline-flex items-center justify-center h-6 w-8 rounded text-[10px] font-bold text-white bg-gradient-to-br ${positionColors[player.position] || 'from-zinc-600 to-zinc-700'}`}>
                        {player.position}
                      </span>
                    ) : (
                      <span class="text-xs text-zinc-600">—</span>
                    )}
                  </td>
                  <td class="text-center">
                    {player?.team ? (
                      <span class="text-xs font-mono text-zinc-400">{player.team}</span>
                    ) : (
                      <span class="text-xs text-zinc-600">—</span>
                    )}
                  </td>
                  <td>
                    <span class="text-sm text-zinc-300">{owner}</span>
                  </td>
                </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </div>
  ))}

  {picks.length === 0 && (
    <div class="glass-card rounded-xl p-8 text-center">
      <div class="text-4xl mb-3">📭</div>
      <p class="text-sm text-zinc-500">No draft data available yet. Check back when the draft happens.</p>
    </div>
  )}
</Layout>
