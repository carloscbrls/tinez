---
import Layout from "../../layouts/Layout.astro";
import { teams } from "../../data/teams";

export async function getStaticPaths() {
  return [{ params: { year: "2025" }, props: { year: 2025 } }];
}

const { year } = Astro.props;
---

<Layout title={`${year} Draft`}>
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📋</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">{year} Draft Board</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2026 Season</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pre-Season Notice -->
  <div class="glass-card-accent rounded-xl p-12 text-center mb-8">
    <div class="text-5xl mb-4">📋</div>
    <h2 class="text-xl font-bold text-amber-400 mb-2">Pre-Season — Draft results not yet available</h2>
    <p class="text-zinc-400">The draft board will populate once the 2026 draft takes place.</p>
  </div>

  <!-- Draft Summary -->
  <div class="grid gap-4 sm:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-amber-400">—</div>
      <div class="text-xs text-zinc-500 mt-1">Total Picks</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-emerald-400">—</div>
      <div class="text-xs text-zinc-500 mt-1">Rounds</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-blue-400">—</div>
      <div class="text-xs text-zinc-500 mt-1">Players Drafted</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-bold text-purple-400">—</div>
      <div class="text-xs text-zinc-500 mt-1">Positions</div>
    </div>
  </div>

  <!-- Team List -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">👥</div>
      <h2 class="text-lg font-bold text-amber-400">The 14 Teams</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {teams.map(t => (
        <div class="glass-card rounded-xl p-4 flex items-center gap-3">
          <div class="h-10 w-10 rounded-xl flex items-center justify-center text-sm font-bold text-white shrink-0" style={`background: linear-gradient(135deg, ${t.primaryColor}, ${t.secondaryColor})`}>
            {t.shortName}
          </div>
          <div>
            <div class="text-sm font-semibold text-zinc-100">{t.name}</div>
            <div class="text-[10px] text-zinc-500">{t.owner}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
