---
import Layout from "../../layouts/Layout.astro";
import { draftHistory, getDraftByYear, getPicksByPosition } from "../../data/draft";
import { getNflTeamLogoUrl } from "../../data/players";
export async function getStaticPaths() {
  return draftHistory.map(d => ({
    params: { year: String(d.year) },
    props: { draft: d },
  }));
}
const { draft } = Astro.props;
const qbPicks = getPicksByPosition(draft.year, "QB");
const rbPicks = getPicksByPosition(draft.year, "RB");
const wrPicks = getPicksByPosition(draft.year, "WR");
const tePicks = getPicksByPosition(draft.year, "TE");
---

<Layout title={`${draft.year} Draft`}>
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">{draft.year}</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">{draft.year} Draft</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · Round 1</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Year Nav -->
  <div class="flex flex-wrap gap-2 mb-6">
    {draftHistory.map(d => (
      <a href={`/draft/${d.year}`} class="rounded-lg px-4 py-2 text-sm font-medium transition-all" class:list={[d.year === draft.year ? 'bg-amber-500/20 text-amber-400 border border-amber-500/30' : 'bg-zinc-800/50 text-zinc-400 hover:text-zinc-200 hover:bg-zinc-800 border border-zinc-700/30']}>
        {d.year}
      </a>
    ))}
  </div>

  <!-- Draft Board -->
  <div class="glass-card rounded-xl overflow-hidden mb-8">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-zinc-700/50 bg-zinc-800/30">
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Pick</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Team</th>
          <th class="px-4 py-3 text-left text-xs font-medium uppercase tracking-wider text-zinc-500">Player</th>
          <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-zinc-500">Pos</th>
          <th class="px-4 py-3 text-center text-xs font-medium uppercase tracking-wider text-zinc-500">NFL</th>
        </tr>
      </thead>
      <tbody>
        {draft.picks.map(pick => {
          const isYou = pick.owner === "Carlitos";
          return (
            <tr class="border-b border-zinc-800/30 hover:bg-zinc-800/20 transition-colors" class:list={[isYou ? 'bg-amber-500/5' : '']}>
              <td class="px-4 py-3">
                <div class="flex items-center gap-2">
                  <span class="flex h-6 w-6 items-center justify-center rounded-full bg-zinc-800 text-xs font-mono font-bold text-zinc-400">{pick.pick}</span>
                  <span class="text-[10px] text-zinc-600">R{pick.round}</span>
                </div>
              </td>
              <td class="px-4 py-3">
                <div class="font-medium" class:list={[isYou ? 'text-amber-400' : 'text-zinc-200']}>{pick.teamName}</div>
                <div class="text-[10px] text-zinc-600">{pick.owner}</div>
              </td>
              <td class="px-4 py-3 font-semibold text-zinc-100">{pick.playerName}</td>
              <td class="px-4 py-3 text-center">
                <span class="position-badge" class:list={[`position-badge-${pick.position.toLowerCase()}`]}>{pick.position}</span>
              </td>
              <td class="px-4 py-3 text-center">
                <img src={getNflTeamLogoUrl(pick.nflTeam)} alt={pick.nflTeam} class="inline-block h-5 w-5 object-contain" loading="lazy" />
              </td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>

  <!-- Position Breakdown -->
  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-zinc-200">QB</span>
        <span class="text-lg font-bold text-amber-400">{qbPicks.length}</span>
      </div>
      <div class="flex flex-wrap gap-1">
        {qbPicks.map(p => (
          <span class="rounded bg-zinc-800/50 px-1.5 py-0.5 text-[10px] text-zinc-400">{p.playerName}</span>
        ))}
      </div>
    </div>
    <div class="glass-card rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-zinc-200">RB</span>
        <span class="text-lg font-bold text-blue-400">{rbPicks.length}</span>
      </div>
      <div class="flex flex-wrap gap-1">
        {rbPicks.map(p => (
          <span class="rounded bg-zinc-800/50 px-1.5 py-0.5 text-[10px] text-zinc-400">{p.playerName}</span>
        ))}
      </div>
    </div>
    <div class="glass-card rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-zinc-200">WR</span>
        <span class="text-lg font-bold text-purple-400">{wrPicks.length}</span>
      </div>
      <div class="flex flex-wrap gap-1">
        {wrPicks.map(p => (
          <span class="rounded bg-zinc-800/50 px-1.5 py-0.5 text-[10px] text-zinc-400">{p.playerName}</span>
        ))}
      </div>
    </div>
    <div class="glass-card rounded-xl p-4">
      <div class="flex items-center justify-between mb-2">
        <span class="text-sm font-semibold text-zinc-200">TE</span>
        <span class="text-lg font-bold text-green-400">{tePicks.length}</span>
      </div>
      <div class="flex flex-wrap gap-1">
        {tePicks.map(p => (
          <span class="rounded bg-zinc-800/50 px-1.5 py-0.5 text-[10px] text-zinc-400">{p.playerName}</span>
        ))}
      </div>
    </div>
  </div>

  <!-- Back link -->
  <div class="text-center">
    <a href="/draft" class="inline-flex items-center gap-2 text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
      Back to Draft Board
    </a>
  </div>
</Layout>
