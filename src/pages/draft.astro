---
import Layout from "../layouts/Layout.astro";
import { players } from "../data/players";
---

<Layout title="Draft">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">D</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Draft Central</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Draft results, grades, and analysis</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Draft Overview Stats -->
  <div class="grid gap-4 sm:grid-cols-3 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">14</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Rounds</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">🔄</div>
      </div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">{players.length}</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Players Available</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">👤</div>
      </div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-3xl font-extrabold gradient-text">0.5</div>
          <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">PPR Scoring</div>
        </div>
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-amber-500/10 text-xl">📊</div>
      </div>
    </div>
  </div>

  <!-- Draft Status -->
  <div class="glass-card rounded-xl p-8 text-center mb-8">
    <div class="text-5xl mb-4">🏈</div>
    <h2 class="text-xl font-bold text-zinc-100 mb-2">Draft Coming Soon</h2>
    <p class="text-zinc-400 max-w-md mx-auto">Draft results, grades, and analysis will appear here after the draft. Data syncs from Yahoo Fantasy API.</p>
    <div class="mt-6 flex flex-wrap justify-center gap-3">
      <a href="/players" class="inline-flex items-center gap-1.5 rounded-lg bg-amber-500/10 border border-amber-500/20 px-4 py-2 text-sm font-medium text-amber-400 hover:bg-amber-500/20 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        Browse Players
      </a>
      <a href="/rules" class="inline-flex items-center gap-1.5 rounded-lg bg-zinc-800/50 border border-zinc-700/50 px-4 py-2 text-sm font-medium text-zinc-300 hover:bg-zinc-700/50 transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" x2="8" y1="13" y2="13"/><line x1="16" x2="8" y1="17" y2="17"/></svg>
        League Rules
      </a>
    </div>
  </div>

  <!-- Top Players Preview -->
  <div>
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-zinc-100">⭐ Top Players by Position</h2>
      <a href="/players" class="text-xs text-amber-400 hover:text-amber-300 transition-colors">View all →</a>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
      {["QB", "RB", "WR", "TE", "K", "DST"].map(pos => {
        const posPlayers = players.filter(p => p.position === pos).slice(0, 5);
        return (
          <div class="glass-card rounded-xl p-4">
            <div class="flex items-center gap-2 mb-3">
              <span class="text-lg">
                {pos === "QB" ? "🎯" : pos === "RB" ? "🏃" : pos === "WR" ? "🏈" : pos === "TE" ? "🔗" : pos === "K" ? "🦵" : "🛡️"}
              </span>
              <h3 class="font-bold text-sm text-zinc-100">{pos}</h3>
              <span class="text-xs text-zinc-600">Top {posPlayers.length}</span>
            </div>
            <div class="space-y-1.5">
              {posPlayers.map((p, i) => (
                <a href={`/players/${p.id}`} class="flex items-center gap-2 rounded-md px-2 py-1.5 hover:bg-zinc-800/30 transition-colors group">
                  <span class="w-4 text-xs font-mono text-zinc-600">{i + 1}</span>
                  <span class="text-xs font-semibold text-zinc-300 group-hover:text-amber-400 transition-colors truncate">{p.name}</span>
                  <span class="ml-auto text-xs text-zinc-600">{p.team}</span>
                </a>
              ))}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>