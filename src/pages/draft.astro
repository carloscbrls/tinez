---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Draft">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Draft</h1>
    <p class="mt-1 text-zinc-400">Draft results, grades, and analysis</p>
  </div>

  <div class="rounded-xl border border-zinc-800 p-8 text-center">
    <p class="text-zinc-500">Draft results will appear here after the draft.</p>
    <p class="mt-2 text-sm text-zinc-600">Data syncs from Yahoo Fantasy API.</p>
  </div>
</Layout>
