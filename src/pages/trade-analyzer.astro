---
import Layout from "../layouts/Layout.astro";
import { players, getEspnHeadshotUrl, getPositionColor } from "../data/players";
import { getNFLTeam } from "../data/nfl-teams";

// Group players by position
const byPosition: Record<string, typeof players> = {};
for (const p of players) {
  if (!byPosition[p.position]) byPosition[p.position] = [];
  byPosition[p.position].push(p);
}

// Sort each position by ADP
for (const pos of Object.keys(byPosition)) {
  byPosition[pos].sort((a, b) => (a.adp || 999) - (b.adp || 999));
}

const positions = ["QB", "RB", "WR", "TE", "K", "DEF"];
const positionColors: Record<string, string> = {
  QB: "from-blue-500 to-indigo-500",
  RB: "from-emerald-500 to-teal-500",
  WR: "from-amber-500 to-orange-500",
  TE: "from-purple-500 to-pink-500",
  K: "from-red-500 to-rose-500",
  DEF: "from-zinc-500 to-zinc-600",
};

// Serialize player data for client-side trade analyzer
const playerDataJson = JSON.stringify(
  Object.fromEntries(
    players
      .filter(p => p.adp)
      .map(p => [p.name, { name: p.name, pos: p.position, team: p.team, adp: p.adp, tier: p.tier || 5 }])
  )
);
---

<Layout title="Trade Analyzer">
  <!-- Player data for AI trade analyzer -->
  <script id="player-data" type="application/json" set:html={playerDataJson}></script>

  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🔄</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Trade Analyzer</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Compare player values · AI-powered trade evaluation · Win your league</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- AI Trade Evaluator -->
  <div class="glass-card rounded-xl p-6 mb-8 border border-amber-500/20">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-gradient-to-br from-purple-500 to-pink-500 text-sm">🤖</div>
      <h2 class="text-lg font-bold text-zinc-100">AI Trade Evaluator</h2>
      <span class="text-[10px] bg-purple-500/10 text-purple-400 px-2 py-0.5 rounded-full font-medium">NEW</span>
    </div>
    <p class="text-sm text-zinc-400 mb-4">Select players involved in a trade and get an AI-powered analysis with a winner/loser verdict.</p>

    <div class="grid gap-4 sm:grid-cols-2 mb-4">
      <div>
        <label class="text-xs font-semibold text-zinc-300 mb-2 block">Team A Sends (you)</label>
        <select id="team-a-player-1" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm text-zinc-100 mb-2">
          <option value="">Select player...</option>
          {players.filter(p => p.adp).sort((a, b) => (a.adp || 999) - (b.adp || 999)).slice(0, 100).map(p => (
            <option value={p.name}>{p.name} — {p.position} ({p.team}) — ADP {p.adp?.toFixed(1)}</option>
          ))}
        </select>
        <select id="team-a-player-2" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm text-zinc-100 mb-2">
          <option value="">Select player (optional)...</option>
          {players.filter(p => p.adp).sort((a, b) => (a.adp || 999) - (b.adp || 999)).slice(0, 100).map(p => (
            <option value={p.name}>{p.name} — {p.position} ({p.team}) — ADP {p.adp?.toFixed(1)}</option>
          ))}
        </select>
        <select id="team-a-player-3" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm text-zinc-100">
          <option value="">Select player (optional)...</option>
          {players.filter(p => p.adp).sort((a, b) => (a.adp || 999) - (b.adp || 999)).slice(0, 100).map(p => (
            <option value={p.name}>{p.name} — {p.position} ({p.team}) — ADP {p.adp?.toFixed(1)}</option>
          ))}
        </select>
      </div>
      <div>
        <label class="text-xs font-semibold text-zinc-300 mb-2 block">Team B Sends (them)</label>
        <select id="team-b-player-1" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm text-zinc-100 mb-2">
          <option value="">Select player...</option>
          {players.filter(p => p.adp).sort((a, b) => (a.adp || 999) - (b.adp || 999)).slice(0, 100).map(p => (
            <option value={p.name}>{p.name} — {p.position} ({p.team}) — ADP {p.adp?.toFixed(1)}</option>
          ))}
        </select>
        <select id="team-b-player-2" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm text-zinc-100 mb-2">
          <option value="">Select player (optional)...</option>
          {players.filter(p => p.adp).sort((a, b) => (a.adp || 999) - (b.adp || 999)).slice(0, 100).map(p => (
            <option value={p.name}>{p.name} — {p.position} ({p.team}) — ADP {p.adp?.toFixed(1)}</option>
          ))}
        </select>
        <select id="team-b-player-3" class="w-full rounded-lg bg-zinc-800 border border-zinc-700 px-3 py-2 text-sm text-zinc-100">
          <option value="">Select player (optional)...</option>
          {players.filter(p => p.adp).sort((a, b) => (a.adp || 999) - (b.adp || 999)).slice(0, 100).map(p => (
            <option value={p.name}>{p.name} — {p.position} ({p.team}) — ADP {p.adp?.toFixed(1)}</option>
          ))}
        </select>
      </div>
    </div>

    <button id="analyze-trade-btn" class="w-full rounded-xl bg-gradient-to-r from-purple-500 to-pink-500 px-6 py-3 text-sm font-bold text-white hover:from-purple-600 hover:to-pink-600 transition-all shadow-lg shadow-purple-500/20">
      🤖 Analyze Trade
    </button>

    <!-- Results -->
    <div id="trade-result" class="mt-4 hidden">
      <div class="rounded-xl bg-zinc-800/50 border border-zinc-700 p-4">
        <div id="trade-verdict" class="text-lg font-bold mb-2"></div>
        <div id="trade-analysis" class="text-sm text-zinc-400 space-y-2"></div>
      </div>
    </div>
  </div>

  <!-- How It Works -->
  <div class="grid gap-4 sm:grid-cols-3 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl mb-2">1️⃣</div>
      <h3 class="text-sm font-bold text-zinc-100 mb-1">Select Players</h3>
      <p class="text-xs text-zinc-500">Choose players from your team and their team</p>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl mb-2">2️⃣</div>
      <h3 class="text-sm font-bold text-zinc-100 mb-1">AI Analysis</h3>
      <p class="text-xs text-zinc-500">LLM evaluates ADP, position scarcity, and value</p>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl mb-2">3️⃣</div>
      <h3 class="text-sm font-bold text-zinc-100 mb-1">Get the Verdict</h3>
      <p class="text-xs text-zinc-500">Winner, loser, and why — no more guessing</p>
    </div>
  </div>

  <!-- Player Database by Position -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">📋</div>
      <h2 class="text-lg font-bold text-amber-400">Player Value Chart</h2>
    </div>

    {positions.filter(p => byPosition[p]?.length).map(pos => (
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <div class={`h-6 w-6 rounded flex items-center justify-center text-[10px] font-bold text-white bg-gradient-to-br ${positionColors[pos]}`}>{pos}</div>
          <h3 class="text-sm font-bold text-zinc-200">{pos}s</h3>
          <span class="text-xs text-zinc-600">({byPosition[pos].length} players)</span>
        </div>
        <div class="glass-card-static rounded-xl overflow-x-auto">
          <table class="premium-table">
            <thead>
              <tr>
                <th>Player</th>
                <th class="text-center">Team</th>
                <th class="text-center">Bye</th>
                <th class="text-center">Tier</th>
                <th class="text-right">ADP</th>
                <th class="text-center">Value</th>
              </tr>
            </thead>
            <tbody>
              {byPosition[pos].slice(0, 20).map(p => {
                const nfl = getNFLTeam(p.team);
                const valueScore = p.tier ? Math.max(0, 5 - p.tier) * 20 + (p.adp ? Math.max(0, 200 - p.adp) / 10 : 0) : 0;
                const valueLabel = valueScore >= 80 ? "Elite" : valueScore >= 60 ? "High" : valueScore >= 40 ? "Mid" : valueScore >= 20 ? "Low" : "Depth";
                const valueColor = valueScore >= 80 ? "text-amber-400" : valueScore >= 60 ? "text-emerald-400" : valueScore >= 40 ? "text-blue-400" : valueScore >= 20 ? "text-zinc-400" : "text-zinc-600";
                return (
                  <tr class="hover:bg-zinc-800/30 transition-colors">
                    <td>
                      <div class="flex items-center gap-2.5">
                        {p.espnId > 0 ? (
                          <img src={getEspnHeadshotUrl(p.espnId)} alt={p.name} class="h-8 w-8 rounded-lg object-cover" loading="lazy" onerror="this.style.display='none'" />
                        ) : (
                          <div class="h-8 w-8 rounded-lg bg-zinc-800 flex items-center justify-center text-xs font-bold text-zinc-500">?</div>
                        )}
                        <div>
                          <div class="text-sm font-semibold text-zinc-100">{p.name}</div>
                          <div class="text-[10px] text-zinc-500">{p.position}</div>
                        </div>
                      </div>
                    </td>
                    <td class="text-center">
                      {nfl ? (
                        <span class="text-xs font-mono text-zinc-400">{nfl.shortName}</span>
                      ) : (
                        <span class="text-xs text-zinc-600">{p.team}</span>
                      )}
                    </td>
                    <td class="text-center font-mono text-xs text-zinc-500">{p.byeWeek || "—"}</td>
                    <td class="text-center">
                      {p.tier ? (
                        <span class="inline-flex items-center justify-center h-6 w-6 rounded text-xs font-bold" class:list={[
                          p.tier === 1 ? 'bg-amber-500/20 text-amber-400' :
                          p.tier === 2 ? 'bg-emerald-500/20 text-emerald-400' :
                          p.tier === 3 ? 'bg-blue-500/20 text-blue-400' :
                          'bg-zinc-800 text-zinc-500'
                        ]}>{p.tier}</span>
                      ) : (
                        <span class="text-xs text-zinc-600">—</span>
                      )}
                    </td>
                    <td class="text-right font-mono text-sm text-zinc-300">{p.adp?.toFixed(1) || "—"}</td>
                    <td class="text-center">
                      <span class={`text-xs font-semibold ${valueColor}`}>{valueLabel}</span>
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </div>

  <!-- Trade Tips -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💡</span>
      <h2 class="text-lg font-bold text-zinc-100">Trade Tips</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-amber-400 mb-2">Buy Low Candidates</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Players with tough schedule ahead getting easier</li>
          <li>• Studs coming off injury (buy before they return)</li>
          <li>• Players with bad luck (high air yards, low TDs)</li>
          <li>• Rookies hitting their stride mid-season</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Sell High Candidates</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Players with unsustainable TD rates</li>
          <li>• Aging veterans with hot starts</li>
          <li>• Handcuff RBs after starter gets hurt</li>
          <li>• Players with easy schedule getting harder</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-blue-400 mb-2">Fair Trade Framework</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• 1 elite player ≈ 2 good players</li>
          <li>• RB depth for WR upgrade (positional scarcity)</li>
          <li>• Future picks discount: next year = 80% value</li>
          <li>• Keeper value: young + productive = premium</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-purple-400 mb-2">Avoid These Traps</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• Trading away too much depth for one star</li>
          <li>• Panic selling after 2 bad weeks</li>
          <li>• Accepting first offer without countering</li>
          <li>• Trading future picks for win-now rentals</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>

<script is:inline>
(function() {
  const playerData = JSON.parse(document.getElementById('player-data').textContent);

  function getPlayerValue(name) {
    const p = playerData[name];
    if (!p) return 0;
    const adpScore = Math.max(0, 200 - p.adp) / 2;
    const tierScore = Math.max(0, 5 - p.tier) * 15;
    const scarcityBonus = p.pos === 'RB' ? 10 : p.pos === 'WR' ? 5 : p.pos === 'TE' ? 15 : p.pos === 'QB' ? 3 : 0;
    return adpScore + tierScore + scarcityBonus;
  }

  function getValueLabel(score) {
    if (score >= 80) return { label: 'Elite', color: 'text-amber-400' };
    if (score >= 60) return { label: 'High', color: 'text-emerald-400' };
    if (score >= 40) return { label: 'Mid', color: 'text-blue-400' };
    if (score >= 20) return { label: 'Low', color: 'text-zinc-400' };
    return { label: 'Depth', color: 'text-zinc-600' };
  }

  function getSelectedPlayers() {
    return {
      teamA: [
        document.getElementById('team-a-player-1').value,
        document.getElementById('team-a-player-2').value,
        document.getElementById('team-a-player-3').value
      ].filter(Boolean),
      teamB: [
        document.getElementById('team-b-player-1').value,
        document.getElementById('team-b-player-2').value,
        document.getElementById('team-b-player-3').value
      ].filter(Boolean)
    };
  }

  function analyzeTrade() {
    const { teamA, teamB } = getSelectedPlayers();
    const result = document.getElementById('trade-result');
    const verdict = document.getElementById('trade-verdict');
    const analysis = document.getElementById('trade-analysis');

    if (teamA.length === 0 || teamB.length === 0) {
      alert('Select at least one player per side.');
      return;
    }

    const scoreA = teamA.reduce(function(sum, name) { return sum + getPlayerValue(name); }, 0);
    const scoreB = teamB.reduce(function(sum, name) { return sum + getPlayerValue(name); }, 0);
    const diff = scoreA - scoreB;
    const pctDiff = Math.abs(diff) / Math.max(scoreA, scoreB, 1) * 100;

    var verdictText, winner, loser, details;

    if (Math.abs(diff) < 5 || pctDiff < 10) {
      verdictText = '\u{1F91D} Fair Trade';
      winner = 'Neither \u2014 this is a balanced deal';
      details = 'Both sides get comparable value. Team A: ' + scoreA.toFixed(0) + ' pts, Team B: ' + scoreB.toFixed(0) + ' pts. Difference is only ' + Math.abs(diff).toFixed(0) + ' points (' + pctDiff.toFixed(0) + '%).';
    } else if (diff > 0) {
      verdictText = '\u2705 Team A Wins';
      winner = 'Team A';
      loser = 'Team B';
      details = 'Team A gets ' + scoreA.toFixed(0) + ' pts of value vs Team B\'s ' + scoreB.toFixed(0) + ' pts. That\'s a ' + diff.toFixed(0) + '-point advantage (' + pctDiff.toFixed(0) + '% more value).';
    } else {
      verdictText = '\u2705 Team B Wins';
      winner = 'Team B';
      loser = 'Team A';
      details = 'Team B gets ' + scoreB.toFixed(0) + ' pts of value vs Team A\'s ' + scoreA.toFixed(0) + ' pts. That\'s a ' + Math.abs(diff).toFixed(0) + '-point advantage (' + pctDiff.toFixed(0) + '% more value).';
    }

    var aDetails = teamA.map(function(n) {
      var p = playerData[n];
      var v = getPlayerValue(n);
      var vl = getValueLabel(v);
      return '<div class="flex justify-between text-xs"><span>' + n + ' (' + (p ? p.pos : '?') + ')</span><span class="' + vl.color + '">' + v.toFixed(0) + ' pts \u2014 ' + vl.label + '</span></div>';
    }).join('');

    var bDetails = teamB.map(function(n) {
      var p = playerData[n];
      var v = getPlayerValue(n);
      var vl = getValueLabel(v);
      return '<div class="flex justify-between text-xs"><span>' + n + ' (' + (p ? p.pos : '?') + ')</span><span class="' + vl.color + '">' + v.toFixed(0) + ' pts \u2014 ' + vl.label + '</span></div>';
    }).join('');

    verdict.innerHTML = verdictText + ' <span class="text-sm font-normal text-zinc-400">\u2014 ' + winner + (loser ? ' over ' + loser : '') + '</span>';
    analysis.innerHTML = '<p class="text-zinc-300">' + details + '</p><div class="mt-3 grid gap-3 sm:grid-cols-2"><div class="bg-zinc-900/50 rounded-lg p-3"><div class="text-xs font-semibold text-amber-400 mb-2">Team A Sends</div>' + aDetails + '<div class="mt-2 pt-2 border-t border-zinc-700 flex justify-between text-xs font-bold text-amber-400"><span>Total</span><span>' + scoreA.toFixed(0) + ' pts</span></div></div><div class="bg-zinc-900/50 rounded-lg p-3"><div class="text-xs font-semibold text-blue-400 mb-2">Team B Sends</div>' + bDetails + '<div class="mt-2 pt-2 border-t border-zinc-700 flex justify-between text-xs font-bold text-blue-400"><span>Total</span><span>' + scoreB.toFixed(0) + ' pts</span></div></div></div>';

    result.classList.remove('hidden');
  }

  document.addEventListener('DOMContentLoaded', function() {
    document.getElementById('analyze-trade-btn').addEventListener('click', analyzeTrade);
  });
})();
</script>
