---
import Layout from "../layouts/Layout.astro";
import { fetchAllPlayers, LEAGUE_CONFIG } from "../data/sleeper-api";
import { getEspnHeadshotUrl } from "../data/players";
import { getNFLTeam } from "../data/nfl-teams";
import { scoringSummary } from "../data/scoring";

const allPlayers = await fetchAllPlayers();

// Filter IDP players (DL, LB, DB)
const idpPlayers = Object.values(allPlayers).filter(p => {
  const pos = p.position || "";
  return ["DL", "LB", "DB", "DE", "DT", "S", "CB", "OLB", "ILB", "NT"].includes(pos);
});

// Group by position
const byPosition: Record<string, any[]> = {};
for (const p of idpPlayers) {
  const pos = p.position || "Unknown";
  if (!byPosition[pos]) byPosition[pos] = [];
  byPosition[pos].push(p);
}

// Sort each position
for (const pos of Object.keys(byPosition)) {
  byPosition[pos].sort((a, b) => {
    const aAge = a.age || 99;
    const bAge = b.age || 99;
    return aAge - bAge;
  });
}

const positionOrder = ["DE", "DT", "NT", "DL", "LB", "OLB", "ILB", "CB", "S", "DB"];
const positionNames: Record<string, string> = {
  DE: "Defensive Ends",
  DT: "Defensive Tackles",
  NT: "Nose Tackles",
  DL: "Defensive Linemen",
  LB: "Linebackers",
  OLB: "Outside Linebackers",
  ILB: "Inside Linebackers",
  CB: "Cornerbacks",
  S: "Safeties",
  DB: "Defensive Backs",
};
const positionEmojis: Record<string, string> = {
  DE: "💪", DT: "🏋️", NT: "🦍", DL: "💪",
  LB: "🛡️", OLB: "🛡️", ILB: "🛡️",
  CB: "⚡", S: "🎯", DB: "⚡",
};
const positionColors: Record<string, string> = {
  DE: "from-zinc-600 to-zinc-700",
  DT: "from-zinc-700 to-zinc-800",
  NT: "from-zinc-800 to-zinc-900",
  DL: "from-zinc-600 to-zinc-700",
  LB: "from-zinc-500 to-zinc-600",
  OLB: "from-zinc-500 to-zinc-600",
  ILB: "from-zinc-500 to-zinc-600",
  CB: "from-zinc-400 to-zinc-500",
  S: "from-zinc-400 to-zinc-500",
  DB: "from-zinc-400 to-zinc-500",
};
---

<Layout title="IDP">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🛡️</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">IDP</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · Individual Defensive Players · {idpPlayers.length} players</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- IDP Scoring Summary -->
  <div class="glass-card-accent rounded-xl p-5 mb-8">
    <div class="flex items-center gap-2 mb-3">
      <span class="text-lg">⚡</span>
      <h2 class="text-sm font-bold text-amber-400 uppercase tracking-wider">IDP Scoring</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-3 lg:grid-cols-6">
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-emerald-400">{scoringSummary.tackleSolo}</div>
        <div class="text-[10px] text-zinc-500">Solo Tackle</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-zinc-300">{scoringSummary.tackleAssist}</div>
        <div class="text-[10px] text-zinc-500">Assisted Tackle</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-emerald-400">{scoringSummary.sackDef}</div>
        <div class="text-[10px] text-zinc-500">Sack</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-emerald-400">{scoringSummary.interceptionDef}</div>
        <div class="text-[10px] text-zinc-500">Interception</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-zinc-300">{scoringSummary.passDefended}</div>
        <div class="text-[10px] text-zinc-500">Pass Defended</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-lg font-bold text-zinc-300">{scoringSummary.tfl}</div>
        <div class="text-[10px] text-zinc-500">Tackle for Loss</div>
      </div>
    </div>
  </div>

  <!-- IDP Strategy -->
  <div class="grid gap-4 sm:grid-cols-3 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5">
      <div class="text-2xl mb-2">💪</div>
      <h3 class="text-sm font-bold text-zinc-100 mb-1">DL Strategy</h3>
      <p class="text-xs text-zinc-500">Target edge rushers with high sack potential. 3 pts per sack with 1.5 per solo tackle makes elite pass rushers as valuable as mid-tier WRs.</p>
      <div class="mt-3 text-xs text-zinc-600">Key stat: <span class="text-amber-400">Sacks + TFLs</span></div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="text-2xl mb-2">🛡️</div>
      <h3 class="text-sm font-bold text-zinc-100 mb-1">LB Strategy</h3>
      <p class="text-xs text-zinc-500">Three-down LBs are gold. Solo tackles (1.5) + assists (0.5) + pass defensed (1) = consistent weekly floor. Target high-tackle volume LBs.</p>
      <div class="mt-3 text-xs text-zinc-600">Key stat: <span class="text-amber-400">Tackles + Pass Defensed</span></div>
    </div>
    <div class="glass-card rounded-xl p-5">
      <div class="text-2xl mb-2">⚡</div>
      <h3 class="text-sm font-bold text-zinc-100 mb-1">DB Strategy</h3>
      <p class="text-xs text-zinc-500">Safeties over corners for IDP. Safeties get more tackle opportunities. Target box safeties and slot corners who play close to the line.</p>
      <div class="mt-3 text-xs text-zinc-600">Key stat: <span class="text-amber-400">Tackles + INTs</span></div>
    </div>
  </div>

  <!-- IDP Player Database -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">📋</div>
      <h2 class="text-lg font-bold text-amber-400">IDP Player Database</h2>
      <span class="text-xs text-zinc-600">({idpPlayers.length} players)</span>
    </div>

    {positionOrder.filter(pos => byPosition[pos]?.length).map(pos => (
      <div class="mb-6">
        <div class="flex items-center gap-2 mb-3">
          <div class={`h-6 w-6 rounded flex items-center justify-center text-[10px] font-bold text-white bg-gradient-to-br ${positionColors[pos]}`}>{positionEmojis[pos]}</div>
          <h3 class="text-sm font-bold text-zinc-200">{positionNames[pos] || pos + "s"}</h3>
          <span class="text-xs text-zinc-600">({byPosition[pos].length})</span>
        </div>
        <div class="glass-card-static rounded-xl overflow-x-auto">
          <table class="premium-table">
            <thead>
              <tr>
                <th>Player</th>
                <th class="text-center">Pos</th>
                <th class="text-center">Team</th>
                <th class="text-center">Age</th>
                <th class="text-center">Number</th>
                <th class="text-center">Depth</th>
              </tr>
            </thead>
            <tbody>
              {byPosition[pos].slice(0, 30).map(p => {
                const espnId = p.espn_id || 0;
                const nfl = p.team ? getNFLTeam(p.team) : null;
                const depth = p.depth_chart_position || "";
                return (
                  <tr class="hover:bg-zinc-800/30 transition-colors">
                    <td>
                      <div class="flex items-center gap-2.5">
                        {espnId > 0 ? (
                          <img src={getEspnHeadshotUrl(espnId)} alt={p.full_name} class="h-8 w-8 rounded-lg object-cover" loading="lazy" onerror="this.style.display='none'" />
                        ) : (
                          <div class="h-8 w-8 rounded-lg bg-zinc-800 flex items-center justify-center text-xs font-bold text-zinc-500">?</div>
                        )}
                        <div>
                          <div class="text-sm font-semibold text-zinc-100">{p.full_name}</div>
                          <div class="text-[10px] text-zinc-500">{nfl?.name || p.team || "FA"}</div>
                        </div>
                      </div>
                    </td>
                    <td class="text-center">
                      <span class={`inline-flex items-center justify-center h-6 w-8 rounded text-[10px] font-bold text-white bg-gradient-to-br ${positionColors[p.position] || 'from-zinc-600 to-zinc-700'}`}>
                        {p.position}
                      </span>
                    </td>
                    <td class="text-center">
                      <span class="text-xs font-mono text-zinc-400">{p.team || "FA"}</span>
                    </td>
                    <td class="text-center font-mono text-xs text-zinc-500">{p.age || "—"}</td>
                    <td class="text-center font-mono text-xs text-zinc-500">{p.number || "—"}</td>
                    <td class="text-center">
                      {depth ? (
                        <span class="text-xs font-mono text-zinc-400">{depth}</span>
                      ) : (
                        <span class="text-xs text-zinc-600">—</span>
                      )}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
      </div>
    ))}
  </div>

  <!-- IDP vs Offense Value Comparison -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">⚖️</span>
      <h2 class="text-lg font-bold text-zinc-100">IDP Value in This League</h2>
    </div>
    <div class="grid gap-4 sm:grid-cols-2">
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-emerald-400 mb-2">Why IDP Matters Here</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• <strong class="text-zinc-200">1.5 pts per solo tackle</strong> — 50% more than Yahoo default</li>
          <li>• <strong class="text-zinc-200">3 pts per sack</strong> — 50% more than Yahoo default</li>
          <li>• <strong class="text-zinc-200">1 pt per pass defensed</strong> — Yahoo default is 0</li>
          <li>• <strong class="text-zinc-200">0.5 pts per TFL</strong> — Yahoo default is 0</li>
          <li>• Elite LBs can outscore mid-tier RBs weekly</li>
        </ul>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-4">
        <h3 class="text-sm font-bold text-amber-400 mb-2">Draft Strategy</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• <strong class="text-zinc-200">Don't ignore IDP</strong> — 4+ IDP starters in lineup</li>
          <li>• <strong class="text-zinc-200">LB > DL > DB</strong> — LBs have highest floor</li>
          <li>• <strong class="text-zinc-200">Target 3-down LBs</strong> — They never leave the field</li>
          <li>• <strong class="text-zinc-200">Edge rushers in DL slots</strong> — Sack upside is real</li>
          <li>• <strong class="text-zinc-200">Box safeties over corners</strong> — More tackle opportunities</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
