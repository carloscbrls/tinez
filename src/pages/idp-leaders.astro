---
import Layout from "../layouts/Layout.astro";
import { fetchPlayers } from "../data/sleeper";
import { getEspnHeadshotUrl } from "../data/players";
import { getNFLTeam } from "../data/nfl-teams";
import { generateIdpProjections, getIdpRankings, getTopIdpByGroup, getIdpSleepers, getIdpPositionGroup } from "../data/idp-projections";

const projections = await generateIdpProjections();
const { overall, byPosition } = await getIdpRankings();
const topDL = await getTopIdpByGroup("DL", 25);
const topLB = await getTopIdpByGroup("LB", 25);
const topDB = await getTopIdpByGroup("DB", 25);
const sleepers = await getIdpSleepers(10);

// Top 50 overall
const top50 = overall.slice(0, 50);

// Position group stats
const groupStats = {
  DL: { count: projections.filter(p => getIdpPositionGroup(p.position) === "DL").length, avg: 0 },
  LB: { count: projections.filter(p => getIdpPositionGroup(p.position) === "LB").length, avg: 0 },
  DB: { count: projections.filter(p => getIdpPositionGroup(p.position) === "DB").length, avg: 0 },
};

for (const group of ["DL", "LB", "DB"] as const) {
  const players = projections.filter(p => getIdpPositionGroup(p.position) === group);
  groupStats[group].avg = players.length > 0
    ? Math.round(players.reduce((s, p) => s + p.weeklyProjected, 0) / players.length * 10) / 10
    : 0;
}

const tierColors: Record<string, string> = {
  elite: "text-amber-400",
  starter: "text-emerald-400",
  rotational: "text-blue-400",
  depth: "text-zinc-500",
  rookie: "text-purple-400",
};

const tierLabels: Record<string, string> = {
  elite: "Elite",
  starter: "Starter",
  rotational: "Rotational",
  depth: "Depth",
  rookie: "Rookie",
};

const groupEmojis: Record<string, string> = { DL: "💪", LB: "🛡️", DB: "⚡" };
const groupNames: Record<string, string> = { DL: "Defensive Line", LB: "Linebackers", DB: "Defensive Backs" };
---

<Layout title="IDP Leaders | Tinez Fantasy Football">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">🛡️</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">IDP Leaders</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · {projections.length} IDP players with projected stats</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Overview Stats -->
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    {(["DL", "LB", "DB"] as const).map((group) => (
      <div class="glass-card rounded-xl p-5">
        <div class="flex items-center gap-3 mb-3">
          <span class="text-2xl">{groupEmojis[group]}</span>
          <div>
            <h3 class="text-sm font-bold text-white">{groupNames[group]}</h3>
            <p class="text-[10px] text-zinc-500">{groupStats[group].count} players</p>
          </div>
        </div>
        <div class="flex items-baseline gap-1">
          <span class="text-2xl font-bold text-amber-400">{groupStats[group].avg}</span>
          <span class="text-xs text-zinc-600">avg weekly projection</span>
        </div>
        <div class="mt-2">
          <span class="text-[10px] text-zinc-600">Top: </span>
          <span class="text-xs text-zinc-300">
            {group === "DL" ? topDL[0]?.player.name : group === "LB" ? topLB[0]?.player.name : topDB[0]?.player.name}
          </span>
          <span class="text-[10px] text-amber-400 ml-1">
            ({group === "DL" ? topDL[0]?.player.weeklyProjected : group === "LB" ? topLB[0]?.player.weeklyProjected : topDB[0]?.player.weeklyProjected})
          </span>
        </div>
      </div>
    ))}
  </div>

  <!-- Top 50 Overall -->
  <div class="glass-card rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
      <span>🏆</span> Top 50 IDP Players
    </h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="text-zinc-500 text-[10px] uppercase tracking-wider border-b border-zinc-800">
            <th class="text-left py-2 pr-2">Rank</th>
            <th class="text-left py-2 pr-2">Player</th>
            <th class="text-center py-2 pr-2">Pos</th>
            <th class="text-center py-2 pr-2">Team</th>
            <th class="text-center py-2 pr-2">Age</th>
            <th class="text-center py-2 pr-2">Exp</th>
            <th class="text-center py-2 pr-2">Tier</th>
            <th class="text-center py-2 pr-2">Src</th>
            <th class="text-center py-2 pr-2">Tkl</th>
            <th class="text-center py-2 pr-2">Sack</th>
            <th class="text-center py-2 pr-2">INT</th>
            <th class="text-center py-2 pr-2">FF</th>
            <th class="text-center py-2 pr-2">PD</th>
            <th class="text-right py-2 pl-2 text-amber-400">Wkly</th>
            <th class="text-right py-2 pl-2 text-zinc-500">Season</th>
          </tr>
        </thead>
        <tbody>
          {top50.map((r) => (
            <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/30 transition-colors">
              <td class="py-2 pr-2 text-zinc-500 text-xs">{r.overallRank}</td>
              <td class="py-2 pr-2">
                <div class="flex items-center gap-2">
                  <img src={getEspnHeadshotUrl(r.player.playerId)} alt="" class="w-6 h-6 rounded-full bg-zinc-800 object-cover" loading="lazy" onerror="this.style.display='none'" />
                  <span class="text-zinc-200 font-medium text-xs truncate max-w-[140px]">{r.player.name}</span>
                </div>
              </td>
              <td class="py-2 pr-2 text-center">
                <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-zinc-800 text-zinc-400">{r.player.position}</span>
              </td>
              <td class="py-2 pr-2 text-center text-zinc-500 text-xs">{r.player.team}</td>
              <td class="py-2 pr-2 text-center text-zinc-500 text-xs">{r.player.age}</td>
              <td class="py-2 pr-2 text-center text-zinc-500 text-xs">{r.player.yearsExp}</td>
              <td class="py-2 pr-2 text-center">
                <span class={`text-[10px] ${tierColors[r.player.tier]}`}>{tierLabels[r.player.tier]}</span>
              </td>
              <td class="py-2 pr-2 text-center">
                {r.player.source === "fantasynerds" || r.player.source === "merged" ? (
                  <span class="text-[9px] text-amber-500 font-mono" title="FantasyNerds expert projection">FN</span>
                ) : (
                  <span class="text-[9px] text-zinc-600 font-mono" title="TINEZ statistical model">TZ</span>
                )}
              </td>
              <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.tackles}</td>
              <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.sacks}</td>
              <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.interceptions}</td>
              <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.forcedFumbles}</td>
              <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.passDefended}</td>
              <td class="py-2 pl-2 text-right font-bold text-amber-400 text-xs">{r.player.weeklyProjected}</td>
              <td class="py-2 pl-2 text-right text-zinc-500 text-xs">{r.player.projectedPoints}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Position-Specific Rankings -->
  {(["DL", "LB", "DB"] as const).map((group) => {
    const rankings = group === "DL" ? topDL : group === "LB" ? topLB : topDB;
    if (rankings.length === 0) return null;
    return (
      <div class="glass-card rounded-xl p-6 mb-6">
        <h2 class="text-lg font-bold text-white mb-1 flex items-center gap-2">
          <span>{groupEmojis[group]}</span> Top {groupNames[group]}
        </h2>
        <p class="text-xs text-zinc-500 mb-4">Ranked by projected weekly points</p>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="text-zinc-500 text-[10px] uppercase tracking-wider border-b border-zinc-800">
                <th class="text-left py-2 pr-2">#</th>
                <th class="text-left py-2 pr-2">Player</th>
                <th class="text-center py-2 pr-2">Pos</th>
                <th class="text-center py-2 pr-2">Team</th>
                <th class="text-center py-2 pr-2">Age</th>
                <th class="text-center py-2 pr-2">Tier</th>
                <th class="text-center py-2 pr-2">Tkl</th>
                <th class="text-center py-2 pr-2">Sack</th>
                <th class="text-center py-2 pr-2">INT</th>
                <th class="text-center py-2 pr-2">PD</th>
                <th class="text-right py-2 pl-2 text-amber-400">Wkly</th>
              </tr>
            </thead>
            <tbody>
              {rankings.map((r) => (
                <tr class="border-b border-zinc-800/50 hover:bg-zinc-800/30 transition-colors">
                  <td class="py-2 pr-2 text-zinc-500 text-xs">{r.positionRank}</td>
                  <td class="py-2 pr-2">
                    <div class="flex items-center gap-2">
                      <img src={getEspnHeadshotUrl(r.player.playerId)} alt="" class="w-6 h-6 rounded-full bg-zinc-800 object-cover" loading="lazy" onerror="this.style.display='none'" />
                      <span class="text-zinc-200 font-medium text-xs truncate max-w-[140px]">{r.player.name}</span>
                    </div>
                  </td>
                  <td class="py-2 pr-2 text-center">
                    <span class="text-[10px] font-mono px-1.5 py-0.5 rounded bg-zinc-800 text-zinc-400">{r.player.position}</span>
                  </td>
                  <td class="py-2 pr-2 text-center text-zinc-500 text-xs">{r.player.team}</td>
                  <td class="py-2 pr-2 text-center text-zinc-500 text-xs">{r.player.age}</td>
                  <td class="py-2 pr-2 text-center">
                    <span class={`text-[10px] ${tierColors[r.player.tier]}`}>{tierLabels[r.player.tier]}</span>
                  </td>
                  <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.tackles}</td>
                  <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.sacks}</td>
                  <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.interceptions}</td>
                  <td class="py-2 pr-2 text-center text-zinc-300 text-xs">{r.player.projectedStats.passDefended}</td>
                  <td class="py-2 pl-2 text-right font-bold text-amber-400 text-xs">{r.player.weeklyProjected}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    );
  })}

  <!-- Sleepers -->
  {sleepers.length > 0 && (
    <div class="glass-card-accent rounded-xl p-6 mb-8 border-amber-500/20">
      <h2 class="text-lg font-bold text-amber-400 mb-4 flex items-center gap-2">
        <span>🔮</span> IDP Sleepers — Late-Round Targets
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {sleepers.map((p) => (
          <div class="bg-zinc-800/50 rounded-lg p-3 flex items-center gap-3">
            <img src={getEspnHeadshotUrl(p.playerId)} alt="" class="w-8 h-8 rounded-full bg-zinc-700 object-cover" loading="lazy" onerror="this.style.display='none'" />
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-zinc-200 truncate">{p.name}</div>
              <div class="text-[10px] text-zinc-500">{p.team} · {p.position} · Age {p.age} · {p.yearsExp}yr</div>
            </div>
            <div class="text-right">
              <div class="text-sm font-bold text-amber-400">{p.weeklyProjected}</div>
              <div class="text-[9px] text-zinc-600">wkly proj</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  )}

  <!-- Draft Strategy -->
  <div class="glass-card rounded-xl p-6 mb-8">
    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2">
      <span>📖</span> IDP Draft Guide
    </h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div class="bg-zinc-800/50 rounded-lg p-4">
        <h3 class="text-sm font-bold text-white mb-2">When to Draft IDP</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• <strong class="text-zinc-300">Rounds 8-10:</strong> Elite LBs (top 5-7)</li>
          <li>• <strong class="text-zinc-300">Rounds 10-12:</strong> Elite DEs, top Safeties</li>
          <li>• <strong class="text-zinc-300">Rounds 12-14:</strong> Starting LBs, top CBs</li>
          <li>• <strong class="text-zinc-300">Rounds 14+:</strong> Rotational players, sleepers</li>
        </ul>
      </div>
      <div class="bg-zinc-800/50 rounded-lg p-4">
        <h3 class="text-sm font-bold text-white mb-2">Positional Scarcity</h3>
        <ul class="space-y-1.5 text-xs text-zinc-400">
          <li>• <strong class="text-zinc-300">LB:</strong> Deepest position — 20+ startable options</li>
          <li>• <strong class="text-zinc-300">DE:</strong> Top-heavy — big drop after elite tier</li>
          <li>• <strong class="text-zinc-300">S:</strong> Moderate depth — target box safeties</li>
          <li>• <strong class="text-zinc-300">CB:</strong> Streamable — don't invest early</li>
        </ul>
      </div>
    </div>
  </div>
</Layout>
