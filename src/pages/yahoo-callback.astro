---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Connecting Yahoo... | Tinez Fantasy Football">
  <main class="min-h-screen bg-gradient-to-b from-zinc-950 via-zinc-900 to-zinc-950 flex items-center justify-center">
    <div class="text-center p-8">
      <div class="animate-spin h-10 w-10 border-4 border-purple-500 border-t-transparent rounded-full mx-auto mb-4"></div>
      <h1 class="text-xl font-bold text-white mb-2">Connecting Yahoo...</h1>
      <p class="text-zinc-400 text-sm">Exchanging authorization code for access token...</p>
    </div>
  </main>
</Layout>

<script>
  // Get the authorization code from the URL
  const urlParams = new URLSearchParams(window.location.search);
  const code = urlParams.get("code");

  if (code) {
    // Redirect to our API to exchange the code
    window.location.href = "/api/yahoo/callback?code=" + encodeURIComponent(code);
  } else {
    // No code found — show error
    document.querySelector("main").innerHTML = `
      <div class="text-center p-8">
        <div class="text-4xl mb-4">❌</div>
        <h1 class="text-xl font-bold text-white mb-2">Connection Failed</h1>
        <p class="text-zinc-400 text-sm mb-4">No authorization code received from Yahoo.</p>
        <a href="/connect-yahoo" class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-gradient-to-r from-purple-600 to-pink-600 text-white font-semibold text-sm">Try Again</a>
      </div>
    `;
  }
</script>
