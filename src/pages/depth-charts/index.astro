---
import Layout from "../../layouts/Layout.astro";

const NFL_TEAMS = [
  { id: 1, abbr: "ATL", name: "Atlanta Falcons", city: "Atlanta", conf: "NFC", div: "South", color: "#A71930" },
  { id: 2, abbr: "BUF", name: "Buffalo Bills", city: "Buffalo", conf: "AFC", div: "East", color: "#00338D" },
  { id: 3, abbr: "CHI", name: "Chicago Bears", city: "Chicago", conf: "NFC", div: "North", color: "#0B162A" },
  { id: 4, abbr: "CIN", name: "Cincinnati Bengals", city: "Cincinnati", conf: "AFC", div: "North", color: "#FB4F14" },
  { id: 5, abbr: "CLE", name: "Cleveland Browns", city: "Cleveland", conf: "AFC", div: "North", color: "#311D00" },
  { id: 6, abbr: "DAL", name: "Dallas Cowboys", city: "Dallas", conf: "NFC", div: "East", color: "#003594" },
  { id: 7, abbr: "DEN", name: "Denver Broncos", city: "Denver", conf: "AFC", div: "West", color: "#FB4F14" },
  { id: 8, abbr: "DET", name: "Detroit Lions", city: "Detroit", conf: "NFC", div: "North", color: "#0076B6" },
  { id: 9, abbr: "GB", name: "Green Bay Packers", city: "Green Bay", conf: "NFC", div: "North", color: "#203731" },
  { id: 10, abbr: "TEN", name: "Tennessee Titans", city: "Nashville", conf: "AFC", div: "South", color: "#0C2340" },
  { id: 11, abbr: "IND", name: "Indianapolis Colts", city: "Indianapolis", conf: "AFC", div: "South", color: "#002C5F" },
  { id: 12, abbr: "KC", name: "Kansas City Chiefs", city: "Kansas City", conf: "AFC", div: "West", color: "#E31837" },
  { id: 13, abbr: "LV", name: "Las Vegas Raiders", city: "Las Vegas", conf: "AFC", div: "West", color: "#000000" },
  { id: 14, abbr: "LAC", name: "Los Angeles Chargers", city: "Los Angeles", conf: "AFC", div: "West", color: "#0080C6" },
  { id: 15, abbr: "LAR", name: "Los Angeles Rams", city: "Los Angeles", conf: "NFC", div: "West", color: "#003594" },
  { id: 16, abbr: "MIA", name: "Miami Dolphins", city: "Miami", conf: "AFC", div: "East", color: "#008E97" },
  { id: 17, abbr: "MIN", name: "Minnesota Vikings", city: "Minneapolis", conf: "NFC", div: "North", color: "#4F2683" },
  { id: 18, abbr: "NE", name: "New England Patriots", city: "Foxborough", conf: "AFC", div: "East", color: "#002244" },
  { id: 19, abbr: "NO", name: "New Orleans Saints", city: "New Orleans", conf: "NFC", div: "South", color: "#D3BC8D" },
  { id: 20, abbr: "NYG", name: "New York Giants", city: "East Rutherford", conf: "NFC", div: "East", color: "#0B2265" },
  { id: 21, abbr: "NYJ", name: "New York Jets", city: "East Rutherford", conf: "AFC", div: "East", color: "#125740" },
  { id: 22, abbr: "PHI", name: "Philadelphia Eagles", city: "Philadelphia", conf: "NFC", div: "East", color: "#004C54" },
  { id: 23, abbr: "ARI", name: "Arizona Cardinals", city: "Glendale", conf: "NFC", div: "West", color: "#97233F" },
  { id: 24, abbr: "PIT", name: "Pittsburgh Steelers", city: "Pittsburgh", conf: "AFC", div: "North", color: "#FFB612" },
  { id: 25, abbr: "LAC", name: "Los Angeles Chargers", city: "Los Angeles", conf: "AFC", div: "West", color: "#0080C6" },
  { id: 26, abbr: "SF", name: "San Francisco 49ers", city: "Santa Clara", conf: "NFC", div: "West", color: "#AA0000" },
  { id: 27, abbr: "SEA", name: "Seattle Seahawks", city: "Seattle", conf: "NFC", div: "West", color: "#002244" },
  { id: 28, abbr: "TB", name: "Tampa Bay Buccaneers", city: "Tampa", conf: "NFC", div: "South", color: "#D50A0A" },
  { id: 29, abbr: "WAS", name: "Washington Commanders", city: "Landover", conf: "NFC", div: "East", color: "#5A1414" },
  { id: 30, abbr: "BAL", name: "Baltimore Ravens", city: "Baltimore", conf: "AFC", div: "North", color: "#241773" },
  { id: 31, abbr: "HOU", name: "Houston Texans", city: "Houston", conf: "AFC", div: "South", color: "#03202F" },
  { id: 32, abbr: "JAX", name: "Jacksonville Jaguars", city: "Jacksonville", conf: "AFC", div: "South", color: "#006778" },
  { id: 33, abbr: "CAR", name: "Carolina Panthers", city: "Charlotte", conf: "NFC", div: "South", color: "#0085CA" },
];

const nflTeamLogo = (abbr: string) =>
  `https://a.espncdn.com/combiner/i?img=/i/teamlogos/nfl/500/${abbr.toLowerCase()}.png`;

const positions = ["QB", "RB", "WR", "TE"];
const posIcons: Record<string, string> = { QB: "🎯", RB: "💨", WR: "🔥", TE: "🛡️" };
const posColors: Record<string, string> = {
  QB: "from-blue-500/20 to-blue-600/10 text-blue-400 border-blue-500/20",
  RB: "from-emerald-500/20 to-emerald-600/10 text-emerald-400 border-emerald-500/20",
  WR: "from-amber-500/20 to-amber-600/10 text-amber-400 border-amber-500/20",
  TE: "from-purple-500/20 to-purple-600/10 text-purple-400 border-purple-500/20",
};

// Deduplicate teams by abbr
const uniqueTeams = NFL_TEAMS.filter((t, i, a) => a.findIndex(x => x.abbr === t.abbr) === i);
const afcTeams = uniqueTeams.filter(t => t.conf === "AFC").sort((a, b) => a.name.localeCompare(b.name));
const nfcTeams = uniqueTeams.filter(t => t.conf === "NFC").sort((a, b) => a.name.localeCompare(b.name));
---

<Layout title="Depth Charts">
  <!-- Hero -->
  <div class="mb-10">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20 bg-gradient-to-br from-zinc-900 via-zinc-950 to-black">
      <div class="absolute inset-0 bg-[radial-gradient(ellipse_at_top_right,_var(--tw-gradient-stops))] from-amber-500/5 via-transparent to-transparent"></div>
      <div class="relative z-10 p-6 md:p-10">
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
          <div class="flex h-14 w-14 shrink-0 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-400 to-orange-500 text-2xl shadow-lg shadow-amber-500/20">📋</div>
          <div class="flex-1 min-w-0">
            <h1 class="text-2xl md:text-4xl font-extrabold tracking-tight mb-1">
              <span class="bg-gradient-to-r from-amber-200 via-amber-400 to-orange-400 bg-clip-text text-transparent">NFL Depth Charts</span>
            </h1>
            <p class="text-zinc-400 text-sm md:text-base">All 32 teams · <span class="text-zinc-300 font-semibold">{uniqueTeams.length}</span> projected starters · 2026 season</p>
          </div>
          <div class="flex items-center gap-3 shrink-0">
            <div class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-blue-400"></span>
              <span class="text-[10px] text-zinc-500 font-semibold">AFC</span>
            </div>
            <div class="flex items-center gap-1.5">
              <span class="h-2 w-2 rounded-full bg-amber-400"></span>
              <span class="text-[10px] text-zinc-500 font-semibold">NFC</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Conference Tabs -->
  <div class="flex gap-2 mb-6 border-b border-zinc-800/40 pb-4">
    <button class="conference-tab active px-4 py-2 rounded-lg text-xs font-semibold bg-amber-500/10 text-amber-400 border border-amber-500/20" data-conf="all">All Teams</button>
    <button class="conference-tab px-4 py-2 rounded-lg text-xs font-semibold text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800/30 border border-transparent" data-conf="afc">AFC</button>
    <button class="conference-tab px-4 py-2 rounded-lg text-xs font-semibold text-zinc-500 hover:text-zinc-300 hover:bg-zinc-800/30 border border-transparent" data-conf="nfc">NFC</button>
  </div>

  <!-- AFC Section -->
  <div class="mb-8 conf-section" data-conf="afc">
    <div class="flex items-center gap-2 mb-4">
      <span class="h-3 w-3 rounded-full bg-blue-400"></span>
      <h2 class="text-sm font-bold text-zinc-200 uppercase tracking-wider">American Football Conference</h2>
      <span class="text-[10px] text-zinc-600">({afcTeams.length} teams)</span>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {afcTeams.map(team => (
        <div class="team-card rounded-xl border border-zinc-800/40 bg-zinc-900/40 backdrop-blur-sm overflow-hidden hover:border-zinc-700/60 transition-all duration-300">
          <div class="h-1" style={`background: linear-gradient(90deg, ${team.color}, ${team.color}88)`}></div>
          <div class="p-4">
            <div class="flex items-center gap-3 mb-4">
              <img src={nflTeamLogo(team.abbr)} alt={team.name} class="h-10 w-10 object-contain" loading="lazy" onerror="this.style.display='none'" />
              <div class="min-w-0">
                <h3 class="text-sm font-bold text-zinc-100 truncate">{team.name}</h3>
                <p class="text-[10px] text-zinc-600">{team.city} · {team.div}</p>
              </div>
            </div>
            <div class="space-y-2">
              {positions.map(pos => (
                <div class={`rounded-lg border p-2.5 ${posColors[pos]}`}>
                  <div class="flex items-center justify-between mb-1">
                    <div class="flex items-center gap-1.5">
                      <span class="text-[10px]">{posIcons[pos]}</span>
                      <span class="text-[10px] font-bold uppercase tracking-wider">{pos}</span>
                    </div>
                    <span class="text-[9px] opacity-60">Starter</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="h-6 w-6 rounded bg-zinc-800/60 flex items-center justify-center text-[9px] text-zinc-500 font-mono">1</div>
                    <span class="text-xs text-zinc-400">TBD</span>
                  </div>
                  <div class="flex items-center gap-2 mt-1 opacity-50">
                    <div class="h-5 w-5 rounded bg-zinc-800/40 flex items-center justify-center text-[8px] text-zinc-600 font-mono">2</div>
                    <span class="text-[10px] text-zinc-600">TBD</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- NFC Section -->
  <div class="mb-8 conf-section" data-conf="nfc">
    <div class="flex items-center gap-2 mb-4">
      <span class="h-3 w-3 rounded-full bg-amber-400"></span>
      <h2 class="text-sm font-bold text-zinc-200 uppercase tracking-wider">National Football Conference</h2>
      <span class="text-[10px] text-zinc-600">({nfcTeams.length} teams)</span>
    </div>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {nfcTeams.map(team => (
        <div class="team-card rounded-xl border border-zinc-800/40 bg-zinc-900/40 backdrop-blur-sm overflow-hidden hover:border-zinc-700/60 transition-all duration-300">
          <div class="h-1" style={`background: linear-gradient(90deg, ${team.color}, ${team.color}88)`}></div>
          <div class="p-4">
            <div class="flex items-center gap-3 mb-4">
              <img src={nflTeamLogo(team.abbr)} alt={team.name} class="h-10 w-10 object-contain" loading="lazy" onerror="this.style.display='none'" />
              <div class="min-w-0">
                <h3 class="text-sm font-bold text-zinc-100 truncate">{team.name}</h3>
                <p class="text-[10px] text-zinc-600">{team.city} · {team.div}</p>
              </div>
            </div>
            <div class="space-y-2">
              {positions.map(pos => (
                <div class={`rounded-lg border p-2.5 ${posColors[pos]}`}>
                  <div class="flex items-center justify-between mb-1">
                    <div class="flex items-center gap-1.5">
                      <span class="text-[10px]">{posIcons[pos]}</span>
                      <span class="text-[10px] font-bold uppercase tracking-wider">{pos}</span>
                    </div>
                    <span class="text-[9px] opacity-60">Starter</span>
                  </div>
                  <div class="flex items-center gap-2">
                    <div class="h-6 w-6 rounded bg-zinc-800/60 flex items-center justify-center text-[9px] text-zinc-500 font-mono">1</div>
                    <span class="text-xs text-zinc-400">TBD</span>
                  </div>
                  <div class="flex items-center gap-2 mt-1 opacity-50">
                    <div class="h-5 w-5 rounded bg-zinc-800/40 flex items-center justify-center text-[8px] text-zinc-600 font-mono">2</div>
                    <span class="text-[10px] text-zinc-600">TBD</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>

  <!-- Info Card -->
  <div class="mt-8 rounded-xl border border-zinc-800/40 bg-zinc-900/30 p-5">
    <div class="flex items-start gap-3">
      <span class="text-lg shrink-0 mt-0.5">ℹ️</span>
      <div>
        <h3 class="text-sm font-bold text-zinc-200 mb-1">About Depth Charts</h3>
        <p class="text-xs text-zinc-500 leading-relaxed">
          Depth charts are sourced from ESPN's public API and update throughout the season as teams make roster changes.
          During the offseason, projected starters are based on roster moves, free agency, and the NFL Draft.
          Data refreshes every 24 hours. Position slots will populate with player names once the season begins.
        </p>
      </div>
    </div>
  </div>
</Layout>

<script>
  // Conference filter tabs
  document.querySelectorAll('.conference-tab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.conference-tab').forEach(b => {
        b.classList.remove('active', 'bg-amber-500/10', 'text-amber-400', 'border-amber-500/20');
        b.classList.add('text-zinc-500', 'border-transparent');
      });
      btn.classList.add('active', 'bg-amber-500/10', 'text-amber-400', 'border-amber-500/20');
      btn.classList.remove('text-zinc-500', 'border-transparent');

      const conf = btn.dataset.conf;
      document.querySelectorAll('.conf-section').forEach(section => {
        if (conf === 'all') {
          section.style.display = 'block';
        } else {
          section.style.display = section.dataset.conf === conf ? 'block' : 'none';
        }
      });
    });
  });
</script>
