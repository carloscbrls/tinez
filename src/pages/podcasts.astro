---

<Layout title="Fantasy Podcasts">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-violet-600/20 via-purple-600/10 to-zinc-900 p-8 border border-violet-500/20">
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight">Fantasy & NFL Podcasts</h1>
        <p class="mt-1 text-zinc-400">Top fantasy football podcasts + team-specific shows</p>
      </div>
    </div>
  </div>

  <!-- Fantasy Podcasts -->
  <div class="mb-8">
    <h2 class="mb-4 text-xl font-semibold">🏆 Top Fantasy Football Podcasts</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {fantasyPodcasts.map(pod => (
        <a
          href={pod.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group rounded-xl border border-zinc-800 bg-zinc-900/30 p-4 hover:border-violet-500/30 hover:bg-zinc-900/50 transition-all"
        >
          <div class="flex items-start gap-3">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-violet-500/20 text-lg">
              🎙️
            </div>
            <div class="min-w-0">
              <div class="font-medium text-sm group-hover:text-violet-400 transition-colors">{pod.name}</div>
              <div class="mt-1 text-xs text-zinc-500 line-clamp-2">{pod.description}</div>
              <div class="mt-2 text-xs text-zinc-600">{pod.platform}</div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- League Podcast Placeholder -->
  <div class="mb-8 rounded-xl border border-amber-500/20 bg-gradient-to-br from-amber-600/10 to-zinc-900 p-6">
    <div class="flex items-center gap-3 mb-3">
      <div class="text-2xl">🎧</div>
      <div>
        <h2 class="text-lg font-semibold text-amber-400">Tinez League Podcast</h2>
        <p class="text-sm text-zinc-400">Coming soon · The #1 fantasy podcast for the Tinez League</p>
      </div>
    </div>
    <p class="text-sm text-zinc-500">
      When the league podcast launches, episodes will appear here with player spotlights, 
      weekly recaps, trade analysis, and championship predictions.
    </p>
  </div>

  <!-- NFL Team Podcasts -->
  <div>
    <h2 class="mb-4 text-xl font-semibold">🏈 NFL Team Podcasts</h2>
    <div class="grid gap-2 sm:grid-cols-2 lg:grid-cols-4">
      {nflTeamPodcasts.map(pod => (
        <a
          href={`https://x.com/${pod.handle}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-lg border border-zinc-800 bg-zinc-900/30 p-2.5 hover:border-zinc-700 transition-all text-sm"
        >
          <span class="text-zinc-500">🎙️</span>
          <span class="truncate font-medium">{pod.team}</span>
          <svg class="ml-auto h-3 w-3 shrink-0 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      ))}
    </div>
  </div>
</Layout>
