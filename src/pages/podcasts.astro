    url: "https://www.espn.com/espnradio/podcast/archive/podcastId/16459776",
    platform: "ESPN",
  },
  {
    name: "The Ringer Fantasy Football Show",
    description: "CBS Sports and The Ringer's crew breaking down matchups, waivers, and DFS.",
    url: "https://www.theringer.com/podcasts",
    platform: "The Ringer",
  },
  {
    name: "Harris Football",
    description: "Christopher Harris with film-focused player evaluations and sleeper picks.",
    url: "https://www.harrisfootball.com/",
    platform: "Harris Football",
  },
  {
    name: "Rotoworld Football Show",
