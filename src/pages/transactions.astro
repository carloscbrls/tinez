---
import Layout from "../layouts/Layout.astro";
import { teams } from "../data/teams";
---

<Layout title="Transactions">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">T</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Transactions</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Waiver wire moves, trades, and free agent activity</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Pre-Season Notice -->
  <div class="glass-card-accent rounded-xl p-12 text-center mb-8">
    <div class="text-5xl mb-4">🔄</div>
    <h2 class="text-xl font-bold text-amber-400 mb-2">No transactions yet</h2>
    <p class="text-zinc-400">Pre-season.</p>
    <p class="text-xs text-zinc-600 mt-1">Transaction data will appear once the season starts.</p>
  </div>

  <!-- Stats Overview -->
  <div class="grid gap-3 sm:grid-cols-3 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-amber-400">0</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Total Transactions</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-blue-400">0</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Trades</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-emerald-400">0</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Waiver/FA Moves</div>
    </div>
  </div>

  <!-- Team List -->
  <div class="mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">👥</div>
      <h2 class="text-lg font-bold text-amber-400">League Teams</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {teams.map(t => (
        <div class="glass-card rounded-xl p-4 flex items-center gap-3">
          <div class="h-10 w-10 rounded-xl flex items-center justify-center text-sm font-bold text-white shrink-0" style={`background: linear-gradient(135deg, ${t.primaryColor}, ${t.secondaryColor})`}>
            {t.shortName}
          </div>
          <div>
            <div class="text-sm font-semibold text-zinc-100">{t.name}</div>
            <div class="text-[10px] text-zinc-500">{t.owner}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</Layout>
