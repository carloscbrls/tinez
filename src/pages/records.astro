---
import Layout from "../layouts/Layout.astro";
import { champions, getChampionCounts } from "../data/champions";
import { teams } from "../data/teams";

const counts = getChampionCounts();
const sortedTeams = [...teams].sort((a, b) => a.name.localeCompare(b.name));
const bestRecord = [...teams].sort((a, b) => {
  const aPct = a.wins + a.ties * 0.5;
  const bPct = b.wins + b.ties * 0.5;
  if (bPct !== aPct) return bPct - aPct;
  return b.pointsFor - a.pointsFor;
})[0];
const topPF = [...teams].sort((a, b) => b.pointsFor - a.pointsFor)[0];
---

<Layout title="League Records">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📜</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">League Records</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · All-time achievements and milestones</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Stats -->
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-amber-400">{champions.length}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Seasons Played</div>
      <div class="text-xs text-zinc-600 mt-0.5">2014-2025</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-emerald-400">{counts.length}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Unique Champions</div>
      <div class="text-xs text-zinc-600 mt-0.5">Different winners</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-blue-400">{bestRecord ? `${bestRecord.wins}-${bestRecord.losses}` : "—"}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Best Record</div>
      <div class="text-xs text-zinc-600 mt-0.5">{bestRecord?.name || "—"}</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-purple-400">{topPF ? topPF.pointsFor.toFixed(0) : "—"}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Most Points For</div>
      <div class="text-xs text-zinc-600 mt-0.5">{topPF?.name || "—"}</div>
    </div>
  </div>

  <!-- All-Time Records -->
  <div class="mb-8">
    <h2 class="text-lg font-bold text-zinc-100 mb-4">🏅 All-Time Records</h2>
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-3 mb-3">
        <span class="text-2xl">📋</span>
        <div>
          <h3 class="text-sm font-semibold text-amber-300">Pre-Season</h3>
          <p class="text-xs text-zinc-500">Records will populate once the 2026 season begins</p>
        </div>
      </div>
      <p class="text-xs text-zinc-400">The TINEZ league is in its first season on Yahoo. All 14 teams are confirmed and the draft is pending. League records, milestones, and historical stats will appear here after games are played.</p>
    </div>
  </div>

  <!-- Championship Leaderboard -->
  <div class="mb-8">
    <h2 class="text-lg font-bold text-zinc-100 mb-4">🏆 Championship Leaderboard</h2>
    <div class="glass-card rounded-xl overflow-hidden">
      <table class="premium-table">
        <thead>
          <tr>
            <th class="w-8">#</th>
            <th>Owner</th>
            <th class="text-center text-amber-500">🏆</th>
            <th class="text-center text-zinc-400">🥈</th>
            <th class="text-center text-zinc-500">🥉</th>
            <th class="text-center">Total</th>
          </tr>
        </thead>
        <tbody>
          {counts.map((c, i) => {
            const isYou = c.owner === "Carlitos";
            const total = c.wins + c.runnerUps + c.thirds;
            return (
              <tr class="hover:bg-zinc-800/30 transition-colors" class:list={[isYou ? 'bg-amber-500/5' : '']}>
                <td class="text-zinc-500 font-mono text-xs">
                  {i === 0 ? <span class="text-amber-400">🥇</span> : i === 1 ? <span class="text-zinc-300">🥈</span> : i === 2 ? <span class="text-amber-600">🥉</span> : i + 1}
                </td>
                <td>
                  <div class="flex items-center gap-2">
                    <span class="font-medium" class:list={[isYou ? 'text-amber-400' : 'text-zinc-200']}>{c.owner}</span>
                    {isYou && <span class="rounded-full bg-amber-500/10 px-1.5 py-0.5 text-[10px] font-medium text-amber-400">YOU</span>}
                  </div>
                </td>
                <td class="text-center">
                  <span class="font-bold text-amber-400 text-lg">{c.wins}</span>
                </td>
                <td class="text-center font-medium text-zinc-300">{c.runnerUps}</td>
                <td class="text-center font-medium text-zinc-300">{c.thirds}</td>
                <td class="text-center font-bold text-zinc-100">{total}</td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </div>

  <!-- Season-by-Season -->
  <div>
    <h2 class="text-lg font-bold text-zinc-100 mb-4">📅 Season-by-Season Champions</h2>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 stagger-children">
      {[...champions].sort((a, b) => b.year - a.year).map(c => (
        <div class="glass-card rounded-xl p-4">
          <div class="flex items-center justify-between mb-2">
            <span class="text-lg font-extrabold text-amber-400">{c.year}</span>
            <span class="text-xs text-zinc-600">League #{c.leagueId}</span>
          </div>
          <div class="space-y-1.5 text-sm">
            <div class="flex items-center gap-2">
              <span>🏆</span>
              <span class="font-semibold text-zinc-100">{c.champion}</span>
              <span class="text-xs text-zinc-500">({c.championOwner})</span>
            </div>
            <div class="flex items-center gap-2">
              <span>🥈</span>
              <span class="text-zinc-300">{c.runnerUp}</span>
              <span class="text-xs text-zinc-500">({c.runnerUpOwner})</span>
            </div>
            <div class="flex items-center gap-2">
              <span>🥉</span>
              <span class="text-zinc-400">{c.thirdPlace}</span>
              <span class="text-xs text-zinc-500">({c.thirdPlaceOwner})</span>
            </div>
          </div>
          {c.championOwner === "Carlitos" && (
            <div class="mt-2">
              <span class="rounded-full bg-amber-500/10 px-2 py-0.5 text-[10px] font-medium text-amber-400">🏆 Your Championship</span>
            </div>
          )}
        </div>
      ))}
    </div>
  </div>
</Layout>
