---
import Layout from "../../layouts/Layout.astro";
import { getTeamById, teams } from "../../data/teams";
import { getNFLTeam } from "../../data/nfl-teams";
export async function getStaticPaths() {
  return teams.map(team => ({
    params: { id: String(team.id) },
    props: { team },
  }));
}
const { team } = Astro.props;
const record = `${team.wins}-${team.losses}-${team.ties}`;
const nfl = team.nflTeam ? getNFLTeam(team.nflTeam) : undefined;
---

<Layout title={`${team.name} | Teams`}>
  <a href="/teams" class="mb-4 inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
    ← All Teams
  </a>

  <div class="rounded-xl border border-zinc-800 p-6" style={`border-color: ${team.primaryColor}40`}>
    <div class="flex items-center gap-4">
      <div class="h-16 w-16 rounded-2xl flex items-center justify-center text-2xl font-bold text-white" style={`background: ${team.primaryColor}`}>
        {team.shortName}
      </div>
      <div>
        <h1 class="text-2xl font-bold">{team.name}</h1>
        <p class="text-zinc-400">Owner: {team.owner}</p>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-3 gap-4">
      <div class="rounded-lg bg-zinc-900 p-4 text-center">
        <div class="text-2xl font-bold">{record}</div>
        <div class="text-xs text-zinc-500 mt-1">Record</div>
      </div>
      <div class="rounded-lg bg-zinc-900 p-4 text-center">
        <div class="text-2xl font-bold">{team.pointsFor.toFixed(1)}</div>
        <div class="text-xs text-zinc-500 mt-1">Points For</div>
      </div>
      <div class="rounded-lg bg-zinc-900 p-4 text-center">
        <div class="text-2xl font-bold">{team.pointsAgainst.toFixed(1)}</div>
        <div class="text-xs text-zinc-500 mt-1">Points Against</div>
      </div>
    </div>

    {nfl && (
      <div class="mt-6">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wider text-zinc-500">NFL Team Feed</h2>
        <a
          href={`https://x.com/${nfl.xHandle}`}
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 rounded-lg border border-zinc-800 bg-zinc-900/50 p-4 hover:border-zinc-700 transition-all group"
        >
          <div class="flex h-10 w-10 items-center justify-center rounded-lg text-sm font-bold text-white" style={`background: ${nfl.primaryColor}`}>
            {nfl.shortName}
          </div>
          <div>
            <div class="font-medium group-hover:text-sky-400 transition-colors">{nfl.name}</div>
            <div class="text-xs text-zinc-500">@{nfl.xHandle}</div>
          </div>
          <svg class="ml-auto h-4 w-4 shrink-0 text-zinc-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    )}
  </div>
</Layout>
