---
import Layout from "../../layouts/Layout.astro";
import { getTeamById, teams } from "../../data/teams";
export async function getStaticPaths() {
  return teams.map(team => ({
    params: { id: String(team.id) },
    props: { team },
  }));
}
const { team } = Astro.props;
const record = `${team.wins}-${team.losses}-${team.ties}`;
---

<Layout title={`${team.name} | Teams`}>
  <a href="/teams" class="mb-4 inline-flex items-center gap-1 text-sm text-zinc-500 hover:text-zinc-300 transition-colors">
    ← All Teams
  </a>

  <div class="rounded-xl border border-zinc-800 p-6" style={`border-color: ${team.primaryColor}40`}>
    <div class="flex items-center gap-4">
      <div class="h-16 w-16 rounded-2xl flex items-center justify-center text-2xl font-bold text-white" style={`background: ${team.primaryColor}`}>
        {team.shortName}
      </div>
      <div>
        <h1 class="text-2xl font-bold">{team.name}</h1>
        <p class="text-zinc-400">Owner: {team.owner}</p>
      </div>
    </div>

    <div class="mt-6 grid grid-cols-3 gap-4">
      <div class="rounded-lg bg-zinc-900 p-4 text-center">
        <div class="text-2xl font-bold">{record}</div>
        <div class="text-xs text-zinc-500 mt-1">Record</div>
      </div>
      <div class="rounded-lg bg-zinc-900 p-4 text-center">
        <div class="text-2xl font-bold">{team.pointsFor.toFixed(1)}</div>
        <div class="text-xs text-zinc-500 mt-1">Points For</div>
      </div>
      <div class="rounded-lg bg-zinc-900 p-4 text-center">
        <div class="text-2xl font-bold">{team.pointsAgainst.toFixed(1)}</div>
        <div class="text-xs text-zinc-500 mt-1">Points Against</div>
      </div>
    </div>

    {team.xHandle && (
      <div class="mt-6">
        <h2 class="mb-2 text-sm font-semibold uppercase tracking-wider text-zinc-500">X Feed</h2>
        <div class="rounded-xl border border-zinc-800 p-4 text-center text-sm text-zinc-500">
          <p>X/Twitter feed for <span class="text-amber-400">@{team.xHandle}</span> will appear here.</p>
          <p class="mt-1 text-xs">Embed via Twitter widget</p>
        </div>
      </div>
    )}
  </div>
</Layout>
