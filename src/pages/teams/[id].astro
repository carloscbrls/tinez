---
import Layout from "../../layouts/Layout.astro";
import { getTeamById, teams } from "../../data/teams";
import { getNFLTeam } from "../../data/nfl-teams";
import { getNflTeamLogoUrl } from "../../data/players";
export async function getStaticPaths() {
  return teams.map(team => ({
    params: { id: String(team.id) },
    props: { team },
  }));
}
const { team } = Astro.props;
const record = `${team.wins}-${team.losses}-${team.ties}`;
const nfl = team.nflTeam ? getNFLTeam(team.nflTeam) : undefined;
const diff = team.pointsFor - team.pointsAgainst;
---

<Layout title={`${team.name} | Teams`}>
  <a href="/teams" class="mb-5 inline-flex items-center gap-1.5 text-sm text-zinc-500 hover:text-zinc-300 transition-all group">
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:-translate-x-0.5 transition-transform"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
    All Teams
  </a>

  <!-- Team Hero -->
  <div class="relative overflow-hidden rounded-2xl border mb-8" style={`border-color: ${team.primaryColor}40`}>
    <div class="absolute inset-0 opacity-10" style={`background: linear-gradient(135deg, ${team.primaryColor}, ${team.secondaryColor})`}></div>
    <div class="relative z-10 p-6 md:p-8">
      <div class="flex items-center gap-4 md:gap-6">
        <div class="h-16 w-16 md:h-20 md:w-20 rounded-2xl flex items-center justify-center text-2xl md:text-3xl font-bold text-white shrink-0 animate-pulse-glow" style={`background: linear-gradient(135deg, ${team.primaryColor}, ${team.secondaryColor})`}>
          {team.shortName}
        </div>
        <div>
          <h1 class="text-2xl md:text-3xl font-extrabold text-zinc-100">{team.name}</h1>
          <div class="flex items-center gap-2 mt-1">
            <span class="text-sm text-zinc-400">Owner: <span class="font-semibold text-zinc-300">{team.owner}</span></span>
            <span class="text-zinc-600">·</span>
            <span class="text-sm text-zinc-500">{record}</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Stats Grid -->
  <div class="grid gap-4 sm:grid-cols-3 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold gradient-text">{record}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Record</div>
      <div class="mt-2 flex justify-center gap-2 text-xs">
        <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-emerald-400"></span> {team.wins} W</span>
        <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-red-400"></span> {team.losses} L</span>
        <span class="inline-flex items-center gap-1"><span class="h-2 w-2 rounded-full bg-zinc-500"></span> {team.ties} T</span>
      </div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-emerald-400">{team.pointsFor.toFixed(1)}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Points For</div>
      <div class="mt-2 text-xs text-zinc-600">Avg: {(team.pointsFor / Math.max(team.wins + team.losses + team.ties, 1)).toFixed(1)}/game</div>
    </div>
    <div class="glass-card rounded-xl p-5 text-center">
      <div class="text-3xl font-extrabold text-red-400">{team.pointsAgainst.toFixed(1)}</div>
      <div class="text-xs text-zinc-500 mt-1 font-medium uppercase tracking-wider">Points Against</div>
      <div class="mt-2 text-xs">
        <span class={diff > 0 ? "text-emerald-400" : diff < 0 ? "text-red-400" : "text-zinc-500"}>
          Diff: {diff > 0 ? '+' : ''}{diff.toFixed(1)}
        </span>
      </div>
    </div>
  </div>

  <!-- NFL Team Feed -->
  {nfl && (
    <div class="glass-card-accent rounded-xl p-5">
      <div class="flex items-center gap-3 mb-3">
        <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400">NFL Team Affiliation</h2>
      </div>
      <a
        href={`https://x.com/${nfl.xHandle}`}
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-4 rounded-xl bg-zinc-800/30 p-4 hover:bg-zinc-800/50 transition-all group border border-zinc-700/30"
      >
        <img src={getNflTeamLogoUrl(nfl.shortName)} alt={nfl.name} class="h-12 w-12 object-contain" loading="lazy" onerror="this.style.display='none'" />
        <div class="flex-1">
          <div class="font-semibold text-zinc-100 group-hover:text-amber-400 transition-colors">{nfl.name}</div>
          <div class="text-xs text-zinc-500">@{nfl.xHandle}</div>
        </div>
        <div class="flex items-center gap-2 text-xs text-zinc-500">
          <span>Follow on X</span>
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover:translate-x-0.5 transition-transform"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </div>
      </a>
    </div>
  )}

  <!-- Team Info -->
  <div class="mt-8 glass-card-static rounded-xl p-5">
    <h2 class="text-sm font-semibold uppercase tracking-wider text-zinc-400 mb-4">Team Details</h2>
    <div class="grid gap-3 sm:grid-cols-2">
      <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-4 py-3">
        <span class="text-sm text-zinc-500">Team Name</span>
        <span class="text-sm font-semibold text-zinc-200">{team.name}</span>
      </div>
      <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-4 py-3">
        <span class="text-sm text-zinc-500">Owner</span>
        <span class="text-sm font-semibold text-zinc-200">{team.owner}</span>
      </div>
      <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-4 py-3">
        <span class="text-sm text-zinc-500">Short Name</span>
        <span class="text-sm font-semibold text-zinc-200">{team.shortName}</span>
      </div>
      <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-4 py-3">
        <span class="text-sm text-zinc-500">Streak</span>
        <span class="text-sm font-semibold text-zinc-200">{team.streak}</span>
      </div>
    </div>
  </div>
</Layout>