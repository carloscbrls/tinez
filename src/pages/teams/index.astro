---
import Layout from "../../layouts/Layout.astro";
import { teams } from "../../data/teams";
---

<Layout title="Teams">
  <div class="mb-6">
    <h1 class="text-2xl font-bold">Teams</h1>
    <p class="mt-1 text-zinc-400">All 16 teams of the Tinez Fantasy Football League</p>
  </div>

  <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
    {teams.map(team => (
      <a href={`/teams/${team.id}`} class="group rounded-xl border border-zinc-800 p-5 hover:border-zinc-700 transition-all hover:bg-zinc-900/50">
        <div class="flex items-center gap-3">
          <div class="h-12 w-12 rounded-xl flex items-center justify-center text-lg font-bold text-white" style={`background: ${team.primaryColor}`}>
            {team.shortName}
          </div>
          <div>
            <div class="font-semibold group-hover:text-amber-400 transition-colors">{team.name}</div>
            <div class="text-xs text-zinc-500">{team.owner}</div>
          </div>
        </div>
        <div class="mt-3 flex items-center gap-3 text-xs text-zinc-500">
          <span>{team.wins}-{team.losses}-{team.ties}</span>
          <span>·</span>
          <span>{team.pointsFor.toFixed(1)} PF</span>
        </div>
      </a>
    ))}
  </div>
</Layout>
