---
import Layout from "../layouts/Layout.astro";
import { matchups2025, getWeeksWithMatchups, getCarlitosMatchups } from "../data/matchups";
import { getNflTeamLogoUrl } from "../data/players";
import { teams } from "../data/teams";
const weeks = getWeeksWithMatchups();
const carlitosMatchups = getCarlitosMatchups();
const currentWeek = weeks.length > 0 ? weeks[0] : 1;
---

<Layout title="Matchups">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">M</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Matchups</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · 2025 Season</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Carlitos's Matchups -->
  <div class="glass-card rounded-xl p-6 mb-8">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">👑</div>
      <h2 class="text-lg font-bold text-amber-400">Your Matchups</h2>
    </div>
    {carlitosMatchups.length > 0 ? (
      <div class="space-y-3">
        {carlitosMatchups.map(m => {
          const isHome = m.homeOwner === "Carlitos";
          const opponent = isHome ? m.awayTeam : m.homeTeam;
          const opponentOwner = isHome ? m.awayOwner : m.homeOwner;
          const yourScore = isHome ? m.homeScore : m.awayScore;
          const oppScore = isHome ? m.awayScore : m.homeScore;
          const result = yourScore > oppScore ? "W" : yourScore < oppScore ? "L" : "T";
          const resultColor = result === "W" ? "text-emerald-400" : result === "L" ? "text-red-400" : "text-zinc-400";
          return (
            <div class="rounded-lg bg-zinc-800/20 p-4">
              <div class="flex items-center justify-between">
                <div class="flex items-center gap-3">
                  <span class="text-xs font-medium text-zinc-500">Week {m.week}</span>
                  <span class={`text-lg font-extrabold ${resultColor}`}>{result}</span>
                </div>
                <span class="text-xs text-zinc-600">{m.winner === "TBD" ? "Upcoming" : "Final"}</span>
              </div>
              <div class="flex items-center justify-between mt-2">
                <div class="flex items-center gap-2">
                  <span class="text-sm font-semibold text-amber-400">CC3PO</span>
                  <span class="text-lg font-bold text-zinc-100">{yourScore}</span>
                </div>
                <span class="text-xs text-zinc-600">vs</span>
                <div class="flex items-center gap-2">
                  <span class="text-lg font-bold text-zinc-100">{oppScore}</span>
                  <span class="text-sm font-semibold text-zinc-300">{opponent}</span>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    ) : (
      <p class="text-sm text-zinc-500">No matchups loaded yet. Data will populate once the season starts.</p>
    )}
  </div>

  <!-- All Matchups by Week -->
  <div>
    <h2 class="text-lg font-bold text-zinc-100 mb-4">All Matchups</h2>
    <div class="space-y-6 stagger-children">
      {weeks.map(week => {
        const weekMatchups = matchups2025.filter(m => m.week === week);
        return (
          <div>
            <h3 class="text-sm font-semibold text-zinc-400 mb-3">Week {week}</h3>
            <div class="grid gap-3">
              {weekMatchups.map(m => {
                const isComplete = m.winner !== "TBD";
                return (
                  <div class="glass-card rounded-xl p-4">
                    <div class="flex items-center justify-between">
                      <div class="flex items-center gap-3 flex-1">
                        <div class="text-right">
                          <div class="font-semibold text-sm text-zinc-100">{m.homeTeam}</div>
                          <div class="text-[10px] text-zinc-600">{m.homeOwner}</div>
                        </div>
                        <div class="text-lg font-extrabold font-mono" class:list={[isComplete && m.winner === m.homeTeam ? 'text-emerald-400' : 'text-zinc-100']}>{m.homeScore}</div>
                      </div>
                      <div class="text-xs text-zinc-600 px-3">@</div>
                      <div class="flex items-center gap-3 flex-1 justify-end">
                        <div class="text-lg font-extrabold font-mono" class:list={[isComplete && m.winner === m.awayTeam ? 'text-emerald-400' : 'text-zinc-100']}>{m.awayScore}</div>
                        <div class="text-left">
                          <div class="font-semibold text-sm text-zinc-100">{m.awayTeam}</div>
                          <div class="text-[10px] text-zinc-600">{m.awayOwner}</div>
                        </div>
                      </div>
                    </div>
                    {isComplete && (
                      <div class="mt-2 text-center">
                        <span class="rounded-full bg-emerald-500/10 px-2 py-0.5 text-[10px] font-medium text-emerald-400">Winner: {m.winner}</span>
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </div>
        );
      })}
    </div>
  </div>
</Layout>
