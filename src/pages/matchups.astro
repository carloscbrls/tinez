---
import Layout from "../layouts/Layout.astro";
import { teams } from "../data/teams";
import { fetchScoreboard, fetchTeamWeather, getWeatherEmoji, getWeatherImpact, stadiums } from "../data/nfl-api";

const scoreboard = await fetchScoreboard(1);
const events = scoreboard?.events || [];

// Fetch weather for each game
const weatherPromises = events.map(async (e) => {
  const comp = e.competitions[0];
  const homeTeam = comp.competitors.find(c => c.homeAway === "home");
  if (!homeTeam) return { gameId: e.id, weather: null };
  const weather = await fetchTeamWeather(homeTeam.team.abbreviation);
  return { gameId: e.id, weather };
});
const weatherResults = await Promise.all(weatherPromises);
const weatherMap = new Map(weatherResults.map(r => [r.gameId, r.weather]));
---

