          </div>
        </div>
        <div class="text-lg font-bold text-zinc-600">vs</div>
        <div class="flex items-center gap-3">
          <div>
            <div class="text-sm font-semibold text-zinc-100 text-right">RemeberTheTrojans</div>
            <div class="text-xs text-zinc-500 text-right">Todd</div>
          </div>
          <div class="h-10 w-10 rounded-xl flex items-center justify-center text-sm font-bold text-white" style="background: linear-gradient(135deg, #800000, #FFB347)">RTT</div>
        </div>
      </div>
    </div>
  </div>

  <!-- NFL Schedule -->
  <div class="mb-8">
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-bold text-zinc-100">🏈 NFL Week {scoreboard?.week?.number || 1} Schedule</h2>
      <span class="text-xs text-zinc-500 bg-zinc-800/30 px-2 py-1 rounded-md">Live from ESPN</span>
    </div>
    <div class="space-y-3">
      {events.map((e) => {
        const comp = e.competitions[0];
        const away = comp.competitors.find(c => c.homeAway === "away");
        const home = comp.competitors.find(c => c.homeAway === "home");
        const weather = weatherMap.get(e.id);
        const impact = weather ? getWeatherImpact(weather) : null;
        const stadium = home ? stadiums[home.team.abbreviation] : null;
        const isPre = e.status.type.state === "pre";
        const isLive = e.status.type.state === "in";
        const isFinal = e.status.type.state === "post";

        return (
          <div class="glass-card rounded-xl p-4 group hover:bg-zinc-800/40 transition-all">
            <div class="flex items-center gap-4">
              <!-- Status Badge -->
              <div class="w-16 shrink-0 text-center">
                {isFinal ? (
                  <span class="text-xs font-semibold text-zinc-500">FINAL</span>
                ) : isLive ? (
                  <span class="text-xs font-semibold text-red-400 animate-pulse">LIVE</span>
                ) : (
                  <span class="text-xs text-zinc-600">{new Date(e.date).toLocaleDateString("en-US", { month: "short", day: "numeric" })}</span>
                )}
              </div>

              <!-- Away Team -->
              <div class="flex-1 text-right">
                <div class="text-sm font-semibold text-zinc-100">{away?.team.displayName || away?.team.abbreviation}</div>
                <div class="text-xs text-zinc-500">{away?.team.abbreviation}</div>
              </div>

              {/* Score / vs */}
              <div class="shrink-0 text-center">
                {isFinal || isLive ? (
                  <div class="flex items-center gap-2">
                    <span class={`text-lg font-extrabold font-mono ${away?.winner ? "text-emerald-400" : "text-zinc-400"}`}>{away?.score || "0"}</span>
                    <span class="text-xs text-zinc-600">-</span>
                    <span class={`text-lg font-extrabold font-mono ${home?.winner ? "text-emerald-400" : "text-zinc-400"}`}>{home?.score || "0"}</span>
                  </div>
                ) : (
                  <span class="text-xs font-bold text-zinc-600">VS</span>
                )}
              </div>

              <!-- Home Team -->
              <div class="flex-1 text-left">
                <div class="text-sm font-semibold text-zinc-100">{home?.team.displayName || home?.team.abbreviation}</div>
                <div class="text-xs text-zinc-500">{home?.team.abbreviation}</div>
              </div>

              <!-- Weather -->
              {weather && stadium?.roof === "open" && (
                <div class="w-20 shrink-0 text-center hidden md:block" title={impact?.description}>
                  <div class="text-sm">{getWeatherEmoji(weather.weatherCode)}</div>
                  <div class="text-xs text-zinc-500">{Math.round(weather.temperature)}°F</div>
                  {weather.windSpeed > 15 && <div class="text-[10px] text-zinc-600">{Math.round(weather.windSpeed)} mph</div>}
                </div>
              )}

              {/* Stadium */}
              {stadium && (
                <div class="w-24 shrink-0 text-center hidden lg:block">
                  <div class="text-[10px] text-zinc-600 truncate">{stadium.name}</div>
                  {stadium.roof !== "open" && (
                    <span class="text-[10px] text-zinc-500">{stadium.roof === "closed" ? "🏟️ Dome" : "🔽 Retractable"}</span>
                  )}
                </div>
              )}
            </div>
          </div>
        );
      })}
    </div>
  </div>

  <!-- Weather Impact Guide -->
  <div class="glass-card rounded-xl p-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">🌤️</span>
      <h2 class="text-lg font-bold text-zinc-100">Weather Impact Guide</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-xl mb-1">☀️</div>
        <div class="text-xs font-semibold text-emerald-400">Clear</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">Normal scoring</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-xl mb-1">🌧️</div>
        <div class="text-xs font-semibold text-blue-400">Rain</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">Passing game down</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-xl mb-1">💨</div>
        <div class="text-xs font-semibold text-amber-400">Windy</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">Deep passes affected</div>
      </div>
      <div class="bg-zinc-800/30 rounded-lg p-3 text-center">
        <div class="text-xl mb-1">❄️</div>
        <div class="text-xs font-semibold text-blue-300">Snow</div>
        <div class="text-[10px] text-zinc-500 mt-0.5">RBs get a boost</div>
      </div>
    </div>
  </div>
</Layout>
