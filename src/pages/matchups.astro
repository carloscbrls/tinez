        <div class="flex items-center gap-3">
          <div>
            <div class="text-sm font-semibold text-zinc-100 text-right">THIS WILL HURTS A LITTLE</div>
            <div class="text-xs text-zinc-500 text-right">tyler</div>
          </div>
