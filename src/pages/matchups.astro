          <div>
            <div class="text-sm font-semibold text-zinc-100">El Bolillo</div>
            <div class="text-xs text-zinc-500">James</div>
          </div>
        </div>
        <div class="text-lg font-bold text-zinc-600">vs</div>
        <div class="flex items-center gap-3">
          <div>
