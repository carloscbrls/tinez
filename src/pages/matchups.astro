          </div>
          <div class="h-10 w-10 rounded-xl flex items-center justify-center text-sm font-bold text-white" style="background: linear-gradient(135deg, #001219, #EE9B00)">TTD</div>
        </div>
      </div>
      <div class="glass-card rounded-xl p-5 flex items-center justify-between">
        <div class="flex items-center gap-3">
          <div class="h-10 w-10 rounded-xl flex items-center justify-center text-sm font-bold text-white" style="background: linear-gradient(135deg, #005F73, #AE2012)">BPH</div>
