---
import Layout from "../layouts/Layout.astro";
import { fetchNFLSchedule, formatGameTime, formatGameDate } from "../data/schedule";
import { getNFLTeam, nflTeams } from "../data/nfl-teams";
import { getNflTeamLogoUrl } from "../data/players";

const currentWeek = 1;
const games = await fetchNFLSchedule(currentWeek);
---

<Layout title="NFL Schedules">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-sky-500/20">
      <div class="absolute inset-0 bg-gradient-to-br from-sky-600/10 via-blue-600/5 to-transparent animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-sky-400 to-blue-500 text-lg font-bold text-white shadow-lg shadow-sky-500/20">S</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">NFL Schedules</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">Week {currentWeek} · 2025 Season</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Week selector -->
  <div class="mb-6 flex gap-2 overflow-x-auto pb-2">
    {Array.from({ length: 18 }, (_, i) => (
      <a
        href={`/schedules`}
        class={`rounded-lg px-3 py-1.5 text-sm font-medium transition-all whitespace-nowrap ${
          i + 1 === currentWeek
            ? "bg-sky-500/15 text-sky-400 border border-sky-500/30 shadow-sm shadow-sky-500/10"
            : "bg-zinc-900/50 text-zinc-500 border border-zinc-800/50 hover:border-zinc-700/50 hover:text-zinc-300"
        }`}
      >
        W{i + 1}
      </a>
    ))}
  </div>

  <div class="space-y-3 stagger-children">
    {games.map(game => {
      const homeTeam = getNFLTeam(game.home_team);
      const awayTeam = getNFLTeam(game.away_team);
      const isFinal = game.status === "Final" || game.status === "Final/OT";
      const isLive = game.status === "In Progress" || game.status === "Halftime";

      return (
        <div class="glass-card rounded-xl p-4">
          <div class="flex items-center justify-between gap-4">
            <!-- Away Team -->
            <div class="flex flex-1 items-center gap-3">
              {awayTeam ? (
                <img src={getNflTeamLogoUrl(awayTeam.shortName)} alt={awayTeam.name} class="h-10 w-10 object-contain" loading="lazy" onerror="this.style.display='none'" />
              ) : null}
              <div class="min-w-0">
                <div class="truncate font-semibold text-sm text-zinc-100">{awayTeam?.name || game.away_team}</div>
                <div class="text-xs text-zinc-500">{awayTeam?.shortName || game.away_team}</div>
              </div>
            </div>

            <!-- Game Info -->
            <div class="text-center shrink-0">
              {isFinal ? (
                <div class="text-lg font-bold text-zinc-100">{game.away_score} - {game.home_score}</div>
              ) : (
                <div class="text-sm font-semibold">
                  {isLive ? (
                    <span class="text-emerald-400 animate-pulse">{game.status}</span>
                  ) : (
                    <span class="text-zinc-200">{formatGameTime(game.date)}</span>
                  )}
                </div>
              )}
              <div class="text-xs text-zinc-600 mt-0.5">{formatGameDate(game.date)}</div>
              <div class="text-xs text-zinc-700 truncate max-w-[120px]">{game.venue}</div>
            </div>

            <!-- Home Team -->
            <div class="flex flex-1 items-center gap-3 justify-end">
              <div class="min-w-0 text-right">
                <div class="truncate font-semibold text-sm text-zinc-100">{homeTeam?.name || game.home_team}</div>
                <div class="text-xs text-zinc-500">{homeTeam?.shortName || game.home_team}</div>
              </div>
              {homeTeam ? (
                <img src={getNflTeamLogoUrl(homeTeam.shortName)} alt={homeTeam.name} class="h-10 w-10 object-contain" loading="lazy" onerror="this.style.display='none'" />
              ) : null}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</Layout>