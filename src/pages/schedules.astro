---
import Layout from "../layouts/Layout.astro";
import { fetchNFLSchedule, formatGameTime, formatGameDate } from "../data/schedule";
import { getNFLTeam, nflTeams } from "../data/nfl-teams";

const currentWeek = 1;
const games = await fetchNFLSchedule(currentWeek);
---

<Layout title="NFL Schedules">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl bg-gradient-to-br from-sky-600/20 via-blue-600/10 to-zinc-900 p-8 border border-sky-500/20">
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight">NFL Schedules</h1>
        <p class="mt-1 text-zinc-400">Week {currentWeek} · 2025 Season</p>
        <p class="mt-2 text-xs text-zinc-600">Powered by ESPN API · Live updates</p>
      </div>
    </div>
  </div>

  <!-- Week selector (static for now, can be made dynamic) -->
  <div class="mb-6 flex gap-2 overflow-x-auto pb-2">
    {Array.from({ length: 18 }, (_, i) => (
      <a
        href={`/schedules`}
        class={`rounded-lg px-3 py-1.5 text-sm font-medium transition-colors ${
          i + 1 === currentWeek
            ? "bg-sky-500/20 text-sky-400 border border-sky-500/30"
            : "bg-zinc-900 text-zinc-500 border border-zinc-800 hover:border-zinc-700"
        }`}
      >
        W{i + 1}
      </a>
    ))}
  </div>

  <div class="space-y-3">
    {games.map(game => {
      const homeTeam = getNFLTeam(game.home_team);
      const awayTeam = getNFLTeam(game.away_team);
      const isFinal = game.status === "Final" || game.status === "Final/OT";
      const isLive = game.status === "In Progress" || game.status === "Halftime";

      return (
        <div class="rounded-xl border border-zinc-800 bg-zinc-900/30 p-4 hover:border-zinc-700 transition-colors">
          <div class="flex items-center justify-between gap-4">
            <!-- Away Team -->
            <div class="flex flex-1 items-center gap-3">
              {awayTeam ? (
                <div class="flex h-10 w-10 items-center justify-center rounded-lg font-bold text-sm text-white" style={`background: ${awayTeam.primaryColor}`}>
                  {awayTeam.shortName}
                </div>
              ) : (
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-800 font-bold text-xs">
                  {game.away_team}
                </div>
              )}
              <div class="min-w-0">
                <div class="truncate font-medium text-sm">{awayTeam?.name || game.away_team}</div>
                <div class="text-xs text-zinc-500">{isFinal ? `${game.away_score}` : "0"}</div>
              </div>
            </div>

            <!-- Game Info -->
            <div class="text-center shrink-0">
              {isFinal ? (
                <div class="text-lg font-bold text-zinc-300">{game.away_score} - {game.home_score}</div>
              ) : (
                <div class="text-sm font-medium">
                  {isLive ? (
                    <span class="text-emerald-400">{game.status}</span>
                  ) : (
                    formatGameTime(game.date)
                  )}
                </div>
              )}
              <div class="text-xs text-zinc-600 mt-0.5">{formatGameDate(game.date)}</div>
              <div class="text-xs text-zinc-600">{game.venue}</div>
            </div>

            <!-- Home Team -->
            <div class="flex flex-1 items-center gap-3 justify-end">
              <div class="min-w-0 text-right">
                <div class="truncate font-medium text-sm">{homeTeam?.name || game.home_team}</div>
                <div class="text-xs text-zinc-500">{isFinal ? `${game.home_score}` : "0"}</div>
              </div>
              {homeTeam ? (
                <div class="flex h-10 w-10 items-center justify-center rounded-lg font-bold text-sm text-white" style={`background: ${homeTeam.primaryColor}`}>
                  {homeTeam.shortName}
                </div>
              ) : (
                <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-zinc-800 font-bold text-xs">
                  {game.home_team}
                </div>
              )}
            </div>
          </div>
        </div>
      );
    })}
  </div>
</Layout>
