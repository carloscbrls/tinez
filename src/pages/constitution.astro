---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Constitution">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">C</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">Constitution</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · Official Charter & Rulebook · Last Updated Aug 27, 2025</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Stats -->
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4 mb-8 stagger-children">
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-extrabold text-amber-400">$175</div>
      <div class="text-xs text-zinc-500 mt-1">Entry Fee</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-extrabold text-emerald-400">$2,450</div>
      <div class="text-xs text-zinc-500 mt-1">Total Prize Pool</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-extrabold text-amber-400">$1,435</div>
      <div class="text-xs text-zinc-500 mt-1">1st Place</div>
    </div>
    <div class="glass-card rounded-xl p-4 text-center">
      <div class="text-2xl font-extrabold text-zinc-100">$175</div>
      <div class="text-xs text-zinc-500 mt-1">2nd Place</div>
    </div>
  </div>

  <!-- League Officers -->
  <div class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">👑</div>
      <h2 class="text-lg font-bold text-amber-400">Article I — League Officers</h2>
    </div>
    <div class="grid gap-3 sm:grid-cols-3">
      <div class="rounded-lg bg-zinc-800/20 p-4 border border-amber-500/10">
        <div class="text-xs font-medium uppercase tracking-wider text-amber-500 mb-1">Commissioner</div>
        <div class="font-semibold text-zinc-100">Carlos Cabrales III</div>
        <div class="text-xs text-zinc-500 mt-1">(209) 423-6633</div>
        <div class="text-xs text-zinc-500">carloscbrls@gmail.com</div>
      </div>
      <div class="rounded-lg bg-zinc-800/20 p-4">
        <div class="text-xs font-medium uppercase tracking-wider text-zinc-400 mb-1">Co-Commissioner</div>
        <div class="font-semibold text-zinc-100">Joshua Phillips</div>
        <div class="text-xs text-zinc-500 mt-1">(858) 382-6412</div>
      </div>
      <div class="rounded-lg bg-zinc-800/20 p-4">
        <div class="text-xs font-medium uppercase tracking-wider text-zinc-400 mb-1">Co-Commissioner</div>
        <div class="font-semibold text-zinc-100">Darnell Simmons</div>
        <div class="text-xs text-zinc-500 mt-1">(669) 207-9577</div>
      </div>
    </div>
    <div class="mt-3 rounded-lg bg-zinc-800/20 p-3">
      <div class="text-xs font-medium uppercase tracking-wider text-zinc-400 mb-1">Treasurer</div>
      <div class="font-semibold text-zinc-100">Joshua Phillips</div>
      <div class="text-xs text-zinc-500">(858) 382-6412</div>
    </div>
  </div>

  <!-- Articles Grid -->
  <div class="grid gap-6 lg:grid-cols-2">
    <!-- Article II - Entry & Fees -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-emerald-500/10 text-sm">💰</div>
        <h2 class="text-lg font-bold text-emerald-400">Article II — Entry & Fees</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Entry Fee</dt>
          <dd class="font-semibold text-zinc-100">$175/team</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Total Collected</dt>
          <dd class="font-semibold text-zinc-100">$2,450</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Payment Deadline</dt>
          <dd class="text-zinc-200">Before Week 10</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Payment Methods</dt>
          <dd class="text-zinc-200">Venmo / Apple Pay</dd>
        </div>
      </dl>
    </div>

    <!-- Article III - Prizes -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">🏆</div>
        <h2 class="text-lg font-bold text-amber-400">Article III — Prize Payouts</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">1st Place (Yahoo)</dt>
          <dd class="font-bold text-amber-400">$1,435</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">2nd Place (Yahoo)</dt>
          <dd class="font-semibold text-zinc-100">$175</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Weekly Winners (Weeks 11-14)</dt>
          <dd class="font-semibold text-emerald-400">$30 each</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Bonus Pool Total</dt>
          <dd class="font-semibold text-zinc-100">$840</dd>
        </div>
      </dl>
    </div>

    <!-- Article IV - Playoffs -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-purple-500/10 text-sm">🏈</div>
        <h2 class="text-lg font-bold text-purple-400">Article IV — Playoffs</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Format</dt>
          <dd class="text-zinc-200">8-team bracket</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Weeks</dt>
          <dd class="text-zinc-200">15, 16, 17</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Tie-Breakers</dt>
          <dd class="text-zinc-200">Win% → PF → H2H → Coin Flip</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Non-Playoff Teams</dt>
          <dd class="text-zinc-200">Locked after Week 14</dd>
        </div>
      </dl>
    </div>

    <!-- Article V - Draft -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-blue-500/10 text-sm">📋</div>
        <h2 class="text-lg font-bold text-blue-400">Article V — Draft Order</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Order Method</dt>
          <dd class="text-zinc-200">Random Generator</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Finalized</dt>
          <dd class="text-zinc-200">3-7 days before draft</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Draft Day Theme</dt>
          <dd class="text-zinc-200">Champion chooses</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Stream</dt>
          <dd class="text-zinc-200">Live on YouTube</dd>
        </div>
      </dl>
    </div>

    <!-- Article VI - Trades -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-red-500/10 text-sm">🔄</div>
        <h2 class="text-lg font-bold text-red-400">Article VI — Trades</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Deadline</dt>
          <dd class="font-semibold text-zinc-100">Week 10</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Acceptance Window</dt>
          <dd class="text-zinc-200">24 hrs before kickoff</dd>
        </div>
      </dl>
    </div>

    <!-- Article IX - Last Place -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-orange-500/10 text-sm">😈</div>
        <h2 class="text-lg font-bold text-orange-400">Article IX — Last Place Punishment</h2>
      </div>
      <div class="rounded-lg bg-zinc-800/20 p-3 mb-3">
        <div class="font-semibold text-zinc-100 text-sm">Default: 🧇 Waffle Challenge</div>
        <p class="text-xs text-zinc-500 mt-1">24 hours in a diner, minus 2 hours per waffle/pancake consumed</p>
      </div>
      <div class="text-xs font-medium text-zinc-400 mb-2">Alternative Options:</div>
      <div class="flex flex-wrap gap-2">
        <span class="rounded-lg bg-zinc-800/50 px-2.5 py-1 text-xs text-zinc-300">$300 Fine</span>
        <span class="rounded-lg bg-zinc-800/50 px-2.5 py-1 text-xs text-zinc-300">Golden Toilet Trophy</span>
        <span class="rounded-lg bg-zinc-800/50 px-2.5 py-1 text-xs text-zinc-300">Funny League Video</span>
        <span class="rounded-lg bg-zinc-800/50 px-2.5 py-1 text-xs text-zinc-300">Draft Penalty (Last Pick R1)</span>
        <span class="rounded-lg bg-zinc-800/50 px-2.5 py-1 text-xs text-zinc-300">Extra $50 on Buy-In</span>
      </div>
      <p class="text-xs text-red-400 mt-2">Refusal = $300 fine + next year's fee upfront OR removal</p>
    </div>

    <!-- Article XVI - Keeper Rule -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-teal-500/10 text-sm">🔒</div>
        <h2 class="text-lg font-bold text-teal-400">Article XVI — Keeper Rule</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Keepers Allowed</dt>
          <dd class="font-semibold text-zinc-100">1 Offense + 1 Defense</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Roster Requirement</dt>
          <dd class="text-zinc-200">Must be rostered by Week 8</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Keep Duration</dt>
          <dd class="text-zinc-200">1 season max</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Declaration Deadline</dt>
          <dd class="text-zinc-200">24 hrs before draft</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">New Team Owners</dt>
          <dd class="text-zinc-200">Can keep anyone on roster</dd>
        </div>
      </dl>
    </div>

    <!-- Article XVIII - Transactions -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-cyan-500/10 text-sm">📝</div>
        <h2 class="text-lg font-bold text-cyan-400">Article XVIII — Transactions & Waivers</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Max Transactions</dt>
          <dd class="font-semibold text-zinc-100">50 per manager</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Waiver Type</dt>
          <dd class="text-zinc-200">Free Agency only (no waivers)</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Emergency Exception</dt>
          <dd class="text-zinc-200">2/3 vote required</dd>
        </div>
      </dl>
    </div>

    <!-- Article XIV - Hall of Champions -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">🏅</div>
        <h2 class="text-lg font-bold text-amber-400">Article XIV — Hall of Champions</h2>
      </div>
      <p class="text-xs text-zinc-500 mb-3">Dynasty Recognition: 3+ titles in a row = permanent enshrinement</p>
      <div class="space-y-2 text-sm">
        <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <span class="text-zinc-400">2025</span>
          <span class="font-semibold text-zinc-100">Best Pacheco Hoe (jayyphilly)</span>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <span class="text-zinc-400">2024</span>
          <span class="font-semibold text-zinc-100">Take that Daak (DatDudeVic)</span>
        </div>
        <div class="flex items-center justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <span class="text-zinc-400">2023</span>
          <span class="font-semibold text-zinc-100">Hit and Ruggs (David)</span>
        </div>
      </div>
    </div>

    <!-- Article XV - Divisions -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-indigo-500/10 text-sm">⚔️</div>
        <h2 class="text-lg font-bold text-indigo-400">Article XV — Divisions & Rivalries</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Divisions</dt>
          <dd class="text-zinc-200">2 divisions of 7 teams</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Naming Rights</dt>
          <dd class="text-zinc-200">Champion names divisions</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Schedule</dt>
          <dd class="text-zinc-200">Balanced — play all once</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Rivalry Week</dt>
          <dd class="text-zinc-200">Included</dd>
        </div>
      </dl>
    </div>

    <!-- Article VII - Rule Changes -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-pink-500/10 text-sm">⚖️</div>
        <h2 class="text-lg font-bold text-pink-400">Article VII — Rule Changes</h2>
      </div>
      <dl class="space-y-2 text-sm">
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Preseason</dt>
          <dd class="text-zinc-200">2/3 majority</dd>
        </div>
        <div class="flex justify-between rounded-lg bg-zinc-800/20 px-3 py-2">
          <dt class="text-zinc-500">Midseason</dt>
          <dd class="text-zinc-200">Unanimous approval</dd>
        </div>
      </dl>
    </div>

    <!-- Article XVII - Trade Deadline Incentive -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-green-500/10 text-sm">🎯</div>
        <h2 class="text-lg font-bold text-green-400">Article XVII — Trade Deadline Incentive</h2>
      </div>
      <p class="text-sm text-zinc-300">Managers with 2+ trades before Week 10 enter a drawing. Most trades = top 1-3 draft picks entry pool.</p>
    </div>

    <!-- Article XIX - Midseason Check-In -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-yellow-500/10 text-sm">📅</div>
        <h2 class="text-lg font-bold text-yellow-400">Article XIX — Midseason Check-In</h2>
      </div>
      <p class="text-sm text-zinc-300">Held Weeks 7-8. Discusses payouts, engagement, and rules.</p>
    </div>

    <!-- Article XX - Payout Ledger -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-sky-500/10 text-sm">📊</div>
        <h2 class="text-lg font-bold text-sky-400">Article XX — Payout Ledger</h2>
      </div>
      <p class="text-sm text-zinc-300">Weekly payouts tracked in Excel Online (TINEZFFL.xlsx). Screenshot posted weekly in chat. End-of-season report shows all money collected and paid.</p>
    </div>

    <!-- Article XXI - Keeper Clarification -->
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-3">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-teal-500/10 text-sm">📌</div>
        <h2 class="text-lg font-bold text-teal-400">Article XXI — Keeper Clarification</h2>
      </div>
      <ul class="space-y-2 text-sm text-zinc-300 list-disc list-inside">
        <li>The "--empty--" draft slot from Round 21 is officially Aaron Donald</li>
        <li>Each team keeps 1 offensive + 1 defensive player only</li>
        <li>No player from Rounds 21 & 22 may be kept again</li>
        <li>New team owners may select keepers from current roster, including previously kept players</li>
      </ul>
    </div>
  </div>

  <!-- Resource Guide -->
  <div class="mt-8">
    <div class="glass-card rounded-xl p-6">
      <div class="flex items-center gap-2 mb-4">
        <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-amber-500/10 text-sm">📚</div>
        <h2 class="text-lg font-bold text-amber-400">Resource Guide for New Managers</h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2">
        <div>
          <h3 class="text-sm font-semibold text-zinc-200 mb-2">Understanding Half-PPR</h3>
          <ul class="space-y-1 text-xs text-zinc-400 list-disc list-inside">
            <li>WRs and pass-catching RBs gain more value</li>
            <li><a href="https://help.yahoo.com/kb/fantasy-football-scoring" target="_blank" class="text-amber-400 hover:text-amber-300">Yahoo Scoring Help</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-zinc-200 mb-2">Draft & Rankings</h3>
          <ul class="space-y-1 text-xs text-zinc-400 list-disc list-inside">
            <li><a href="https://football.fantasysports.yahoo.com/f1/draftanalysis" target="_blank" class="text-amber-400 hover:text-amber-300">Yahoo Pre-Draft Rankings</a></li>
            <li>CBS Fantasy Football Today Podcast</li>
            <li>Fantasy Footballers (Foot Clan)</li>
            <li>The Ringer Fantasy Football Show</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-zinc-200 mb-2">Weekly Lineup Help</h3>
          <ul class="space-y-1 text-xs text-zinc-400 list-disc list-inside">
            <li>Yahoo "Who Should I Start?" Tool</li>
            <li><a href="https://www.fantasypros.com/nfl/start-sit/" target="_blank" class="text-amber-400 hover:text-amber-300">FantasyPros Start/Sit</a></li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-zinc-200 mb-2">Position Tips (Half-PPR)</h3>
          <ul class="space-y-1 text-xs text-zinc-400 list-disc list-inside">
            <li>QB — Only need 1; mid-round value</li>
            <li>RB — Pass-catching RBs are gold</li>
            <li>WR — Most valuable position in Half-PPR</li>
            <li>TE — Only a few elite; stream weekly</li>
            <li>K/DEF — Draft last; stream matchups</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-zinc-200 mb-2">Waiver Wire</h3>
          <ul class="space-y-1 text-xs text-zinc-400 list-disc list-inside">
            <li><a href="https://www.fantasypros.com/nfl/waiver-wire/" target="_blank" class="text-amber-400 hover:text-amber-300">FantasyPros Waiver Rankings</a></li>
            <li>Yahoo Waiver Wire Articles (in app)</li>
          </ul>
        </div>
        <div>
          <h3 class="text-sm font-semibold text-zinc-200 mb-2">Trade Analyzer</h3>
          <ul class="space-y-1 text-xs text-zinc-400 list-disc list-inside">
