---
import Layout from "../layouts/Layout.astro";
import { LEAGUE_CONFIG } from "../data/sleeper-api";
---

<Layout title="Constitution">
  <div class="mb-8">
    <div class="relative overflow-hidden rounded-2xl border border-amber-500/20">
      <div class="hero-gradient absolute inset-0 animate-gradient"></div>
      <div class="relative z-10 p-8">
        <div class="flex items-center gap-3 mb-2">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-gradient-to-br from-amber-400 to-orange-500 text-lg font-bold text-white shadow-lg shadow-amber-500/20">📜</div>
          <div>
            <h1 class="text-2xl md:text-3xl font-extrabold tracking-tight">
              <span class="gradient-text">League Constitution</span>
            </h1>
            <p class="text-zinc-400 text-sm mt-0.5">TINEZ LEAGUE · Official Rules & Bylaws · Established 2014</p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Quick Links -->
  <div class="flex gap-2 mb-6 overflow-x-auto pb-2">
    <a href="#overview" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Overview</a>
    <a href="#scoring" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Scoring</a>
    <a href="#rosters" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Rosters</a>
    <a href="#draft" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Draft</a>
    <a href="#keepers" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Keepers</a>
    <a href="#playoffs" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Playoffs</a>
    <a href="#finances" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Finances</a>
    <a href="#conduct" class="flex-shrink-0 rounded-lg bg-zinc-800/50 px-3 py-1.5 text-xs font-medium text-zinc-400 hover:text-zinc-200 border border-zinc-700/30 transition-all">Conduct</a>
  </div>

  <!-- Overview -->
  <div id="overview" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">📋</span>
      <h2 class="text-lg font-bold text-amber-400">1. League Overview</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">League Name:</strong> TINEZ LEAGUE</p>
      <p><strong class="text-zinc-200">Established:</strong> 2014</p>
      <p><strong class="text-zinc-200">Commissioner:</strong> Carlitos</p>
      <p><strong class="text-zinc-200">Number of Teams:</strong> 14</p>
      <p><strong class="text-zinc-200">Platform:</strong> Yahoo Fantasy Sports</p>
      <p><strong class="text-zinc-200">Scoring Type:</strong> Head-to-Head</p>
      <p><strong class="text-zinc-200">Format:</strong> 0.5 PPR · IDP · 6pt Passing TD</p>
      <p><strong class="text-zinc-200">Season Length:</strong> 18 weeks regular season + 3 weeks playoffs</p>
    </div>
  </div>

  <!-- Scoring -->
  <div id="scoring" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">📊</span>
      <h2 class="text-lg font-bold text-amber-400">2. Scoring Rules</h2>
    </div>
    <div class="space-y-4">
      <div>
        <h3 class="text-sm font-bold text-zinc-200 mb-2">Offensive Scoring</h3>
        <div class="bg-zinc-800/30 rounded-lg p-3">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-zinc-500">
                <th class="text-left pb-1">Category</th>
                <th class="text-right pb-1">Points</th>
              </tr>
            </thead>
            <tbody class="text-zinc-400">
              <tr><td class="py-0.5">Passing TD</td><td class="text-right font-mono text-emerald-400">6</td></tr>
              <tr><td class="py-0.5">Passing Yard</td><td class="text-right font-mono">25 yds/pt</td></tr>
              <tr><td class="py-0.5">Interception</td><td class="text-right font-mono text-red-400">-3</td></tr>
              <tr><td class="py-0.5">Rushing/Receiving TD</td><td class="text-right font-mono text-emerald-400">6</td></tr>
              <tr><td class="py-0.5">Rushing/Receiving Yard</td><td class="text-right font-mono">10 yds/pt</td></tr>
              <tr><td class="py-0.5">Reception</td><td class="text-right font-mono text-emerald-400">0.5</td></tr>
              <tr><td class="py-0.5">2-Point Conversion</td><td class="text-right font-mono">2</td></tr>
              <tr><td class="py-0.5">Fumble Lost</td><td class="text-right font-mono text-red-400">-2</td></tr>
              <tr><td class="py-0.5">Sack (QB)</td><td class="text-right font-mono text-red-400">-2</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-bold text-zinc-200 mb-2">IDP Scoring</h3>
        <div class="bg-zinc-800/30 rounded-lg p-3">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-zinc-500">
                <th class="text-left pb-1">Category</th>
                <th class="text-right pb-1">Points</th>
              </tr>
            </thead>
            <tbody class="text-zinc-400">
              <tr><td class="py-0.5">Solo Tackle</td><td class="text-right font-mono text-emerald-400">1.5</td></tr>
              <tr><td class="py-0.5">Assisted Tackle</td><td class="text-right font-mono">0.5</td></tr>
              <tr><td class="py-0.5">Sack</td><td class="text-right font-mono text-emerald-400">3</td></tr>
              <tr><td class="py-0.5">Interception</td><td class="text-right font-mono text-emerald-400">3</td></tr>
              <tr><td class="py-0.5">Forced Fumble</td><td class="text-right font-mono">2</td></tr>
              <tr><td class="py-0.5">Fumble Recovery</td><td class="text-right font-mono">2</td></tr>
              <tr><td class="py-0.5">Pass Defensed</td><td class="text-right font-mono">1</td></tr>
              <tr><td class="py-0.5">Tackle for Loss</td><td class="text-right font-mono">0.5</td></tr>
              <tr><td class="py-0.5">Blocked Kick</td><td class="text-right font-mono">3</td></tr>
              <tr><td class="py-0.5">Safety</td><td class="text-right font-mono">2</td></tr>
              <tr><td class="py-0.5">Defensive TD</td><td class="text-right font-mono text-emerald-400">6</td></tr>
            </tbody>
          </table>
        </div>
      </div>
      <div>
        <h3 class="text-sm font-bold text-zinc-200 mb-2">Kicking & Special Teams</h3>
        <div class="bg-zinc-800/30 rounded-lg p-3">
          <table class="w-full text-xs">
            <thead>
              <tr class="text-zinc-500">
                <th class="text-left pb-1">Category</th>
                <th class="text-right pb-1">Points</th>
              </tr>
            </thead>
            <tbody class="text-zinc-400">
              <tr><td class="py-0.5">Field Goal 0-39 yds</td><td class="text-right font-mono">3</td></tr>
              <tr><td class="py-0.5">Field Goal 40-49 yds</td><td class="text-right font-mono">4</td></tr>
              <tr><td class="py-0.5">Field Goal 50+ yds</td><td class="text-right font-mono">5</td></tr>
              <tr><td class="py-0.5">Extra Point</td><td class="text-right font-mono">1</td></tr>
              <tr><td class="py-0.5">Extra Point Returned</td><td class="text-right font-mono text-emerald-400">6</td></tr>
              <tr><td class="py-0.5">Return Yards</td><td class="text-right font-mono">25 yds/pt</td></tr>
              <tr><td class="py-0.5">Return TD</td><td class="text-right font-mono text-emerald-400">6</td></tr>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>

  <!-- Rosters -->
  <div id="rosters" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">👥</span>
      <h2 class="text-lg font-bold text-amber-400">3. Roster Rules</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">Starting Lineup:</strong> 1 QB, 2 RB, 2 WR, 1 TE, 2 FLEX (RB/WR/TE), 1 K, 3 DL, 3 LB, 3 DB, 1 DEF</p>
      <p><strong class="text-zinc-200">Bench:</strong> 7 spots</p>
      <p><strong class="text-zinc-200">IR Spots:</strong> 2</p>
      <p><strong class="text-zinc-200">Total Roster:</strong> 25 players</p>
      <p><strong class="text-zinc-200">Position Limits:</strong> None</p>
      <p><strong class="text-zinc-200">Waiver Type:</strong> FAAB (Free Agent Acquisition Budget)</p>
      <p><strong class="text-zinc-200">FAAB Budget:</strong> $100 per season</p>
      <p><strong class="text-zinc-200">Waiver Period:</strong> 2 days after games</p>
      <p><strong class="text-zinc-200">Trade Deadline:</strong> Week 12</p>
      <p><strong class="text-zinc-200">Trade Review:</strong> Commissioner approval (no veto unless collusion)</p>
    </div>
  </div>

  <!-- Draft -->
  <div id="draft" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">📋</span>
      <h2 class="text-lg font-bold text-amber-400">4. Draft Rules</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">Draft Type:</strong> Snake (non-linear)</p>
      <p><strong class="text-zinc-200">Draft Order:</strong> Determined by previous season's finish (reverse order of standings)</p>
      <p><strong class="text-zinc-200">Rounds:</strong> 18 rounds</p>
      <p><strong class="text-zinc-200">Time Per Pick:</strong> 90 seconds</p>
      <p><strong class="text-zinc-200">Draft Style:</strong> Live online (in-person when possible)</p>
      <p><strong class="text-zinc-200">Keeper Declaration:</strong> 24 hours before draft</p>
    </div>
  </div>

  <!-- Keepers -->
  <div id="keepers" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">🔄</span>
      <h2 class="text-lg font-bold text-amber-400">5. Keeper Rules</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">Format:</strong> 1+1 Keeper (1 player kept + 1 rookie kept)</p>
      <p><strong class="text-zinc-200">Cost:</strong> Player costs the round they were drafted in the previous year</p>
      <p><strong class="text-zinc-200">Undrafted Players:</strong> Cost a last-round pick</p>
      <p><strong class="text-zinc-200">Rookie Exception:</strong> Rookies can be kept for a 16th-round pick regardless of where drafted</p>
      <p><strong class="text-zinc-200">Max Keep:</strong> A player cannot be kept more than 2 consecutive seasons</p>
      <p><strong class="text-zinc-200">Declaration:</strong> Keepers must be declared 24 hours before the draft</p>
      <p><strong class="text-zinc-200">Traded Players:</strong> Keeper rights transfer with the player in trades</p>
    </div>
  </div>

  <!-- Playoffs -->
  <div id="playoffs" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">🏆</span>
      <h2 class="text-lg font-bold text-amber-400">6. Playoff Rules</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">Teams:</strong> 6 teams qualify (top 6 of 14)</p>
      <p><strong class="text-zinc-200">Format:</strong> Seeds 1-2 get first-round bye</p>
      <p><strong class="text-zinc-200">Quarterfinals:</strong> Week 15 — (3) vs (6), (4) vs (5)</p>
      <p><strong class="text-zinc-200">Semifinals:</strong> Week 16 — (1) vs lowest winner, (2) vs highest winner</p>
      <p><strong class="text-zinc-200">Championship:</strong> Week 17 — Super Bowl LX</p>
      <p><strong class="text-zinc-200">Tiebreaker:</strong> Higher seed wins tie</p>
      <p><strong class="text-zinc-200">Consolation:</strong> Non-playoff teams play for draft position</p>
    </div>
  </div>

  <!-- Finances -->
  <div id="finances" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">💰</span>
      <h2 class="text-lg font-bold text-amber-400">7. Financial Rules</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">Buy-In:</strong> $150 per team per season</p>
      <p><strong class="text-zinc-200">Total Pool:</strong> $2,100</p>
      <p><strong class="text-zinc-200">1st Place:</strong> $1,400</p>
      <p><strong class="text-zinc-200">2nd Place:</strong> $700</p>
      <p><strong class="text-zinc-200">3rd Place:</strong> $350</p>
      <p><strong class="text-zinc-200">Regular Season Champion:</strong> $100</p>
      <p><strong class="text-zinc-200">Weekly High Score:</strong> $25 (Weeks 1-14)</p>
      <p><strong class="text-zinc-200">Payment Due:</strong> Before the annual draft</p>
      <p><strong class="text-zinc-200">Late Payment:</strong> Team is ineligible to draft until dues are paid</p>
    </div>
  </div>

  <!-- Conduct -->
  <div id="conduct" class="glass-card rounded-xl p-6 mb-6">
    <div class="flex items-center gap-2 mb-4">
      <span class="text-lg">⚖️</span>
      <h2 class="text-lg font-bold text-amber-400">8. League Conduct</h2>
    </div>
    <div class="space-y-3 text-sm text-zinc-400">
      <p><strong class="text-zinc-200">Collusion:</strong> Zero tolerance. Any team found colluding will be expelled from the league.</p>
      <p><strong class="text-zinc-200">Tanking:</strong> Intentional tanking for better draft position is prohibited.</p>
      <p><strong class="text-zinc-200">Inactive Teams:</strong> Teams that fail to set lineups for 3 consecutive weeks may be removed.</p>
      <p><strong class="text-zinc-200">Trash Talk:</strong> Encouraged. If you dish it, you must be able to take it.</p>
      <p><strong class="text-zinc-200">Rule Changes:</strong> Proposed during offseason. Requires majority vote (7 of 14).</p>
      <p><strong class="text-zinc-200">Commissioner Authority:</strong> Commissioner has final say on all disputes. Decisions can be appealed to the league.</p>
      <p><strong class="text-zinc-200">Punishment:</strong> Last place must complete league-assigned punishment before next year's draft or forfeit league membership.</p>
    </div>
  </div>

  <!-- Last Updated -->
  <div class="text-center text-xs text-zinc-600 mt-8">
    Last updated: {LEAGUE_CONFIG.season} Season · Questions? Contact the Commissioner
  </div>
</Layout>
