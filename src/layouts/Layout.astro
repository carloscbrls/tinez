    <!-- Footer -->
    <footer class="border-t border-zinc-800/40 mt-12 bg-zinc-950/50">
      <div class="mx-auto max-w-6xl px-4 py-10">
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-4">
          <!-- League Info -->
          <div>
            <div class="flex items-center gap-2 mb-3">
              <span class="flex h-7 w-7 items-center justify-center rounded-md bg-gradient-to-br from-amber-400 to-orange-500 text-xs font-bold text-white">T</span>
              <span class="text-sm font-bold gradient-text">Tinez League</span>
            </div>
            <p class="text-xs text-zinc-500 leading-relaxed">
              The most competitive 14-team keeper league in fantasy football. 
              Established 2014. 0.5 PPR. IDP. 3-time champion Carlitos.
            </p>
            <div class="mt-3 flex items-center gap-2">
              <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
              <span class="text-[10px] text-zinc-600">2026 Season Active</span>
            </div>
          </div>

          <!-- Quick Links -->
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">Quick Links</h3>
            <div class="grid grid-cols-2 gap-1.5">
              <a href="/" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Standings</a>
