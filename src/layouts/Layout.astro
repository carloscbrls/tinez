              <a href="/teams" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Teams</a>
              <a href="/matchups" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Matchups</a>
              <a href="/draft" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Draft</a>
              <a href="/rules" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Rules</a>
              <a href="/transactions" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Transactions</a>
              <a href="/trending" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Trending</a>
              <a href="/power-rankings" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Power Rankings</a>
              <a href="/records" class="text-xs text-zinc-500 hover:text-amber-400 transition-colors">Records</a>
            </div>
          </div>

          <!-- Commissioner -->
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">Commissioner</h3>
            <div class="space-y-2 text-xs">
              <div class="flex items-center gap-2">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-amber-500/10 text-[10px]">👑</span>
                <span class="text-zinc-300 font-medium">Carlos Cabrales III</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-zinc-800/50 text-[10px]">📧</span>
                <a href="mailto:carloscbrls@gmail.com" class="text-zinc-500 hover:text-amber-400 transition-colors">carloscbrls@gmail.com</a>
              </div>
              <div class="flex items-center gap-2">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-zinc-800/50 text-[10px]">📞</span>
                <span class="text-zinc-500">(209) 423-6633</span>
              </div>
              <div class="flex items-center gap-2">
                <span class="flex h-6 w-6 items-center justify-center rounded bg-zinc-800/50 text-[10px]">🏆</span>
                <span class="text-zinc-500">3x Champion</span>
              </div>
            </div>
          </div>

          <!-- League Info -->
          <div>
            <h3 class="text-xs font-semibold uppercase tracking-wider text-zinc-500 mb-3">League Details</h3>
            <div class="space-y-1.5 text-xs">
              <div class="flex justify-between">
                <span class="text-zinc-500">Teams</span>
                <span class="text-zinc-300 font-medium">14</span>
              </div>
              <div class="flex justify-between">
                <span class="text-zinc-500">Format</span>
                <span class="text-zinc-300 font-medium">Keeper (1+1)</span>
              </div>
              <div class="flex justify-between">
                <span class="text-zinc-500">Scoring</span>
                <span class="text-zinc-300 font-medium">0.5 PPR</span>
              </div>
              <div class="flex justify-between">
                <span class="text-zinc-500">Entry Fee</span>
